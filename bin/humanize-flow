yolo_completed_child_task_ids() {
  local slug
  slug="$1"
  command_exists bd || die "YOLO Epic mode requires bd CLI so it can query child task status."
  run_python3 - "$(handoff_path "$slug")" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)

task_ids = [
    task.get('bd_id')
    for task in (data.get('bd') or {}).get('tasks') or []
    if isinstance(task, dict) and task.get('bd_id')
]
closed_statuses = {'closed', 'done', 'complete', 'completed', 'resolved'}

for task_id in task_ids:
    result = subprocess.run(
        ['bd', 'show', task_id, '--json'],
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        raise SystemExit(1)
    try:
        raw = json.loads(result.stdout)
    except Exception:
        raise SystemExit(1)
    if isinstance(raw, list):
        item = next((entry for entry in raw if isinstance(entry, dict) and entry.get('id') == task_id), None)
        if item is None and raw and isinstance(raw[0], dict):
            item = raw[0]
    elif isinstance(raw, dict):
        item = raw
    else:
        item = None
    if not isinstance(item, dict):
        continue
    status = str(item.get('status') or '').lower()
    if status in closed_statuses or item.get('closed_at'):
        print(task_id)
PY
}

yolo_in_progress_child_task_ids() {
  local slug completed_csv
  slug="$1"; completed_csv="${2:-}"
  command_exists bd || die "YOLO Epic mode requires bd CLI so it can query child task status."
  run_python3 - "$(handoff_path "$slug")" "$completed_csv" <<'PY'
import json
import subprocess
import sys
from pathlib import Path

path = Path(sys.argv[1])
completed = {item for item in sys.argv[2].split(',') if item}
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)

task_ids = [
    task.get('bd_id')
    for task in (data.get('bd') or {}).get('tasks') or []
    if isinstance(task, dict) and task.get('bd_id')
]
active_statuses = {'in_progress', 'in-progress', 'active', 'started', 'doing', 'wip'}

for task_id in task_ids:
    if task_id in completed:
        continue
    result = subprocess.run(
        ['bd', 'show', task_id, '--json'],
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        raise SystemExit(1)
    try:
        raw = json.loads(result.stdout)
    except Exception:
        raise SystemExit(1)
    if isinstance(raw, list):
        item = next((entry for entry in raw if isinstance(entry, dict) and entry.get('id') == task_id), None)
        if item is None and raw and isinstance(raw[0], dict):
            item = raw[0]
    elif isinstance(raw, dict):
        item = raw
    else:
        item = None
    if not isinstance(item, dict):
        continue
    status = str(item.get('status') or '').lower()
    if status in active_statuses:
        print(task_id)
PY
}

yolo_ref_is_epic_scope() {
  local ref slug
  ref="$1"; slug="$2"
  run_python3 - "$(handoff_path "$slug")" "$ref" "$slug" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
ref = sys.argv[2]
slug = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)
epic = (data.get('bd') or {}).get('epic') or {}
epic_id = epic.get('bd_id') if isinstance(epic, dict) else None
if ref in {slug, data.get('slug'), path.stem} or (epic_id and ref == epic_id):
    raise SystemExit(0)
raise SystemExit(1)
PY
}

yolo_ready_child_task_ids() {
  local slug completed_csv tmp
  slug="$1"; completed_csv="${2:-}"
  command_exists bd || die "YOLO Epic mode requires bd CLI so it can query ready child tasks dynamically."
  tmp="$(state_dir)/tmp/bd-ready-yolo-$(timestamp).json"
  mkdir -p "$(dirname "$tmp")"
  bd ready --json > "$tmp"
  run_python3 - "$(handoff_path "$slug")" "$tmp" "$completed_csv" <<'PY'
import json
import sys
from pathlib import Path

handoff_path = Path(sys.argv[1])
ready_path = Path(sys.argv[2])
completed = {item for item in sys.argv[3].split(',') if item}
try:
    handoff = json.loads(handoff_path.read_text(encoding='utf-8'))
    ready_data = json.loads(ready_path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)

ordered = [
    task.get('bd_id')
    for task in (handoff.get('bd') or {}).get('tasks') or []
    if isinstance(task, dict) and task.get('bd_id')
]
remaining = {task_id for task_id in ordered if task_id not in completed}

if isinstance(ready_data, dict):
    items = ready_data.get('issues') or ready_data.get('items') or ready_data.get('data') or ready_data.get('ready') or []
elif isinstance(ready_data, list):
    items = ready_data
else:
    items = []

def item_id(item):
    if not isinstance(item, dict):
        return None
    for key in ('id', 'issue_id', 'bead_id'):
        value = item.get(key)
        if isinstance(value, str) and value:
            return value
    return None

seen = set()
for item in items:
    task_id = item_id(item)
    if task_id in remaining and task_id not in seen:
        seen.add(task_id)
        print(task_id)
PY
}

yolo_mark_child_complete() {
  local task_id review_path reason
  task_id="$1"; review_path="$2"
  command_exists bd || die "YOLO Epic mode requires bd CLI so it can advance completed child tasks."
  reason="Humanize Flow YOLO review passed"
  if [ -n "$review_path" ]; then
    reason="$reason: $(repo_relative_path "$review_path")"
  fi
  if ! bd close "$task_id" --reason "$reason" >/dev/null; then
    die "YOLO Epic mode could not close completed Beads task: $task_id"
  fi
}

yolo_mark_child_implemented() {
  local task_id reason
  task_id="$1"
  command_exists bd || die "YOLO Epic mode requires bd CLI so it can advance implemented child tasks."
  reason="Humanize Flow YOLO final-review mode completed implementation; final Epic review pending"
  if ! bd close "$task_id" --reason "$reason" >/dev/null; then
    die "YOLO Epic final-review mode could not close implemented Beads task: $task_id"
  fi
}

yolo_mark_epic_in_progress() {
  local epic_id
  epic_id="$1"
  [ -n "$epic_id" ] || return 0
  command_exists bd || die "YOLO Epic mode requires bd CLI so it can mark the Epic in progress."
  if ! bd update "$epic_id" --status in_progress >/dev/null; then
    die "YOLO Epic mode could not mark Beads Epic in progress: $epic_id"
  fi
}

latest_review_for_slug() {
  local slug ref review_dir
  slug="$1"; ref="${2:-}"
  review_dir="$(docs_dir)/$slug/reviews"
  [ -d "$review_dir" ] || return 1
  run_python3 - "$review_dir" "$ref" <<'PY'
import sys
from pathlib import Path
import re

review_dir = Path(sys.argv[1])
ref = sys.argv[2]
paths = []
patterns = [
    re.compile(r'^\s*Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\s*$', re.I | re.M),
    re.compile(r'^\s*(?:[-*]\s*)?(?:verdict|final verdict)\s*[:：]\s*`?(pass|changes_requested|blocked)`?\b', re.I | re.M),
    re.compile(r'^\s*`(pass|changes_requested|blocked)`\s*$', re.I | re.M),
    re.compile(r'^\s*(pass|changes_requested|blocked)\s*$', re.I | re.M),
]
for path in sorted(review_dir.glob('*.md')):
    try:
        if path.stat().st_size <= 0:
            continue
        text = path.read_text(encoding='utf-8', errors='replace')
    except OSError:
        continue
    if not any(pattern.search(text) for pattern in patterns):
        continue
    if ref:
        name = path.name
        if not (name.endswith(f'-{ref}.md') or name.endswith(f'-{ref}-human-feedback.md')):
            continue
    paths.append(path)
if not paths:
    raise SystemExit(1)
print(paths[-1])
PY
}

review_verdict() {
  local review_file
  review_file="$1"
  [ -f "$review_file" ] || return 1
  run_python3 - "$review_file" <<'PY'
import re
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text(encoding='utf-8', errors='replace')
patterns = [
    r'(?im)^\s*Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\s*$',
    r'(?im)^\s*(?:[-*]\s*)?(?:verdict|final verdict)\s*[:：]\s*`?(pass|changes_requested|blocked)`?\b',
    r'(?im)^\s*`(pass|changes_requested|blocked)`\s*$',
    r'(?im)^\s*(pass|changes_requested|blocked)\s*$',
]
for pattern in patterns:
    match = re.search(pattern, text)
    if match:
        print(match.group(1).lower())
        raise SystemExit(0)
embedded = re.findall(r'(?i)Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\b', text)
unique = sorted({item.lower() for item in embedded})
if len(unique) == 1:
    print(unique[0])
    raise SystemExit(0)
raise SystemExit(1)
PY
}

normalize_review_output() {
  local raw_file output_file
  raw_file="$1"; output_file="$2"
  [ -f "$raw_file" ] || return 1
  run_python3 - "$raw_file" "$output_file" <<'PY'
import re
import sys
from pathlib import Path

raw_path = Path(sys.argv[1])
output_path = Path(sys.argv[2])
text = raw_path.read_text(encoding='utf-8', errors='replace').replace('\ufeff', '')
lines = text.splitlines()

canonical = re.compile(r'^\s*Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\s*$', re.I)
embedded = re.compile(r'Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\b', re.I)

first_non_empty = next((idx for idx, line in enumerate(lines) if line.strip()), None)
if first_non_empty is not None:
    match = canonical.match(lines[first_non_empty])
    if match:
        output_path.write_text(text.rstrip() + '\n', encoding='utf-8')
        print('unchanged')
        raise SystemExit(0)

verdicts = []
canonical_line = None
embedded_line = None
for idx, line in enumerate(lines):
    match = canonical.match(line)
    if match:
        verdicts.append(match.group(1).lower())
        if canonical_line is None:
            canonical_line = idx
        continue
    match = embedded.search(line)
    if match:
        verdicts.append(match.group(1).lower())
        if embedded_line is None:
            embedded_line = idx

unique_verdicts = sorted(set(verdicts))
if len(unique_verdicts) != 1:
    raise SystemExit(1)

verdict = unique_verdicts[0]
source_line = canonical_line if canonical_line is not None else embedded_line
if source_line is None:
    raise SystemExit(1)

body_start = None
for idx in range(source_line + 1, len(lines)):
    if re.match(r'^\s*#{1,6}\s+\S', lines[idx]):
        body_start = idx
        break
if body_start is None:
    for idx in range(source_line + 1, len(lines)):
        if lines[idx].strip():
            body_start = idx
            break

if body_start is None:
    body = text.strip()
else:
    body = '\n'.join(lines[body_start:]).strip()
if not body:
    body = text.strip()
if not body.lstrip().startswith('#'):
    body = '## Original Codex output\n\n' + body

output_path.write_text(f'Humanize-Flow-Verdict: {verdict}\n\n{body.rstrip()}\n', encoding='utf-8')
print('normalized')
PY
}

handoff_artifact_path() {
  local slug key file value root
  slug="$1"; key="$2"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || return 1
  value="$(json_get "$file" "artifacts.$key" "")"
  [ -n "$value" ] || return 1
  root="$(repo_root)"
  case "$value" in
    /*) printf '%s\n' "$value" ;;
    *) printf '%s/%s\n' "$root" "$value" ;;
  esac
}

ensure_approved_handoff_for_slug() {
  local slug file
  slug="$1"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || die "handoff not found for yolo run: $file"
  run_python3 - "$file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception as exc:
    raise SystemExit(f'invalid handoff JSON: {path}: {exc}')
if data.get('approval', {}).get('status') != 'approved':
    raise SystemExit(f'handoff is not approved: {path}')
PY
}

set_handoff_artifact() {
  local slug key value file
  slug="$1"; key="$2"; value="$3"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || return 0
  run_python3 - "$file" "$key" "$value" <<'PY'
import json, sys, datetime
from pathlib import Path

path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(0)
artifacts = data.setdefault('artifacts', {})
artifacts[key] = value
data['updated_at'] = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n', encoding='utf-8')
PY
}

verification_artifact_for_review() {
  local review_file
  review_file="$1"
  run_python3 - "$review_file" "$(repo_root)" "$(state_dir)" <<'PY'
import re
import sys
from pathlib import Path

review = Path(sys.argv[1])
repo = Path(sys.argv[2])
state_dir = Path(sys.argv[3])
try:
    rel = review.resolve().relative_to(repo.resolve())
except Exception:
    rel = Path(re.sub(r'[^A-Za-z0-9_.-]+', '-', str(review)).strip('-'))
safe = re.sub(r'[^A-Za-z0-9_.-]+', '-', str(rel)).strip('-')
if safe.endswith('.md'):
    safe = safe[:-3]
print(state_dir / 'verifications' / f'{safe}.json')
PY
}

verification_artifact_for_ref() {
  local ref bd_id slug stamp
  ref="$1"; bd_id="${2:-}"; slug="${3:-}"; stamp="$(timestamp)"
  run_python3 - "$ref" "$bd_id" "$slug" "$(state_dir)" "$stamp" <<'PY'
import re
import sys
from pathlib import Path

ref = sys.argv[1]
bd_id = sys.argv[2]
slug = sys.argv[3]
state_dir = Path(sys.argv[4])
stamp = sys.argv[5]
raw = bd_id or ref or slug or 'manual'
safe = re.sub(r'[^A-Za-z0-9_.-]+', '-', raw).strip('-') or 'manual'
print(state_dir / 'verifications' / f'manual-{safe}-{stamp}.json')
PY
}

latest_verification_for_slug() {
  local slug ref review_file verification_file
  slug="$1"; ref="${2:-}"
  review_file="$(latest_review_for_slug "$slug" "$ref" 2>/dev/null || true)"
  [ -n "$review_file" ] || return 1
  verification_file="$(verification_artifact_for_review "$review_file")"
  [ -f "$verification_file" ] || return 1
  printf '%s\n' "$verification_file"
}

yolo_retry_hint() {
  local ref max_round retry retry_delay review_strategy
  ref="$1"; max_round="$2"; retry="$3"; retry_delay="$4"; review_strategy="${5:-each-task}"
  printf 'humanize-flow run %s --yolo' "$ref"
  if [ "$review_strategy" = "final" ]; then
    printf ' --review-at-end'
  fi
  printf ' --max-round %s --retry %s --retry-delay %s\n' "$max_round" "$retry" "$retry_delay"
}

yolo_phase_with_retries() {
  local attempts delay phase target attempt status
  attempts="$1"; delay="$2"; phase="$3"; target="$4"; shift 4
  attempt=1
  while :; do
    if ( "$@" ); then
      return 0
    fi
    status=$?
    if [ "$attempt" -ge "$attempts" ]; then
      warn "YOLO phase failed after $attempts attempt(s): $phase for $target"
      return "$status"
    fi
    warn "YOLO phase failed (attempt $attempt/$attempts): $phase for $target; retrying in ${delay}s"
    if [ "$delay" -gt 0 ]; then sleep "$delay"; fi
    attempt=$((attempt + 1))
  done
}

yolo_latest_pass_review() {
  local slug target_id latest_review verdict
  slug="$1"; target_id="$2"
  latest_review="$(latest_review_for_slug "$slug" "$target_id" 2>/dev/null || true)"
  [ -n "$latest_review" ] || return 1
  verdict="$(review_verdict "$latest_review" 2>/dev/null || true)"
  [ "$verdict" = "pass" ] || return 1
  printf '%s\n' "$latest_review"
}

cmd_run_once() {
  require_git_repo
  local ref mode model permission_mode output_format verbose partial hook_events humanize_mode
  local bd_id slug file latest_review latest_review_display plan_path plan_display humanize_text run_dir prompt_file final_file raw_file skill_file skill_text prompt_text claude_args claude_env_file
  ref="$1"; mode="$2"; model="$3"; permission_mode="$4"; output_format="$5"; verbose="$6"; partial="$7"; hook_events="$8"; humanize_mode="$9"; claude_env_file="${10:-}"
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG"
  [ -n "$model" ] || die "Claude model cannot be empty."
  [ -n "$permission_mode" ] || die "Claude permission mode cannot be empty."
  humanize_mode="$(normalize_humanize_mode "$humanize_mode")" || die "Unsupported Claude humanize mode: $humanize_mode (supported: required, auto, off)"
  command_exists claude || die "claude CLI not found."
  command_exists bd || warn "bd CLI not found; worker prompt will still reference task id."
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then bd_id="$(bd_id_for_ref_and_slug "$ref" "$slug" 2>/dev/null || true)"; fi
  if [ -z "$bd_id" ]; then bd_id="$ref"; fi
  if [ -n "$slug" ]; then file="$(handoff_path "$slug")"; else file=""; fi
  if [ -n "$slug" ]; then latest_review="$(latest_review_for_slug "$slug" "$bd_id" 2>/dev/null || true)"; else latest_review=""; fi
  if [ -n "$latest_review" ]; then latest_review_display="$(repo_relative_path "$latest_review")"; else latest_review_display=""; fi
  if [ -n "$slug" ]; then plan_path="$(handoff_artifact_path "$slug" "plan" 2>/dev/null || true)"; else plan_path=""; fi
  if [ -n "$plan_path" ]; then plan_display="$(repo_relative_path "$plan_path")"; else plan_display="not-found"; fi
  ensure_humanize_available "$humanize_mode"
  if [ "$humanize_mode" = "required" ] && { [ -z "$plan_path" ] || [ ! -f "$plan_path" ]; }; then
    die "Claude humanize mode is required, but the approved plan artifact was not found for $ref. Expected plan path: $plan_display"
  fi
  claude_env_file="$(normalize_claude_env_file_value "$claude_env_file")"
  humanize_text="$(humanize_worker_instruction "$humanize_mode" "$plan_path")"
  run_dir="$(state_dir)/runs/$(timestamp)-run-$bd_id"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/claude-worker-prompt.md"
  final_file="$run_dir/claude-final.md"
  raw_file="$run_dir/claude-final.jsonl"
  skill_file="$(worker_skill_file || true)"

  if [ -n "$skill_file" ]; then skill_text="$(cat "$skill_file")"; else skill_text=""; fi

  cat > "$prompt_file" <<EOF
You are the Claude Code implementer in the Humanize Flow workflow.

Task id: $bd_id
Handoff slug: ${slug:-unknown}
Handoff path: ${file:-not-found}
Plan path: $plan_display
Latest review path: ${latest_review_display:-not-found}
Repository root: $(repo_root)

$(language_instruction)

Embedded worker skill instructions follow. Treat them as authoritative for this run.

--- BEGIN humanize-flow-worker SKILL.md ---
$skill_text
--- END humanize-flow-worker SKILL.md ---

Required behavior:
- Read the Beads task with: bd show $bd_id --json
- Read the approved handoff, plan, and acceptance criteria before implementing.
- If the approved handoff, plan, or acceptance criteria cannot be found, stop and report the missing artifact instead of implementing from the brief Beads task alone.
- If the latest review path is not "not-found", read that review as the current correction target before editing.
- Do not bulk-load docs/humanize-flow/${slug:-unknown}/reviews/ or older review reports. Inspect older reviews only when the latest review explicitly references them or the user asks for review history.
- Do not expand scope beyond this task.
$humanize_text
- Run relevant tests.
- Write an implementation summary under docs/humanize-flow/<slug>/implementation/ when a slug is known.
- Update Beads notes/status with what changed, tests run, and remaining risks.
- Stop with a clear summary and request Codex review via: humanize-flow review $bd_id
- Use the actual Beads task id in the review command. If you mention the handoff slug (${slug:-unknown}), present it only as an alternative supported by newer humanize-flow versions.
EOF

  info "worker prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  claude_args="${HUMANIZE_FLOW_CLAUDE_ARGS:-}"
  if [ -n "$claude_env_file" ]; then
    info "Claude env file: $(repo_relative_path "$(resolve_repo_path "$claude_env_file")")"
    load_claude_env_file "$claude_env_file"
  else
    info "Claude env file: disabled"
  fi
  if [ "$mode" = "interactive" ]; then
    info "starting Claude Code interactive worker session"
    info "model: $model"
    info "permission mode: $permission_mode"
    info "humanize mode: $humanize_mode"
    info "final output is not captured in print-mode log for interactive sessions"
    # shellcheck disable=SC2086
    claude --model "$model" --permission-mode "$permission_mode" $claude_args "$prompt_text"
  else
    info "starting Claude Code print worker session"
    info "model: $model"
    info "permission mode: $permission_mode"
    info "humanize mode: $humanize_mode"
    info "output format: $output_format"
    if [ "$output_format" = "stream-json" ]; then
      info "human-readable log: $final_file"
      info "raw stream log: $raw_file"
      if [ "$verbose" -eq 1 ]; then
        if [ "$partial" -eq 1 ] && [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages --include-hook-events --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$partial" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-hook-events --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        else
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        fi
      else
        if [ "$partial" -eq 1 ] && [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages --include-hook-events $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$partial" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-hook-events $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        else
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        fi
      fi
    else
      if [ "$verbose" -eq 1 ]; then
        # shellcheck disable=SC2086
        claude -p --model "$model" --permission-mode "$permission_mode" --output-format text --verbose $claude_args "$prompt_text" | tee "$final_file"
      else
        # shellcheck disable=SC2086
        claude -p --model "$model" --permission-mode "$permission_mode" --output-format text $claude_args "$prompt_text" | tee "$final_file"
      fi
    fi
  fi
}

cmd_run_codex_once() {
  require_git_repo
  local ref bd_id slug file latest_review latest_review_display plan_path plan_display acceptance_path acceptance_display run_dir prompt_file final_file prompt_text
  ref="$1"
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG"
  command_exists codex || die "codex CLI not found."
  command_exists bd || warn "bd CLI not found; worker prompt will still reference task id."
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  [ -n "$slug" ] || die "Codex worker requires an approved Humanize Flow handoff for: $ref"
  ensure_approved_handoff_for_slug "$slug"
  bd_id="$(bd_id_for_ref_and_slug "$ref" "$slug" 2>/dev/null || true)"
  [ -n "$bd_id" ] || bd_id="$ref"
  file="$(handoff_path "$slug")"
  latest_review="$(latest_review_for_slug "$slug" "$bd_id" 2>/dev/null || true)"
  if [ -z "$latest_review" ] && [ "$ref" != "$bd_id" ]; then
    latest_review="$(latest_review_for_slug "$slug" "$ref" 2>/dev/null || true)"
  fi
  if [ -n "$latest_review" ]; then latest_review_display="$(repo_relative_path "$latest_review")"; else latest_review_display="not-found"; fi
  plan_path="$(handoff_artifact_path "$slug" "plan" 2>/dev/null || true)"
  if [ -n "$plan_path" ]; then plan_display="$(repo_relative_path "$plan_path")"; else plan_display="not-found"; fi
  acceptance_path="$(handoff_artifact_path "$slug" "acceptance" 2>/dev/null || true)"
  if [ -n "$acceptance_path" ]; then acceptance_display="$(repo_relative_path "$acceptance_path")"; else acceptance_display="not-found"; fi

  run_dir="$(state_dir)/runs/$(timestamp)-run-$bd_id"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-worker-prompt.md"
  final_file="$run_dir/codex-worker-final.md"

  cat > "$prompt_file" <<EOF
You are the Codex implementer in the Humanize Flow workflow.

Task id: $bd_id
Handoff slug: $slug
Handoff path: $(repo_relative_path "$file")
Plan path: $plan_display
Acceptance path: $acceptance_display
Latest review path: $latest_review_display
Repository root: $(repo_root)

$(language_instruction)

Required behavior:
- Implement this approved task directly; do not start humanize/RLCR or invoke any humanize skill.
- Read the Beads task with: bd show $bd_id --json
- Read the approved handoff, plan, and acceptance criteria before implementing.
- If the approved handoff, plan, or acceptance criteria cannot be found, stop and report the missing artifact instead of implementing from the brief Beads task alone.
- If the latest review path is not "not-found", read that review as the current correction target before editing.
- Do not bulk-load docs/humanize-flow/$slug/reviews/ or older review reports. Inspect older reviews only when the latest review explicitly references them or the user asks for review history.
- Do not expand scope beyond this task unless this run is a final full-scope correction for the handoff/Epic target.
- Run relevant tests.
- Write an implementation summary under docs/humanize-flow/$slug/implementation/.
- Update Beads notes/status with what changed, tests run, and remaining risks when bd is available.
- Stop with a clear summary and request Codex review via: humanize-flow review $bd_id
- Preserve the Humanize Flow Codex review boundary: do not self-approve, do not mark review passed, and do not run delivery commands.
EOF

  info "worker prompt: $prompt_file"
  info "starting Codex worker session"
  info "model: $(worker_codex_model_default)"
  info "reasoning effort: $(worker_codex_reasoning_effort_default)"
  info "humanize mode: off (Codex worker does not run humanize)"
  info "human-readable log: $final_file"
  prompt_text="$(cat "$prompt_file")"
  run_codex_worker_exec "$prompt_text" | tee "$final_file"
}

cmd_run_yolo() {
  require_git_repo
  local ref max_round model output_format verbose partial hook_events humanize_mode claude_env_file retry retry_delay review_strategy worker_provider slug
  local epic_scope child_ids target_ids target_count completed_csv completed_count
  local target_index target_id ready_ids active_ids round latest_review verdict hint epic_id
  ref="$1"; max_round="$2"; model="$3"; output_format="$4"; verbose="$5"; partial="$6"; hook_events="$7"; humanize_mode="$8"; claude_env_file="${9:-}"; retry="${10:-3}"; retry_delay="${11:-10}"; review_strategy="${12:-final}"; worker_provider="${13:-claude}"
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG --yolo"
  case "$review_strategy" in
    each-task|final) ;;
    *) die "Unsupported YOLO review strategy: $review_strategy" ;;
  esac
  worker_provider="$(normalize_worker_provider "$worker_provider")" || die "Unsupported worker provider: $worker_provider (supported: claude, codex)"
  case "$max_round" in
    ''|*[!0-9]*) die "--max-round must be a positive integer." ;;
  esac
  [ "$max_round" -ge 1 ] || die "--max-round must be at least 1."
  case "$retry" in
    ''|*[!0-9]*) die "--retry must be a positive integer." ;;
  esac
  [ "$retry" -ge 1 ] || die "--retry must be at least 1."
  case "$retry_delay" in
    ''|*[!0-9]*) die "--retry-delay must be a non-negative integer." ;;
  esac
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  [ -n "$slug" ] || die "YOLO mode requires an approved Humanize Flow handoff for: $ref"
  ensure_approved_handoff_for_slug "$slug"
  epic_scope=0
  if yolo_ref_is_epic_scope "$ref" "$slug"; then epic_scope=1; fi
  if [ "$epic_scope" -eq 1 ]; then
    child_ids="$(handoff_child_task_ids "$slug" 2>/dev/null || true)"
    [ -n "$child_ids" ] || die "YOLO Epic mode could not find materialized child Beads tasks in handoff: $slug"
    target_count="$(printf '%s\n' "$child_ids" | sed '/^$/d' | wc -l | tr -d ' ')"
    epic_id="$(epic_bd_id_for_slug "$slug" 2>/dev/null || true)"
  else
    target_ids="$(yolo_target_ids_for_ref "$ref" "$slug" 2>/dev/null || true)"
    [ -n "$target_ids" ] || die "YOLO mode could not resolve Beads task target(s) for: $ref"
    target_count="$(printf '%s\n' "$target_ids" | sed '/^$/d' | wc -l | tr -d ' ')"
  fi

  info "starting YOLO mode"
  info "handoff slug: $slug"
  if [ "$epic_scope" -eq 1 ]; then
    info "Epic scheduling: dynamic via bd ready --json"
    info "child task count: $target_count"
  else
    info "target count: $target_count"
  fi
  info "max rounds: $max_round"
  info "worker provider: $worker_provider"
  if [ "$review_strategy" = "final" ]; then
    info "review strategy: final full-scope review after all child tasks"
  else
    info "review strategy: review each completed task"
  fi
  info "phase retry: $retry attempt(s), ${retry_delay}s delay"
  info "humanize mode: off (forced by --yolo to avoid nested review loops)"
  info "human verification gate: YOLO automates worker implementation and Codex review only; after a pass review, run humanize-flow verify <task-id> after manual testing before commit/push/pr."
  hint="$(yolo_retry_hint "$ref" "$max_round" "$retry" "$retry_delay" "$review_strategy")"
  completed_csv=""
  completed_count=0
  if [ "$epic_scope" -eq 1 ]; then
    if [ -n "$epic_id" ]; then
      if ! yolo_phase_with_retries "$retry" "$retry_delay" "mark Epic in progress" "$epic_id" yolo_mark_epic_in_progress "$epic_id"; then
        die "YOLO Epic mode failed while marking Epic in progress for handoff: $slug. Retry later with: $hint"
      fi
      success "YOLO marked Beads Epic in progress: $epic_id"
    fi
    if ! completed_csv="$(yolo_phase_with_retries "$retry" "$retry_delay" "query completed child tasks" "$slug" yolo_completed_child_task_ids "$slug" | paste -sd, -)"; then
      die "YOLO Epic mode failed while querying completed child task status for handoff: $slug. Retry later with: $hint"
    fi
    if [ -n "$completed_csv" ]; then
      completed_count="$(printf '%s\n' "$completed_csv" | tr ',' '\n' | sed '/^$/d' | wc -l | tr -d ' ')"
      info "completed child tasks recovered from Beads: $completed_count/$target_count"
    fi
    while [ "$completed_count" -lt "$target_count" ]; do
      if ! active_ids="$(yolo_phase_with_retries "$retry" "$retry_delay" "query in-progress child tasks" "$slug" yolo_in_progress_child_task_ids "$slug" "$completed_csv")"; then
        die "YOLO Epic mode failed while querying in-progress child task status for handoff: $slug. Retry later with: $hint"
      fi
      target_id="$(printf '%s\n' "$active_ids" | sed '/^$/d' | head -n 1)"
      if [ -n "$target_id" ]; then
        info "YOLO target $((completed_count + 1))/$target_count selected from in-progress handoff child: $target_id"
      elif ! ready_ids="$(yolo_phase_with_retries "$retry" "$retry_delay" "query bd ready" "$slug" yolo_ready_child_task_ids "$slug" "$completed_csv")"; then
        die "YOLO Epic mode failed while querying ready child tasks for handoff: $slug. Retry later with: $hint"
      fi
      if [ -z "$target_id" ]; then
        target_id="$(printf '%s\n' "$ready_ids" | sed '/^$/d' | head -n 1)"
      fi
      if [ -z "$target_id" ]; then
        die "YOLO Epic mode found no ready remaining child tasks for $slug. Completed $completed_count/$target_count. Check Beads dependency/status state with: bd ready --json"
      fi
      target_index=$((completed_count + 1))
      if [ -z "$active_ids" ]; then
        info "YOLO target $target_index/$target_count selected from bd ready: $target_id"
      fi
      if [ "$review_strategy" = "final" ]; then
        info "YOLO target $target_index/$target_count: $worker_provider worker"
        if [ "$worker_provider" = "codex" ]; then
          if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex worker" "$target_id" cmd_run_codex_once "$target_id"; then
            die "YOLO Codex worker failed for $target_id. Network or provider issues do not consume a review round. Retry later with: $hint"
          fi
        elif ! yolo_phase_with_retries "$retry" "$retry_delay" "Claude Code worker" "$target_id" cmd_run_once "$target_id" "print" "$model" "bypassPermissions" "$output_format" "$verbose" "$partial" "$hook_events" "off" "$claude_env_file"; then
          die "YOLO Claude worker failed for $target_id. Network or provider issues do not consume a review round. Retry later with: $hint"
        fi
        if ! yolo_phase_with_retries "$retry" "$retry_delay" "close implemented Beads task" "$target_id" yolo_mark_child_implemented "$target_id"; then
          die "YOLO could not close implemented Beads task $target_id in final-review mode. Retry later with: $hint"
        fi
        success "YOLO marked Beads task implemented pending final review: $target_id"
        completed_csv="${completed_csv:+$completed_csv,}$target_id"
        completed_count=$((completed_count + 1))
        continue
      fi
      if latest_review="$(yolo_latest_pass_review "$slug" "$target_id" 2>/dev/null || true)" && [ -n "$latest_review" ]; then
        info "YOLO target $target_id already has a passing review; marking complete without rerunning: $(repo_relative_path "$latest_review")"
        if ! yolo_phase_with_retries "$retry" "$retry_delay" "close Beads task" "$target_id" yolo_mark_child_complete "$target_id" "$latest_review"; then
          die "YOLO could not close already-passed Beads task $target_id. Retry later with: $hint"
        fi
        completed_csv="${completed_csv:+$completed_csv,}$target_id"
        completed_count=$((completed_count + 1))
        continue
      fi
      round=1
      while [ "$round" -le "$max_round" ]; do
        info "YOLO target $target_index/$target_count round $round/$max_round: $worker_provider worker"
        if [ "$worker_provider" = "codex" ]; then
          if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex worker" "$target_id" cmd_run_codex_once "$target_id"; then
            die "YOLO Codex worker failed for $target_id. Network or provider issues do not consume a review round. Retry later with: $hint"
          fi
        elif ! yolo_phase_with_retries "$retry" "$retry_delay" "Claude Code worker" "$target_id" cmd_run_once "$target_id" "print" "$model" "bypassPermissions" "$output_format" "$verbose" "$partial" "$hook_events" "off" "$claude_env_file"; then
          die "YOLO Claude worker failed for $target_id. Network or provider issues do not consume a review round. Retry later with: $hint"
        fi
        info "YOLO target $target_index/$target_count round $round/$max_round: Codex review"
        if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex review" "$target_id" cmd_review "$target_id" --yolo; then
          die "YOLO Codex review failed for $target_id. Network or provider issues do not consume a correction round. Retry later with: $hint"
        fi
        latest_review="$(latest_review_for_slug "$slug" "$target_id" 2>/dev/null || true)"
        [ -n "$latest_review" ] || die "YOLO review did not produce a non-empty review artifact for $target_id"
        verdict="$(review_verdict "$latest_review" 2>/dev/null || true)"
        [ -n "$verdict" ] || die "YOLO review did not produce a parseable verdict for $target_id. Latest review: $latest_review"
        info "YOLO review verdict for $target_id: $verdict"
        case "$verdict" in
          pass)
            success "YOLO target $target_id completed after $round round(s): review passed."
            if ! yolo_phase_with_retries "$retry" "$retry_delay" "close Beads task" "$target_id" yolo_mark_child_complete "$target_id" "$latest_review"; then
              die "YOLO could not close Beads task $target_id after passing review. Retry later with: $hint"
            fi
            success "YOLO marked Beads task complete: $target_id"
            break
            ;;
          changes_requested|blocked)
            if [ "$round" -ge "$max_round" ]; then
              die "YOLO mode reached max rounds ($max_round) for $target_id without a passing review. Latest review: $latest_review"
            fi
            info "YOLO mode will run another correction round for $target_id using latest review: $(repo_relative_path "$latest_review")"
            ;;
          *)
            die "YOLO mode could not parse a supported verdict for $target_id. Latest verdict: $verdict. Latest review: $latest_review"
            ;;
        esac
        round=$((round + 1))
      done
      completed_csv="${completed_csv:+$completed_csv,}$target_id"
      completed_count=$((completed_count + 1))
    done
    if [ "$review_strategy" = "final" ]; then
      round=1
      while [ "$round" -le "$max_round" ]; do
        info "YOLO final review round $round/$max_round: Codex full handoff/Epic scope"
        if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex final review" "$ref" cmd_review "$ref" --yolo; then
          die "YOLO final Codex review failed for $ref. Network or provider issues do not consume a correction round. Retry later with: $hint"
        fi
        latest_review="$(latest_review_for_slug "$slug" "$ref" 2>/dev/null || true)"
        [ -n "$latest_review" ] || die "YOLO final review did not produce a non-empty review artifact for $ref"
        verdict="$(review_verdict "$latest_review" 2>/dev/null || true)"
        [ -n "$verdict" ] || die "YOLO final review did not produce a parseable verdict for $ref. Latest review: $latest_review"
        info "YOLO final review verdict for $ref: $verdict"
        case "$verdict" in
          pass)
            success "YOLO mode completed all target(s); final full-scope review passed."
            return 0
            ;;
          changes_requested|blocked)
            if [ "$round" -ge "$max_round" ]; then
              die "YOLO final-review mode reached max rounds ($max_round) for $ref without a passing final review. Latest review: $latest_review"
            fi
            info "YOLO mode will run a full-scope correction round using latest final review: $(repo_relative_path "$latest_review")"
            if [ "$worker_provider" = "codex" ]; then
              if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex final correction" "$ref" cmd_run_codex_once "$ref"; then
                die "YOLO final correction failed for $ref. Network or provider issues do not consume a correction round. Retry later with: $hint"
              fi
            elif ! yolo_phase_with_retries "$retry" "$retry_delay" "Claude Code final correction" "$ref" cmd_run_once "$ref" "print" "$model" "bypassPermissions" "$output_format" "$verbose" "$partial" "$hook_events" "off" "$claude_env_file"; then
              die "YOLO final correction failed for $ref. Network or provider issues do not consume a correction round. Retry later with: $hint"
            fi
            ;;
          *)
            die "YOLO mode could not parse a supported final verdict for $ref. Latest verdict: $verdict. Latest review: $latest_review"
            ;;
        esac
        round=$((round + 1))
      done
    fi
    success "YOLO mode completed all target(s)."
    return 0
  fi

  target_index=1
  printf '%s\n' "$target_ids" | sed '/^$/d' | while IFS= read -r target_id; do
    info "YOLO target $target_index/$target_count: $target_id"
    if latest_review="$(yolo_latest_pass_review "$slug" "$target_id" 2>/dev/null || true)" && [ -n "$latest_review" ]; then
      info "YOLO target $target_id already has a passing review; skipping rerun: $(repo_relative_path "$latest_review")"
      target_index=$((target_index + 1))
      continue
    fi
    round=1
    while [ "$round" -le "$max_round" ]; do
      info "YOLO target $target_index/$target_count round $round/$max_round: $worker_provider worker"
      if [ "$worker_provider" = "codex" ]; then
        if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex worker" "$target_id" cmd_run_codex_once "$target_id"; then
          die "YOLO Codex worker failed for $target_id. Network or provider issues do not consume a review round. Retry later with: $hint"
        fi
      elif ! yolo_phase_with_retries "$retry" "$retry_delay" "Claude Code worker" "$target_id" cmd_run_once "$target_id" "print" "$model" "bypassPermissions" "$output_format" "$verbose" "$partial" "$hook_events" "off" "$claude_env_file"; then
        die "YOLO Claude worker failed for $target_id. Network or provider issues do not consume a review round. Retry later with: $hint"
      fi
      info "YOLO target $target_index/$target_count round $round/$max_round: Codex review"
      if ! yolo_phase_with_retries "$retry" "$retry_delay" "Codex review" "$target_id" cmd_review "$target_id" --yolo; then
        die "YOLO Codex review failed for $target_id. Network or provider issues do not consume a correction round. Retry later with: $hint"
      fi
      latest_review="$(latest_review_for_slug "$slug" "$target_id" 2>/dev/null || true)"
      [ -n "$latest_review" ] || die "YOLO review did not produce a non-empty review artifact for $target_id"
      verdict="$(review_verdict "$latest_review" 2>/dev/null || true)"
      [ -n "$verdict" ] || die "YOLO review did not produce a parseable verdict for $target_id. Latest review: $latest_review"
      info "YOLO review verdict for $target_id: $verdict"
      case "$verdict" in
        pass)
          success "YOLO target $target_id completed after $round round(s): review passed."
          break
          ;;
        changes_requested|blocked)
          if [ "$round" -ge "$max_round" ]; then
            die "YOLO mode reached max rounds ($max_round) for $target_id without a passing review. Latest review: $latest_review"
          fi
          info "YOLO mode will run another correction round for $target_id using latest review: $(repo_relative_path "$latest_review")"
          ;;
        *)
          die "YOLO mode could not parse a supported verdict for $target_id. Latest verdict: $verdict. Latest review: $latest_review"
          ;;
      esac
      round=$((round + 1))
    done
    target_index=$((target_index + 1))
  done
  success "YOLO mode completed all target(s)."
}

cmd_run() {
  require_git_repo
  local ref mode model permission_mode output_format verbose partial hook_events humanize_mode claude_env_file yolo max_round retry retry_delay review_strategy review_strategy_explicit worker_provider
  ref=""; mode="print"; model="$(claude_model_default)"; permission_mode="$(claude_permission_mode_default)"
  humanize_mode="$(claude_humanize_default)"
  claude_env_file="$(claude_env_file_default)"
  worker_provider="$(worker_provider_default)"
  output_format="stream-json"; verbose=1; partial=1; hook_events=1; yolo=0; max_round="$(yolo_max_round_default)"; retry=3; retry_delay=10; review_strategy="$(yolo_review_strategy_default)"; review_strategy_explicit=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --interactive|-i) mode="interactive" ;;
      --model) shift; model="${1:-}" ;;
      --permission-mode) shift; permission_mode="${1:-}" ;;
      --humanize) humanize_mode="required" ;;
      --no-humanize) humanize_mode="off" ;;
      --humanize-mode) shift; humanize_mode="${1:-}" ;;
      --env-file|--claude-env-file) shift; claude_env_file="${1:-}" ;;
      --no-env-file) claude_env_file="" ;;
      --yolo) yolo=1; permission_mode="bypassPermissions"; humanize_mode="off" ;;
      --review-at-end|--final-review-only) review_strategy="final"; review_strategy_explicit=1 ;;
      --review-each-task) review_strategy="each-task"; review_strategy_explicit=1 ;;
      --worker-provider) shift; worker_provider="${1:-}" ;;
      --max-round) shift; max_round="${1:-}" ;;
      --retry) shift; retry="${1:-}" ;;
      --retry-delay) shift; retry_delay="${1:-}" ;;
      --text) output_format="text"; partial=0; hook_events=0 ;;
      --stream-json) output_format="stream-json"; partial=1; hook_events=1 ;;
      --no-partial) partial=0 ;;
      --no-hook-events) hook_events=0 ;;
      --no-verbose) verbose=0 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow run BD_ID_OR_SLUG [options]

BD_ID_OR_SLUG may be either a Beads task id or a Humanize Flow handoff slug.

Options:
  --interactive, -i          Open a Claude Code interactive session instead of print mode.
  --worker-provider PROVIDER Override configured worker provider: claude or codex.
  --model MODEL              Override the configured Claude model for this run.
  --permission-mode MODE     Override the configured Claude permission mode for this run.
  --humanize                 Require humanize/RLCR for this run.
  --no-humanize              Disable humanize/RLCR for this run.
  --humanize-mode MODE       Set humanize mode: required, auto, or off.
  --env-file FILE            Load Claude Code provider/auth env vars from FILE for this run.
  --no-env-file              Ignore configured HUMANIZE_FLOW_CLAUDE_ENV_FILE / claude.env_file.
  --yolo                     Run worker+Codex review loop until pass or max rounds. Forces --humanize-mode off.
  --review-at-end            With --yolo Epic/handoff runs, skip per-child reviews and run one final full-scope review.
  --final-review-only        Alias for --review-at-end.
  --review-each-task         With --yolo, review each completed task.
  --max-round N              Maximum YOLO correction rounds. Default: configured yolo.max_round (5 if unset).
  --retry N                  YOLO phase retry attempts for transient command failures. Default: 3.
  --retry-delay SECONDS      Delay between YOLO phase retries. Default: 10.
  --text                     Use Claude text output instead of detailed stream-json.
  --stream-json              Use detailed stream-json internally and show a human-readable progress log. This is the default.
  --no-partial               Do not include partial message chunks in stream-json output.
  --no-hook-events           Do not include hook lifecycle events in stream-json output.
  --no-verbose               Do not pass --verbose to Claude Code.
EOF
        return 0 ;;
      --*) die "Unknown run option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected run argument: $1"; fi
        ;;
    esac
    shift
  done
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG"
  worker_provider="$(normalize_worker_provider "$worker_provider")" || die "Unsupported worker provider: $worker_provider (supported: claude, codex)"
  [ -n "$model" ] || die "Claude model cannot be empty."
  [ -n "$permission_mode" ] || die "Claude permission mode cannot be empty."
  humanize_mode="$(normalize_humanize_mode "$humanize_mode")" || die "Unsupported Claude humanize mode: $humanize_mode (supported: required, auto, off)"
  claude_env_file="$(normalize_claude_env_file_value "$claude_env_file")"
  if [ "$review_strategy_explicit" -eq 1 ] && [ "$review_strategy" = "final" ] && [ "$yolo" -ne 1 ]; then
    die "--review-at-end requires --yolo."
  fi
  if [ "$yolo" -eq 1 ]; then
    [ "$mode" != "interactive" ] || die "YOLO mode does not support --interactive."
    cmd_run_yolo "$ref" "$max_round" "$model" "$output_format" "$verbose" "$partial" "$hook_events" "$humanize_mode" "$claude_env_file" "$retry" "$retry_delay" "$review_strategy" "$worker_provider"
  else
    [ "$worker_provider" = "claude" ] || die "worker.provider=codex currently supports only run --yolo."
    cmd_run_once "$ref" "$mode" "$model" "$permission_mode" "$output_format" "$verbose" "$partial" "$hook_events" "$humanize_mode" "$claude_env_file"
  fi
}

cmd_run_next() {
  require_git_repo
  command_exists bd || die "bd CLI not found."
  local tmp bd_id
  tmp="$(state_dir)/tmp/bd-ready-$(timestamp).json"
  mkdir -p "$(dirname "$tmp")"
  bd ready --json > "$tmp"
  bd_id="$(run_python3 - "$tmp" "$(state_dir)/handoffs" "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" <<'PY'
import json, sys
from pathlib import Path
ready_path = Path(sys.argv[1])
handoffs_dir = Path(sys.argv[2])
noninteractive = sys.argv[3] == '1'
try:
    data = json.loads(ready_path.read_text())
except Exception:
    raise SystemExit(1)
if isinstance(data, dict):
    items = data.get('issues') or data.get('items') or data.get('data') or []
elif isinstance(data, list):
    items = data
else:
    items = []

def labels_of(item):
    labels = item.get('labels') or item.get('label_names') or []
    if isinstance(labels, str):
        labels = [x.strip() for x in labels.split(',') if x.strip()]
    return labels

def item_id(item):
    for key in ('id', 'issue_id', 'bead_id'):
        v = item.get(key)
        if isinstance(v, str) and v:
            return v
    return None

def item_title(item):
    for key in ('title', 'summary', 'name'):
        v = item.get(key)
        if isinstance(v, str) and v:
            return v
    return '(untitled)'

def item_type(item):
    v = item.get('type') or item.get('issue_type') or ''
    return v if isinstance(v, str) else ''

def parent_id(item):
    for key in ('parent_id', 'parent', 'epic_id', 'epic'):
        v = item.get(key)
        if isinstance(v, str) and v:
            return v
        if isinstance(v, dict):
            for nested in ('id', 'issue_id', 'bead_id'):
                nv = v.get(nested)
                if isinstance(nv, str) and nv:
                    return nv
    return ''

approved_ids = set()
if handoffs_dir.exists():
    for path in sorted(handoffs_dir.glob('*.json')):
        try:
            h = json.loads(path.read_text(encoding='utf-8'))
        except Exception:
            continue
        if h.get('approval', {}).get('status') != 'approved':
            continue
        source = h.get('source') or {}
        if isinstance(source, dict):
            if source.get('bd_id'):
                approved_ids.add(source['bd_id'])
            for bid in source.get('bd_ids') or []:
                approved_ids.add(bid)
        execution = h.get('execution') or {}
        if isinstance(execution, dict) and execution.get('current_bd_id'):
            approved_ids.add(execution['current_bd_id'])
        bd = h.get('bd') or {}
        epic = bd.get('epic') or {}
        if epic.get('bd_id'):
            approved_ids.add(epic['bd_id'])
        for task in bd.get('tasks') or []:
            if isinstance(task, dict) and task.get('bd_id'):
                approved_ids.add(task['bd_id'])

chosen = None
ready = [item for item in items if isinstance(item, dict) and item_id(item)]

def priority(item):
    iid = item_id(item)
    labels = labels_of(item)
    if iid in approved_ids:
        return 0
    if 'humanize-flow' in labels:
        return 1
    return 2

ready = sorted(ready, key=lambda item: (priority(item), parent_id(item), item_id(item) or ''))
if ready and (noninteractive or not sys.stdin.isatty() or len(ready) == 1):
    chosen = item_id(ready[0])
elif ready:
    groups = {}
    order = []
    for item in ready:
        group = parent_id(item) or item_id(item)
        if group not in groups:
            groups[group] = []
            order.append(group)
        groups[group].append(item)
    if len(order) > 1:
        print('Ready Epic/task groups:', file=sys.stderr)
        for idx, group in enumerate(order, 1):
            group_items = groups[group]
            first = group_items[0]
            print(f'  {idx}. {group} ({len(group_items)} ready) - {item_title(first)}', file=sys.stderr)
        while True:
            answer = input('Select Epic/task group number, Beads task id, or q to cancel: ').strip()
            if answer.lower() in {'q', 'quit', 'cancel'}:
                raise SystemExit(2)
            selected_group = ''
            if answer.isdigit() and 1 <= int(answer) <= len(order):
                selected_group = order[int(answer) - 1]
            elif answer in groups:
                selected_group = answer
            else:
                for group, group_items in groups.items():
                    if any(item_id(item) == answer for item in group_items):
                        selected_group = group
                        chosen = answer
                        break
            if selected_group:
                group_items = groups[selected_group]
                if not chosen:
                    if len(group_items) == 1:
                        chosen = item_id(group_items[0])
                    else:
                        print(f'Ready tasks in {selected_group}:', file=sys.stderr)
                        for idx, item in enumerate(group_items, 1):
                            print(f'  {idx}. {item_id(item)} [{item_type(item) or "task"}] {item_title(item)}', file=sys.stderr)
                        while True:
                            task_answer = input('Select task number or Beads task id: ').strip()
                            if task_answer.isdigit() and 1 <= int(task_answer) <= len(group_items):
                                chosen = item_id(group_items[int(task_answer) - 1])
                                break
                            if any(item_id(item) == task_answer for item in group_items):
                                chosen = task_answer
                                break
                            print('Invalid selection.', file=sys.stderr)
                break
            print('Invalid selection.', file=sys.stderr)
    else:
        group_items = groups[order[0]]
        if len(group_items) == 1:
            chosen = item_id(group_items[0])
        else:
            print('Ready tasks:', file=sys.stderr)
            for idx, item in enumerate(group_items, 1):
                print(f'  {idx}. {item_id(item)} [{item_type(item) or "task"}] {item_title(item)}', file=sys.stderr)
            while True:
                answer = input('Select task number, Beads task id, or q to cancel: ').strip()
                if answer.lower() in {'q', 'quit', 'cancel'}:
                    raise SystemExit(2)
                if answer.isdigit() and 1 <= int(answer) <= len(group_items):
                    chosen = item_id(group_items[int(answer) - 1])
                    break
                if any(item_id(item) == answer for item in group_items):
                    chosen = answer
                    break
                print('Invalid selection.', file=sys.stderr)
if chosen:
    print(chosen)
PY
)"
  [ -n "$bd_id" ] || die "No ready Beads task found."
  info "selected ready task: $bd_id"
  cmd_run "$bd_id"
}

cmd_review() {
  require_git_repo
  local ref="" bd_id slug file run_dir prompt_file review_dir review_file raw_review_file base prompt_text sandbox yolo normalized
  sandbox="$(review_sandbox_default)"
  yolo="$(review_yolo_default)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --sandbox) shift; sandbox="${1:-}"; yolo="false" ;;
      --yolo) yolo="true" ;;
      --no-yolo) yolo="false" ;;
      --help|-h|help)
        cat <<'EOF'
Usage:
  humanize-flow review BD_ID_OR_SLUG [--yolo|--no-yolo] [--sandbox MODE]

BD_ID_OR_SLUG may be either a Beads task id or a Humanize Flow handoff slug.
Default review mode is yolo, which passes Codex
--dangerously-bypass-approvals-and-sandbox to avoid approval prompts.
Set review.yolo=false, HUMANIZE_FLOW_REVIEW_YOLO=false, --no-yolo, or
--sandbox MODE to use normal sandboxed Codex execution. Supported sandbox
modes: read-only, workspace-write, danger-full-access.
EOF
        return 0 ;;
      --*) die "Unknown review option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected review argument: $1"; fi
        ;;
    esac
    shift
  done
  sandbox="$(normalize_sandbox_mode "$sandbox")" || die "Unsupported review sandbox: $sandbox (supported: read-only, workspace-write, danger-full-access)"
  yolo="$(normalize_bool "$yolo")" || die "Unsupported review yolo value: $yolo (supported: true, false)"
  [ -n "$ref" ] || die "Usage: humanize-flow review BD_ID_OR_SLUG [--yolo|--no-yolo] [--sandbox MODE]"
  command_exists codex || die "codex CLI not found."
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then bd_id="$(bd_id_for_ref_and_slug "$ref" "$slug" 2>/dev/null || true)"; fi
  if [ -z "${bd_id:-}" ]; then bd_id="$ref"; fi
  if [ -n "$slug" ]; then file="$(handoff_path "$slug")"; else file=""; fi
  run_dir="$(state_dir)/runs/$(timestamp)-review-$ref"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-reviewer-prompt.md"
  raw_review_file="$run_dir/codex-reviewer-output.md"
  review_dir="$(docs_dir)/${slug:-unknown}/reviews"
  mkdir -p "$review_dir"
  review_file="$review_dir/$(timestamp)-$ref.md"
  base="$(git merge-base HEAD main 2>/dev/null || git merge-base HEAD master 2>/dev/null || git rev-parse HEAD~1 2>/dev/null || git rev-parse HEAD 2>/dev/null || printf 'HEAD')"

  cat > "$prompt_file" <<EOF
$(reviewer_skill_hint)

You are running the Humanize Flow reviewer for this repository.

Task id: $bd_id
Handoff slug: ${slug:-unknown}
Handoff path: ${file:-not-found}
Review output path requested by caller: $review_file
Suggested git base: $base

$(language_instruction)

Follow the humanize-flow-reviewer skill exactly:
- Inspect the Beads task, handoff, plan, acceptance criteria, git status, and diff.
$(review_scope_instruction "$ref" "$slug" "$bd_id")
- Treat a missing approved handoff, plan, or acceptance criteria as a blocked review, not a pass.
- Do not implement fixes.
- The first non-empty line of the Markdown review must be exactly one machine-readable ASCII verdict line: Humanize-Flow-Verdict: pass, Humanize-Flow-Verdict: changes_requested, or Humanize-Flow-Verdict: blocked.
- Produce the rest of the review in Markdown using the configured human language; do not translate or localize the machine-readable Humanize-Flow-Verdict line.
- Include blocking findings with severity labels [P0]..[P3].
- If the verdict is pass, include a "Human verification guide" section with concrete manual test steps and a checkbox checklist for the human to complete before commit/push.
- If the verdict is changes_requested or blocked, include a "Human correction options" section explaining what context corrections, exclusions, or scope clarifications could change the verdict.
- State exactly what must happen before the task can close.
EOF

  info "review prompt: $prompt_file"
  info "review yolo: $yolo"
  if [ "$yolo" = "true" ]; then
    info "review codex mode: dangerously-bypass-approvals-and-sandbox"
  else
    info "review sandbox: $sandbox"
  fi
  prompt_text="$(cat "$prompt_file")"
  if [ "$yolo" = "true" ]; then
    run_codex_exec --yolo "$prompt_text" | tee "$raw_review_file"
  else
    run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$raw_review_file"
  fi
  if [ ! -s "$raw_review_file" ]; then
    die "review command produced an empty review artifact: $review_file"
  fi
  normalized="$(normalize_review_output "$raw_review_file" "$review_file" 2>/dev/null)" || die "review command did not produce a parseable verdict in: $review_file (raw output: $raw_review_file)"
  if [ "$normalized" = "normalized" ]; then
    warn "normalized Codex review output into canonical verdict format: $review_file (raw output: $raw_review_file)"
  fi
  review_verdict "$review_file" >/dev/null 2>&1 || die "review command did not produce a parseable verdict in: $review_file"
  if [ -n "$slug" ]; then
    set_handoff_artifact "$slug" "latest_review" "$review_file"
  fi
  success "review written: $review_file"
}

cmd_review_feedback() {
  require_git_repo
  local ref="" note="" from_file="" review_file="" bd_id slug file run_dir prompt_file feedback_file output_file raw_output_file review_dir base prompt_text safe_ref editor sandbox yolo normalized
  sandbox="$(review_sandbox_default)"
  yolo="$(review_yolo_default)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --note) shift; note="${1:-}" ;;
      --from) shift; from_file="${1:-}" ;;
      --review) shift; review_file="${1:-}" ;;
      --sandbox) shift; sandbox="${1:-}"; yolo="false" ;;
      --yolo) yolo="true" ;;
      --no-yolo) yolo="false" ;;
      --help|-h|help)
        cat <<'EOF'
Usage:
  humanize-flow review-feedback BD_ID_OR_SLUG [--yolo|--no-yolo] [--sandbox MODE]
  humanize-flow review-feedback BD_ID_OR_SLUG --note "manual test feedback" [--yolo|--no-yolo] [--sandbox MODE]
  humanize-flow review-feedback BD_ID_OR_SLUG --from docs/manual-test-notes.md [--yolo|--no-yolo] [--sandbox MODE]
  humanize-flow review-feedback BD_ID_OR_SLUG --review docs/.../reviews/latest.md --note "..." [--yolo|--no-yolo] [--sandbox MODE]

Merges human manual-test feedback or review corrections with the latest Codex
review and writes a new consolidated review report. The consolidated report
may keep the verdict, change pass to changes_requested, or change
changes_requested/blocked to pass when the human correction changes the review
scope or evidence.

Without --note or --from, opens ${VISUAL:-${EDITOR:-vi}} for writing feedback
and continues after the editor exits.
Default review-feedback mode is yolo, which passes Codex
--dangerously-bypass-approvals-and-sandbox to avoid approval prompts.
Set review.yolo=false, HUMANIZE_FLOW_REVIEW_YOLO=false, --no-yolo, or
--sandbox MODE to use normal sandboxed Codex execution. Supported sandbox
modes: read-only, workspace-write, danger-full-access.
EOF
        return 0 ;;
      --*) die "Unknown review-feedback option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected review-feedback argument: $1"; fi
        ;;
    esac
    shift
  done

  sandbox="$(normalize_sandbox_mode "$sandbox")" || die "Unsupported review sandbox: $sandbox (supported: read-only, workspace-write, danger-full-access)"
  yolo="$(normalize_bool "$yolo")" || die "Unsupported review yolo value: $yolo (supported: true, false)"
  [ -n "$ref" ] || die "Usage: humanize-flow review-feedback BD_ID_OR_SLUG [--note TEXT|--from FILE]"
  if [ -n "$from_file" ] && [ ! -f "$from_file" ]; then
    die "feedback file not found: $from_file"
  fi
  command_exists codex || die "codex CLI not found."

  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then bd_id="$(bd_id_for_ref_and_slug "$ref" "$slug" 2>/dev/null || true)"; fi
  if [ -z "${bd_id:-}" ]; then bd_id="$ref"; fi
  if [ -n "$slug" ]; then file="$(handoff_path "$slug")"; else file=""; fi
  if [ -z "$review_file" ] && [ -n "$slug" ]; then
    review_file="$(latest_review_for_slug "$slug" "$bd_id" 2>/dev/null || true)"
  fi
  [ -n "$review_file" ] || die "No prior review found. Pass --review FILE or run humanize-flow review first."
  [ -f "$review_file" ] || die "review file not found: $review_file"

  run_dir="$(state_dir)/runs/$(timestamp)-review-feedback-$ref"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-review-feedback-prompt.md"
  feedback_file="$run_dir/human-feedback.md"
  raw_output_file="$run_dir/codex-review-feedback-output.md"
  review_dir="$(docs_dir)/${slug:-unknown}/reviews"
  mkdir -p "$review_dir"
  safe_ref="$(slugify "$ref")"
  output_file="$review_dir/$(timestamp)-$safe_ref-human-feedback.md"
  base="$(git merge-base HEAD main 2>/dev/null || git merge-base HEAD master 2>/dev/null || git rev-parse HEAD~1 2>/dev/null || git rev-parse HEAD 2>/dev/null || printf 'HEAD')"

  if [ -n "$note" ] || [ -n "$from_file" ]; then
    {
      if [ -n "$note" ]; then
        printf '%s\n' "$note"
      fi
      if [ -n "$from_file" ]; then
        [ -z "$note" ] || printf '\n'
        cat "$from_file"
      fi
    } > "$feedback_file"
  else
    if [ ! -t 0 ] && [ -z "${VISUAL:-}" ] && [ -z "${EDITOR:-}" ]; then
      die "review-feedback needs --note/--from in non-interactive mode unless VISUAL or EDITOR is set."
    fi
    cat > "$feedback_file" <<'EOF'
# Write manual-test feedback or review correction notes below.
# Lines starting with # are ignored.
# Save and quit the editor to continue.

EOF
    editor="${VISUAL:-${EDITOR:-vi}}"
    info "opening editor for human feedback: $editor"
    # shellcheck disable=SC2086
    $editor "$feedback_file" || die "editor exited unsuccessfully"
    run_python3 - "$feedback_file" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
lines = [
    line.rstrip()
    for line in path.read_text(encoding='utf-8').splitlines()
    if not line.lstrip().startswith('#')
]
text = '\n'.join(lines).strip()
path.write_text((text + '\n') if text else '', encoding='utf-8')
PY
  fi
  [ -s "$feedback_file" ] || die "human feedback is empty; aborted."

  cat > "$prompt_file" <<EOF
$(reviewer_skill_hint)

You are updating a Humanize Flow review with human manual-test feedback or human correction notes.

Task id: $bd_id
Handoff slug: ${slug:-unknown}
Handoff path: ${file:-not-found}
Prior review: $review_file
Human feedback: $feedback_file
Updated review output path requested by caller: $output_file
Suggested git base: $base

$(language_instruction)

Follow the humanize-flow-reviewer skill and these additional rules:
- Read the Beads task, handoff, plan, acceptance criteria, git status, diff, prior review, and human feedback.
$(review_scope_instruction "$ref" "$slug" "$bd_id")
- Treat human feedback as additional evidence or scope correction, not as an automatic override.
- Reconcile disagreements explicitly: state whether the feedback changes the review scope, invalidates a prior finding, adds a new finding, or supplies missing verification evidence.
- Re-evaluate the final verdict: pass, changes_requested, or blocked.
- The first non-empty line of the updated Markdown review must be exactly one machine-readable ASCII verdict line: Humanize-Flow-Verdict: pass, Humanize-Flow-Verdict: changes_requested, or Humanize-Flow-Verdict: blocked.
- Produce the rest of the updated review in Markdown using the configured human language; do not translate or localize the machine-readable Humanize-Flow-Verdict line.
- If human feedback says a file or diff should be excluded, verify that exclusion against the approved plan/handoff before accepting it.
- If the updated verdict is pass, include a "Human verification guide" section with concrete manual test steps and a checkbox checklist to complete before commit/push.
- If the updated verdict is changes_requested or blocked, include the exact next command to return to the worker, usually: humanize-flow run $bd_id
- Preserve links/paths to the prior review and human feedback artifact.
- Do not implement fixes.
EOF

  info "review feedback prompt: $prompt_file"
  info "human feedback saved: $feedback_file"
  info "review feedback yolo: $yolo"
  if [ "$yolo" = "true" ]; then
    info "review feedback codex mode: dangerously-bypass-approvals-and-sandbox"
  else
    info "review feedback sandbox: $sandbox"
  fi
  prompt_text="$(cat "$prompt_file")"
  if [ "$yolo" = "true" ]; then
    run_codex_exec --yolo "$prompt_text" | tee "$raw_output_file"
  else
    run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$raw_output_file"
  fi
  if [ ! -s "$raw_output_file" ]; then
    die "review-feedback command produced an empty review artifact: $output_file"
  fi
  normalized="$(normalize_review_output "$raw_output_file" "$output_file" 2>/dev/null)" || die "review-feedback command did not produce a parseable verdict in: $output_file (raw output: $raw_output_file)"
  if [ "$normalized" = "normalized" ]; then
    warn "normalized Codex review-feedback output into canonical verdict format: $output_file (raw output: $raw_output_file)"
  fi
  review_verdict "$output_file" >/dev/null 2>&1 || die "review-feedback command did not produce a parseable verdict in: $output_file"
  if [ -n "$slug" ]; then
    set_handoff_artifact "$slug" "latest_review" "$output_file"
    set_handoff_artifact "$slug" "latest_human_feedback" "$feedback_file"
  fi
  success "updated review written: $output_file"
}

cmd_verify() {
  require_git_repo
  local ref="" note="" review_file="" bd_id slug run_dir verification_file verdict answer explicit_review=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --note) shift; note="${1:-}" ;;
      --review) shift; review_file="${1:-}"; explicit_review=1 ;;
      --yes|-y) answer="y" ;;
      --help|-h|help)
        cat <<'EOF'
Usage:
  humanize-flow verify BD_ID_OR_SLUG [--note TEXT] [--review FILE] [--yes]

Records that a human completed the manual verification gate for a task or
handoff. If a latest passing review is available, the verification links to it.
If no review is available, the command records a standalone human verification.

When --review FILE is passed explicitly, the selected review must have verdict
pass. This avoids linking manual confirmation to a failed review by mistake.
EOF
        return 0 ;;
      --*) die "Unknown verify option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected verify argument: $1"; fi
        ;;
    esac
    shift
  done
  [ -n "$ref" ] || die "Usage: humanize-flow verify BD_ID_OR_SLUG [--note TEXT] [--review FILE] [--yes]"
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then bd_id="$(bd_id_for_ref_and_slug "$ref" "$slug" 2>/dev/null || true)"; fi
  if [ -z "${bd_id:-}" ]; then bd_id="$ref"; fi
  if [ -z "$review_file" ] && [ -n "$slug" ]; then
    review_file="$(latest_review_for_slug "$slug" "$bd_id" 2>/dev/null || true)"
  fi
  verdict=""
  if [ -n "$review_file" ]; then
    [ -f "$review_file" ] || die "review file not found: $review_file"
    verdict="$(review_verdict "$review_file" 2>/dev/null || true)"
    if [ "$verdict" != "pass" ]; then
      if [ "$explicit_review" -eq 1 ]; then
        die "Cannot link verification to review because verdict is '${verdict:-unparseable}', not 'pass': $review_file"
      fi
      warn "latest review verdict is '${verdict:-unparseable}', so verification will be recorded without linking that review: $(repo_relative_path "$review_file")"
      review_file=""
      verdict=""
    fi
  fi
  if [ -z "${answer:-}" ] && [ -t 0 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ]; then
    if [ -n "$review_file" ]; then
      printf 'Mark Human verification guide as completed for %s? [y/N] ' "$(repo_relative_path "$review_file")"
    else
      printf 'No passing review found for %s. Record standalone human verification? [y/N] ' "$bd_id"
    fi
    IFS= read -r answer || answer=""
  fi
  case "${answer:-n}" in
    y|Y|yes|YES|Yes) ;;
    *) die "Verification not recorded." ;;
  esac
  if [ -n "$review_file" ]; then
    verification_file="$(verification_artifact_for_review "$review_file")"
  else
    verification_file="$(verification_artifact_for_ref "$ref" "$bd_id" "${slug:-}")"
  fi
  mkdir -p "$(dirname "$verification_file")"
  run_python3 - "$verification_file" "$ref" "$bd_id" "${slug:-}" "$review_file" "$verdict" "$note" <<'PY'
import getpass
import json
import sys
from datetime import datetime, timezone
from pathlib import Path

path = Path(sys.argv[1])
data = {
    "schema_version": "1",
    "verified_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "verified_by": getpass.getuser(),
    "ref": sys.argv[2],
    "bd_id": sys.argv[3],
    "handoff_slug": sys.argv[4],
    "review": sys.argv[5],
    "review_verdict": sys.argv[6],
    "verification_scope": "linked_pass_review" if sys.argv[5] else "standalone_manual",
    "note": sys.argv[7],
}
path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
  if [ -n "$slug" ]; then
    set_handoff_artifact "$slug" "latest_human_verification" "$verification_file"
  fi
  success "human verification recorded: $verification_file"
  info "next: humanize-flow commit, humanize-flow push, humanize-flow pr, or continue ready work with humanize-flow run-next"
}

commit_failure_looks_hook_related() {
  local log_file
  log_file="$1"
  grep -Eiq '(hook|pre-commit|pre commit|lefthook|husky|lint-staged|eslint|prettier|typecheck|tsc|biome|stylelint|test)' "$log_file"
}

write_selected_cached_changes() {
  local paths_file stat_file diff_file path
  paths_file="$1"
  stat_file="$2"
  diff_file="$3"
  : > "$stat_file"
  : > "$diff_file"
  while IFS= read -r path || [ -n "$path" ]; do
    [ -n "$path" ] || continue
    git diff --cached --stat -- "$path" >> "$stat_file"
    git diff --cached --binary -- "$path" >> "$diff_file"
  done < "$paths_file"
}

humanize_flow_runtime_artifact_path() {
  case "$1" in
    .humanize-flow/runs|.humanize-flow/runs/*|.humanize-flow/tmp|.humanize-flow/tmp/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

humanize_flow_doc_artifact_path() {
  case "$1" in
    docs/humanize-flow|docs/humanize-flow/*|.humanize-flow/handoffs|.humanize-flow/handoffs/*|.humanize-flow/verifications|.humanize-flow/verifications/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

collect_excluded_commit_remainder() {
  local with_doc output_file line path count
  with_doc="$1"
  output_file="$2"
  count=0
  : > "$output_file"
  while IFS= read -r line || [ -n "$line" ]; do
    [ -n "$line" ] || continue
    path="${line#???}"
    case "$path" in
      *" -> "*) path="${path##* -> }" ;;
    esac
    if humanize_flow_runtime_artifact_path "$path"; then
      printf '%s\n' "$path" >> "$output_file"
      count=$((count + 1))
      continue
    fi
    if [ "$with_doc" -ne 1 ] && humanize_flow_doc_artifact_path "$path"; then
      printf '%s\n' "$path" >> "$output_file"
      count=$((count + 1))
      continue
    fi
    return 1
  done <<EOF
$(git status --porcelain --untracked-files=all)
EOF
  [ "$count" -gt 0 ]
}

open_file_in_pager() {
  local file pager_cmd
  file="$1"
  if [ -n "${PAGER:-}" ]; then
    pager_cmd="$PAGER"
  elif command_exists less; then
    pager_cmd="less -R"
  else
    pager_cmd="cat"
  fi
  if [ "$pager_cmd" = "cat" ]; then
    cat "$file"
  else
    sh -c "$pager_cmd \"\$1\"" sh "$file"
  fi
}

create_commit_failure_bd() {
  local run_dir log_file message_file prompt_file task_file output_file prompt_text answer
  run_dir="$1"; log_file="$2"; message_file="$3"

  if ! command_exists bd; then
    warn "bd CLI not found; cannot create a Beads task for the commit failure."
    return 0
  fi
  if [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" = "1" ]; then
    warn "non-interactive mode; skipped Beads task prompt for commit failure."
    return 0
  fi

  printf 'Create a Beads task to fix this commit hook failure? [y/N] '
  read -r answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) success "skipped Beads task creation for commit failure."; return 0 ;;
  esac

  prompt_file="$run_dir/codex-hook-failure-bd-prompt.md"
  task_file="$run_dir/hook-failure-bd.json"
  output_file="$run_dir/hook-failure-bd-create-output.json"
  cat > "$prompt_file" <<EOF
You are drafting a Beads task for a failed git commit hook.

$(language_instruction)

Inspect:
- Commit failure log: $log_file
- Proposed commit message: $message_file
- Selected commit paths when available: $(dirname "$message_file")/commit-paths.txt
- git status --short --untracked-files=all
- git diff --cached --stat for the selected commit paths
- git diff --cached for the selected commit paths
- Relevant repository guidance files, especially AGENTS.md and CLAUDE.md when present.

Return only JSON with this shape:
{
  "title": "short task title",
  "description": "actionable task description",
  "priority": 2,
  "labels": ["humanize-flow", "commit-hook"]
}

Rules:
- The task should be about making the commit hook pass.
- Distinguish likely code issues from likely local environment issues.
- Include the failed hook/check name when visible.
- Mention the saved failure log path.
- Do not return Markdown fences or explanation.
EOF
  info "hook failure Beads prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec "$prompt_text" > "$task_file"
  sed -i.bak '/^```/d' "$task_file"
  rm -f "$task_file.bak"

  run_python3 - "$task_file" "$log_file" "$output_file" <<'PY'
import json, re, subprocess, sys
from pathlib import Path

task_path = Path(sys.argv[1])
log_path = Path(sys.argv[2])
output_path = Path(sys.argv[3])
raw = task_path.read_text(encoding="utf-8").strip()
try:
    data = json.loads(raw)
except Exception:
    match = re.search(r"\{.*\}", raw, re.S)
    if not match:
        raise SystemExit(f"could not parse Codex Beads task JSON: {task_path}")
    data = json.loads(match.group(0))

title = str(data.get("title") or "Fix commit hook failure").strip()
description = str(data.get("description") or "").strip()
priority = str(data.get("priority") or "2").strip()
labels = data.get("labels") or []
if isinstance(labels, str):
    labels = [part.strip() for part in labels.split(",")]
labels = [re.sub(r"[^A-Za-z0-9_.-]+", "-", str(label).strip()).strip("-") for label in labels]
labels = [label for label in labels if label]
for label in ("humanize-flow", "commit-hook"):
    if label not in labels:
        labels.append(label)
if priority not in {"0", "1", "2", "3", "4", "5"}:
    priority = "2"
if not description:
    description = "A git commit hook failed during `humanize-flow commit`."
description = description.rstrip() + f"\n\nFailure log: `{log_path}`\n"

args = [
    "bd",
    "create",
    title,
    "-t",
    "task",
    "-p",
    priority,
    "--description",
    description,
    "-l",
    ",".join(labels),
    "--json",
]
cp = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
if cp.returncode != 0:
    sys.stderr.write(cp.stderr)
    raise SystemExit(cp.returncode)
output_path.write_text(cp.stdout, encoding="utf-8")
print(cp.stdout.strip())
PY
  success "created Beads task for commit failure; output saved: $output_file"
}

handle_commit_failure() {
  local run_dir log_file message_file
  run_dir="$1"; log_file="$2"; message_file="$3"
  warn "git commit failed; output saved: $log_file"
  cat "$log_file" >&2
  if commit_failure_looks_hook_related "$log_file"; then
    create_commit_failure_bd "$run_dir" "$log_file" "$message_file"
  else
    warn "commit failure does not look like a hook/lint/test failure; skipped Beads task prompt."
  fi
}

cmd_commit() {
  require_git_repo
  local yes=0 with_doc=0 message_file prompt_file run_dir prompt_text first_line stage_prompt_file stage_paths_file commit_paths_file excluded_paths_file stat_file diff_file selected_count excluded_count path commit_log commit_status answer merge_in_progress doc_policy_text
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y) yes=1 ;;
      --with-doc) with_doc=1 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow commit [--yes] [--with-doc]

Creates a commit with Codex-selected paths and a Codex-drafted Lore commit
message. Codex always reviews the full working tree, including staged and
unstaged changes, then selects which changed paths belong in this commit.
By default, generated Humanize Flow planning/review docs are excluded from the
commit path set. Pass --with-doc to allow those artifacts.
EOF
        return 0 ;;
      *) die "Unknown commit option: $1" ;;
    esac
    shift
  done
  command_exists codex || die "codex CLI not found."
  run_dir="$(state_dir)/runs/$(timestamp)-commit"
  mkdir -p "$run_dir"
  stage_prompt_file="$run_dir/codex-stage-prompt.md"
  stage_paths_file="$run_dir/stage-paths.txt"
  commit_paths_file="$run_dir/commit-paths.txt"
  excluded_paths_file="$run_dir/excluded-commit-paths.txt"
  stat_file="$run_dir/selected-diffstat.txt"
  diff_file="$run_dir/selected-diff.patch"
  if [ -z "$(git status --porcelain --untracked-files=all)" ]; then
    if [ "$(git_integration_state)" != "merge" ]; then
      die "No changes to commit."
    fi
  fi
  merge_in_progress=0
  if [ "$(git_integration_state)" = "merge" ]; then
    merge_in_progress=1
  fi

  if [ "$merge_in_progress" -eq 1 ]; then
    if [ -n "$(git_unmerged_paths)" ]; then
      die "Cannot commit while merge conflicts remain. Resolve unmerged paths first: $(git_unmerged_paths | tr '\n' ' ')"
    fi
    prompt_file="$run_dir/codex-merge-commit-prompt.md"
    message_file="$run_dir/commit-message.txt"
    stat_file="$run_dir/selected-diffstat.txt"
    diff_file="$run_dir/selected-diff.patch"
    git diff --cached --stat > "$stat_file" || true
    git diff --cached > "$diff_file" || true
    cat > "$prompt_file" <<EOF
You are writing a git merge-resolution commit message.

This repository is currently in a merge state after all PR target branch conflict paths were cleared.

$(language_instruction)

Inspect:
- git status --short
- git log --oneline --left-right HEAD...MERGE_HEAD
- git diff --cached --stat
- git diff --cached
- git diff HEAD
- Relevant repository guidance files, especially AGENTS.md and CLAUDE.md when present.

Return only the commit message, with no Markdown fences and no explanation.
Use the Lore Commit Protocol:

<intent line: why the merge resolution was made, not what changed>

<body: narrative context, constraints, approach rationale>

Constraint: <external constraint that shaped the decision>
Rejected: <alternative considered> | <reason>
Confidence: <low|medium|high>
Scope-risk: <narrow|moderate|broad>
Directive: <forward-looking warning if useful>
Tested: <what was verified>
Not-tested: <known gaps>

Keep the first line under 72 characters. Be honest about tests.
EOF
    info "merge commit prompt: $prompt_file"
    prompt_text="$(cat "$prompt_file")"
    run_codex_exec "$prompt_text" > "$message_file"
    sed -i.bak '/^```/d' "$message_file"
    rm -f "$message_file.bak"
    first_line="$(sed -n '1p' "$message_file")"
    [ -n "$first_line" ] || die "Codex returned an empty commit message."
    info "merge resolution changes:"
    if [ -s "$stat_file" ]; then
      cat "$stat_file"
    else
      warn "No cached diffstat was produced for the merge resolution."
    fi
    if [ -s "$diff_file" ]; then
      info "merge resolution diff: $diff_file"
      if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ] && [ -t 0 ] && [ -t 1 ]; then
        info "opening merge resolution diff preview; press q to return to the commit confirmation prompt."
        open_file_in_pager "$diff_file"
      fi
    else
      warn "No cached diff content was produced for the merge resolution. Git may still create a merge commit."
    fi
    info "commit message: $message_file"
    log ""
    sed -n '1,120p' "$message_file"
    log ""
    if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ]; then
      printf 'Create merge-resolution commit with this message? [y/N] '
      read -r answer
      case "$answer" in
        y|Y|yes|YES) ;;
        *) die "Commit cancelled. Message kept at $message_file" ;;
      esac
    fi
    commit_log="$run_dir/git-commit.log"
    set +e
    git commit -F "$message_file" > "$commit_log" 2>&1
    commit_status=$?
    set -e
    if [ "$commit_status" -ne 0 ]; then
      handle_commit_failure "$run_dir" "$commit_log" "$message_file"
      return "$commit_status"
    fi
    cat "$commit_log"
    return 0
  fi
  if [ "$with_doc" -eq 1 ]; then
    doc_policy_text="The user passed --with-doc. You may include Humanize Flow generated planning/review artifacts when they genuinely belong in this commit. This includes docs/humanize-flow/**, .humanize-flow/handoffs/**, and .humanize-flow/verifications/**. Continue to exclude local runtime artifacts such as .humanize-flow/runs/** and .humanize-flow/tmp/**."
  else
    doc_policy_text="Default policy: do not include Humanize Flow generated planning/review artifacts in the commit path list. Exclude docs/humanize-flow/**, .humanize-flow/handoffs/**, and .humanize-flow/verifications/** even if they are staged or related. The user can rerun humanize-flow commit --with-doc to include them intentionally. Also exclude local runtime artifacts such as .humanize-flow/runs/** and .humanize-flow/tmp/**."
  fi
  cat > "$stage_prompt_file" <<EOF
You are selecting which changed files belong in one git commit.

$(language_instruction)

Humanize Flow artifact policy:
$doc_policy_text

Inspect:
- git status --short --untracked-files=all
- git diff --cached --stat
- git diff --cached
- git diff --stat
- git diff
- Relevant repository guidance files, especially AGENTS.md and CLAUDE.md in the root or along changed paths when present.

Rules:
- Return only repository-relative file paths to commit, one per line.
- Do not return Markdown, bullets, quotes, explanations, directories, commands, or absolute paths.
- Include only files that belong in this commit.
- Treat existing staged changes as advisory context only; they may be accidental, incomplete, or unrelated.
- Include unstaged paths when they belong with the commit, even if other paths were already staged.
- Exclude staged paths when they do not belong with the commit.
- Exclude unrelated user changes, generated local runtime files, accidental command output, secrets, credentials, build artifacts, temp files, and anything repository guidance says not to commit.
- If no changed file should be committed, return exactly: NONE
- Do not run git add, git commit, or modify files.
EOF
  info "commit path selection prompt: $stage_prompt_file"
  prompt_text="$(cat "$stage_prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec "$prompt_text" > "$stage_paths_file"
  sed -i.bak '/^```/d' "$stage_paths_file"
  rm -f "$stage_paths_file.bak"
  : > "$commit_paths_file"
  : > "$excluded_paths_file"
  selected_count=0
  excluded_count=0
  while IFS= read -r path || [ -n "$path" ]; do
    path="${path%$'\r'}"
    [ -n "$path" ] || continue
    [ "$path" != "NONE" ] || continue
    case "$path" in
      /*|../*|*/../*|.git|.git/*)
        die "Codex selected an unsafe path to commit: $path"
        ;;
    esac
    if [ -z "$(git status --porcelain --untracked-files=all -- "$path")" ]; then
      die "Codex selected a path with no working tree changes: $path"
    fi
    if humanize_flow_runtime_artifact_path "$path"; then
      printf '%s\n' "$path" >> "$excluded_paths_file"
      excluded_count=$((excluded_count + 1))
      continue
    fi
    if [ "$with_doc" -ne 1 ] && humanize_flow_doc_artifact_path "$path"; then
      printf '%s\n' "$path" >> "$excluded_paths_file"
      excluded_count=$((excluded_count + 1))
      continue
    fi
    printf '%s\n' "$path" >> "$commit_paths_file"
    git add -- "$path"
    selected_count=$((selected_count + 1))
  done < "$stage_paths_file"
  if [ "$excluded_count" -gt 0 ]; then
    if [ "$with_doc" -eq 1 ]; then
      info "excluded $excluded_count local runtime artifact path(s); list saved: $excluded_paths_file"
    else
      info "excluded $excluded_count Humanize Flow artifact path(s); rerun with --with-doc to include planning/review docs. List saved: $excluded_paths_file"
    fi
  fi
  if [ "$selected_count" -eq 0 ]; then
    if collect_excluded_commit_remainder "$with_doc" "$excluded_paths_file"; then
      if [ "$with_doc" -eq 1 ]; then
        success "No commit created: all commit-eligible changes are already committed; only local Humanize Flow runtime artifacts remain."
      else
        success "No commit created: all commit-eligible changes are already committed; remaining changes are Humanize Flow artifacts excluded by default."
        info "run humanize-flow commit --with-doc to include planning/review docs intentionally."
      fi
      info "excluded remaining artifact path(s): $excluded_paths_file"
      info "Codex selection kept at $stage_paths_file"
      return 0
    fi
    die "Codex did not select any files to commit. Selection kept at $stage_paths_file"
  fi
  info "selected $selected_count path(s) for commit; selection saved: $commit_paths_file"
  prompt_file="$run_dir/codex-commit-prompt.md"
  message_file="$run_dir/commit-message.txt"
  cat > "$prompt_file" <<EOF
You are writing a git commit message for the selected commit paths only.

Selected paths:
$(sed 's/^/- /' "$commit_paths_file")

$(language_instruction)

Inspect:
- git status --short
- Selected path list: $commit_paths_file
- git diff --cached --stat -- <selected paths>
- git diff --cached -- <selected paths>

Return only the commit message, with no Markdown fences and no explanation.
Use the Lore Commit Protocol:

<intent line: why the change was made, not what changed>

<body: narrative context, constraints, approach rationale>

Constraint: <external constraint that shaped the decision>
Rejected: <alternative considered> | <reason>
Confidence: <low|medium|high>
Scope-risk: <narrow|moderate|broad>
Directive: <forward-looking warning if useful>
Tested: <what was verified>
Not-tested: <known gaps>

Keep the first line under 72 characters. Be honest about tests.
EOF
  info "commit prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec "$prompt_text" > "$message_file"
  sed -i.bak '/^```/d' "$message_file"
  rm -f "$message_file.bak"
  first_line="$(sed -n '1p' "$message_file")"
  [ -n "$first_line" ] || die "Codex returned an empty commit message."
  write_selected_cached_changes "$commit_paths_file" "$stat_file" "$diff_file"
  info "selected changes:"
  if [ -s "$stat_file" ]; then
    cat "$stat_file"
  else
    warn "No cached diffstat was produced for selected paths."
  fi
  if [ -s "$diff_file" ]; then
    info "selected diff: $diff_file"
    if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ] && [ -t 0 ] && [ -t 1 ]; then
      info "opening selected diff preview; press q to return to the commit confirmation prompt."
      open_file_in_pager "$diff_file"
    fi
  else
    warn "No cached diff content was produced for selected paths."
  fi
  info "commit message: $message_file"
  log ""
  sed -n '1,120p' "$message_file"
  log ""
  if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ]; then
    printf 'Create commit with this message? [y/N] '
    read -r answer
    case "$answer" in
      y|Y|yes|YES) ;;
      *) die "Commit cancelled. Message kept at $message_file" ;;
    esac
  fi
  commit_log="$run_dir/git-commit.log"
  set +e
  git commit --only --pathspec-from-file="$commit_paths_file" -F "$message_file" > "$commit_log" 2>&1
  commit_status=$?
  set -e
  if [ "$commit_status" -ne 0 ]; then
    handle_commit_failure "$run_dir" "$commit_log" "$message_file"
    return "$commit_status"
  fi
  cat "$commit_log"
}

select_git_remote() {
  local provided purpose remotes count idx answer remote
  provided="$1"
  purpose="$2"
  if [ -n "$provided" ]; then
    if ! git remote get-url "$provided" >/dev/null 2>&1; then
      die "Unknown remote: $provided"
    fi
    printf '%s\n' "$provided"
    return 0
  fi
  remotes="$(git remote)"
  count="$(printf '%s\n' "$remotes" | sed '/^$/d' | wc -l | tr -d ' ')"
  [ "$count" -gt 0 ] || die "No git remotes configured."
  if [ "$count" -eq 1 ]; then
    printf '%s\n' "$remotes" | sed '/^$/d' | sed -n '1p'
    return 0
  fi
  printf 'Available remotes for %s:\n' "$purpose" >&2
  idx=1
  while IFS= read -r remote; do
    [ -n "$remote" ] || continue
    printf '  %s. %s  %s\n' "$idx" "$remote" "$(git remote get-url "$remote")" >&2
    idx=$((idx + 1))
  done <<EOF
$remotes
EOF
  if [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" = "1" ]; then
    die "Multiple remotes configured; pass --remote NAME in non-interactive mode."
  fi
  printf 'Select remote number or name for %s: ' "$purpose" >&2
  read -r answer
  if printf '%s\n' "$answer" | grep -Eq '^[0-9]+$'; then
    [ "$answer" -ge 1 ] || die "Invalid remote selection: $answer"
    remote="$(printf '%s\n' "$remotes" | sed '/^$/d' | awk -v n="$answer" 'NR == n { print; exit }')"
  else
    remote="$answer"
  fi
  [ -n "$remote" ] || die "Invalid remote selection."
  if ! git remote get-url "$remote" >/dev/null 2>&1; then
    die "Unknown remote: $remote"
  fi
  printf '%s\n' "$remote"
}

repo_arg_from_remote() {
  local remote url repo
  remote="$1"
  url="$(git remote get-url "$remote")"
  repo="$(run_python3 - "$url" <<'PY'
import re
import sys
from urllib.parse import unquote, urlparse

url = sys.argv[1].strip()
host = ""
path = ""

if "://" not in url:
    match = re.match(r"^(?:[^@]+@)?([^:]+):(.+)$", url)
    if match:
        host = match.group(1)
        path = match.group(2)
else:
    parsed = urlparse(url)
    if parsed.scheme in {"git", "http", "https", "ssh"}:
        host = parsed.hostname or ""
        path = parsed.path.lstrip("/")

parts = [unquote(part) for part in path.strip("/").split("/") if part]
if not host or len(parts) < 2:
    raise SystemExit(1)

owner = parts[0]
repo = parts[1]
if repo.endswith(".git"):
    repo = repo[:-4]
if not owner or not repo:
    raise SystemExit(1)

if host in {"github.com", "www.github.com"}:
    print(f"{owner}/{repo}")
else:
    print(f"{host}/{owner}/{repo}")
PY
)" || die "Remote '$remote' is not a GitHub-style repository URL usable with gh: $url"
  [ -n "$repo" ] || die "Remote '$remote' is not a GitHub-style repository URL usable with gh: $url"
  printf '%s\n' "$repo"
}

collect_pr_human_verification_guides() {
  local output_file
  output_file="$1"
  run_python3 - "$(repo_root)" "$output_file" <<'PY'
import json
import re
import sys
from pathlib import Path

root = Path(sys.argv[1])
output = Path(sys.argv[2])
review_paths = []

for handoff in sorted((root / ".humanize-flow" / "handoffs").glob("*.json")):
    try:
        data = json.loads(handoff.read_text(encoding="utf-8"))
    except Exception:
        continue
    latest = (data.get("artifacts") or {}).get("latest_review")
    if latest:
        path = root / latest
        if path.exists():
            review_paths.append(path)

for path in sorted((root / "docs" / "humanize-flow").glob("*/reviews/*.md")):
    review_paths.append(path)

seen = set()
sections = []
verdict_heading = r"(?:Verdict|评审结论|審查結論|评审结果|審查結果|结论|結論)"
guide_heading = r"(?:Human verification guide|人工验证指南|人工驗證指南|人工测试指南|人工測試指南|手工验证指南|手工驗證指南|手工测试指南|手工測試指南|人类验证指南|人類驗證指南)"
for path in review_paths:
    path = path.resolve()
    if path in seen or not path.exists():
        continue
    seen.add(path)
    text = path.read_text(encoding="utf-8", errors="replace")
    machine_verdict = re.search(r"(?im)^\s*Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\s*$", text)
    if machine_verdict:
        if machine_verdict.group(1).lower() != "pass":
            continue
    else:
        verdict_match = re.search(rf"(?ims)^##\s*{verdict_heading}\b(?P<body>.*?)(?:^##\s+|\Z)", text)
        if not verdict_match or not re.search(r"(?i)(?:`|\b)pass(?:`|\b)", verdict_match.group("body")):
            continue
    guide_match = re.search(
        rf"(?ims)^#{{1,6}}\s*{guide_heading}\b.*?(?=^#{{1,6}}\s+|\Z)",
        text,
    )
    if not guide_match:
        continue
    section = guide_match.group(0).strip()
    if not section:
        continue
    rel = path.relative_to(root)
    sections.append((rel.as_posix(), section))

lines = []
for rel, section in sections:
    lines.append(f"### {rel}")
    lines.append("")
    lines.append(section)
    lines.append("")

output.write_text("\n".join(lines).rstrip() + ("\n" if lines else ""), encoding="utf-8")
PY
}

append_pr_human_verification_guide_if_missing() {
  local body_file guides_file lang
  body_file="$1"
  guides_file="$2"
  lang="$(language_default)"
  [ -s "$guides_file" ] || return 0
  run_python3 - "$body_file" "$guides_file" "$lang" <<'PY'
import re
import sys
from pathlib import Path

body_path = Path(sys.argv[1])
guides_path = Path(sys.argv[2])
lang = sys.argv[3]
body = body_path.read_text(encoding="utf-8")
guides = guides_path.read_text(encoding="utf-8").strip()
if not guides:
    raise SystemExit(0)
if re.search(r"(?i)human verification guide|人工验证|人工測試|手工验证|手工測試", body):
    raise SystemExit(0)
if lang == "zh":
    heading = "## 人工验证指南"
    intro = "以下内容来自 Humanize Flow 通过的 review 报告，供 PR 审核和人工测试参考。"
else:
    heading = "## Human verification guide"
    intro = "The following guidance comes from passing Humanize Flow review reports and is included for reviewer and manual-test reference."
addition = f"\n\n{heading}\n\n{intro}\n\n{guides}\n"
body_path.write_text(body.rstrip() + addition, encoding="utf-8")
PY
}

cmd_push() {
  require_git_repo
  local remote="" branch
  while [ $# -gt 0 ]; do
    case "$1" in
      --remote) shift; remote="${1:-}" ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow push [--remote NAME]

Pushes the current branch. If no remote is provided and more than one remote
exists, prompts for a remote number or name.
EOF
        return 0 ;;
      *) die "Unknown push option: $1" ;;
    esac
    shift
  done
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || die "Cannot determine current branch."
  remote="$(select_git_remote "$remote" "push")"
  if [ -z "$remote" ]; then
    die "No remote selected."
  fi
  info "pushing $branch to $remote"
  git push -u "$remote" "$branch"
}

guess_pr_base() {
  local branch configured origin_head
  branch="$(git branch --show-current)"
  configured="$(git config --get "branch.$branch.gh-merge-base" 2>/dev/null || true)"
  if [ -n "$configured" ]; then
    printf '%s\n' "$configured"
    return 0
  fi
  origin_head="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##' || true)"
  if [ -n "$origin_head" ]; then
    printf '%s\n' "$origin_head"
    return 0
  fi
  if git show-ref --verify --quiet refs/heads/main || git show-ref --verify --quiet refs/remotes/origin/main; then
    printf 'main\n'
    return 0
  fi
  if git show-ref --verify --quiet refs/heads/master || git show-ref --verify --quiet refs/remotes/origin/master; then
    printf 'master\n'
    return 0
  fi
  printf 'main\n'
}

git_unmerged_paths() {
  git diff --name-only --diff-filter=U
}

git_integration_state() {
  local git_dir
  git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
  if [ -n "$git_dir" ] && [ -d "$git_dir/rebase-merge" -o -d "$git_dir/rebase-apply" ]; then
    printf 'rebase\n'
    return 0
  fi
  if [ -n "$git_dir" ] && [ -f "$git_dir/MERGE_HEAD" ]; then
    printf 'merge\n'
    return 0
  fi
  if [ -n "$(git_unmerged_paths)" ]; then
    printf 'conflict\n'
    return 0
  fi
  printf 'none\n'
}

current_branch_push_remote() {
  local branch configured upstream
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || return 0
  configured="$(git config --get "branch.$branch.remote" 2>/dev/null || true)"
  if [ -n "$configured" ] && [ "$configured" != "." ]; then
    printf '%s\n' "$configured"
    return 0
  fi
  upstream="$(git rev-parse --abbrev-ref --symbolic-full-name "@{upstream}" 2>/dev/null || true)"
  case "$upstream" in
    */*) printf '%s\n' "${upstream%%/*}" ;;
  esac
}

cmd_pull_main() {
  require_git_repo
  local base="" remote="" no_fetch=0 yolo=0 branch state root run_id run_dir log_file stash_push_log stash_apply_log pre_stash_status merge_conflicts_file stash_conflicts_file marker_file prompt_file final_file impact_prompt_file impact_file prompt_text target_ref before_head after_head merge_status apply_status stash_created=0 stash_ref="" dirty_before stash_push_output conflicts_before conflicts_after path merge_result="clean" stash_result="not-needed"
  while [ $# -gt 0 ]; do
    case "$1" in
      --base) shift; base="${1:-}" ;;
      --remote) shift; remote="${1:-}" ;;
      --no-fetch) no_fetch=1 ;;
      --yolo) yolo=1 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow pull-main [--base BRANCH] [--remote NAME] [--no-fetch] [--yolo]

Pulls the repository's main/base branch into the current branch with a merge.
The command auto-detects the base branch, stashes uncommitted work before the
merge, asks Codex to resolve conflicts, restores the stash, and writes an impact
report under .humanize-flow/runs/<timestamp>-pull-main/.

Options:
  --base BRANCH   Main/base branch. Defaults to branch gh-merge-base,
                  origin/HEAD, main, then master.
  --remote NAME   Remote to fetch the base branch from. Required in
                  non-interactive mode when multiple remotes exist.
  --no-fetch      Do not fetch before merging; use an existing local or
                  remote-tracking base ref.
  --yolo          Run Codex conflict-resolution prompts with yolo permissions.
EOF
        return 0 ;;
      *) die "Unknown pull-main option: $1" ;;
    esac
    shift
  done

  command_exists codex || die "codex CLI not found."
  root="$(repo_root)"
  cd "$root"
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || die "Cannot determine current branch."
  state="$(git_integration_state)"
  [ "$state" = "none" ] || die "Repository is already in a $state state. Resolve or abort that state before running pull-main."
  if [ -z "$base" ]; then base="$(guess_pr_base)"; fi
  [ "$branch" != "$base" ] || die "Current branch '$branch' matches detected base '$base'; switch to a feature branch before running pull-main."
  before_head="$(git rev-parse HEAD)"
  run_id="$(timestamp)-pull-main"

  dirty_before="$(git status --porcelain --untracked-files=all)"
  if [ -n "$dirty_before" ]; then
    info "stashing uncommitted work before pulling $base"
    pre_stash_status="$dirty_before"
    set +e
    stash_push_output="$(git stash push -u -m "humanize-flow pull-main autostash $run_id" 2>&1)"
    apply_status=$?
    set -e
    [ "$apply_status" -eq 0 ] || die "Failed to stash uncommitted work before pulling $base: $stash_push_output"
    stash_ref="$(git rev-parse -q --verify refs/stash 2>/dev/null || true)"
    [ -n "$stash_ref" ] || die "Git reported local changes but did not create a stash."
    stash_created=1
    stash_result="stashed"
  fi

  run_dir="$(state_dir)/runs/$run_id"
  mkdir -p "$run_dir"
  log_file="$run_dir/git-pull-main.log"
  stash_push_log="$run_dir/git-stash-push.log"
  stash_apply_log="$run_dir/git-stash-apply.log"
  merge_conflicts_file="$run_dir/merge-conflicted-files.txt"
  stash_conflicts_file="$run_dir/stash-conflicted-files.txt"
  marker_file="$run_dir/remaining-conflict-markers.txt"
  prompt_file="$run_dir/codex-pull-main-conflict-prompt.md"
  final_file="$run_dir/codex-pull-main-conflict-final.md"
  impact_prompt_file="$run_dir/codex-pull-main-impact-prompt.md"
  impact_file="$run_dir/impact-report.md"
  if [ "$stash_created" -eq 1 ]; then
    printf '%s\n' "$pre_stash_status" > "$run_dir/pre-stash-status.txt"
    printf '%s\n' "$stash_push_output" > "$stash_push_log"
  fi

  target_ref="$base"
  if [ "$no_fetch" -ne 1 ]; then
    remote="$(select_git_remote "$remote" "pull-main")"
    info "fetching $base from $remote"
    git fetch "$remote" "$base" > "$log_file" 2>&1 || {
      cat "$log_file" >&2
      die "Failed to fetch $base from $remote. Stashed work is still saved at ${stash_ref:-none}. Log: $log_file"
    }
    target_ref="FETCH_HEAD"
    if git show-ref --verify --quiet "refs/remotes/$remote/$base"; then
      target_ref="$remote/$base"
    fi
  elif [ -n "$remote" ] && git show-ref --verify --quiet "refs/remotes/$remote/$base"; then
    target_ref="$remote/$base"
  elif git show-ref --verify --quiet "refs/remotes/origin/$base"; then
    target_ref="origin/$base"
  fi

  info "merging $target_ref into $branch"
  set +e
  git merge --no-edit "$target_ref" >> "$log_file" 2>&1
  merge_status=$?
  set -e
  if [ "$merge_status" -ne 0 ]; then
    conflicts_before="$(git_unmerged_paths)"
    [ -n "$conflicts_before" ] || {
      cat "$log_file" >&2
      die "Merge failed without unmerged paths. Stashed work is still saved at ${stash_ref:-none}. Log: $log_file"
    }
    merge_result="conflicts-resolved"
    printf '%s\n' "$conflicts_before" > "$merge_conflicts_file"
    cat > "$prompt_file" <<EOF
You are resolving main branch integration conflicts in this repository.

Current branch: $branch
Detected main/base branch: $base
Target ref used: $target_ref
Git merge log: $log_file
Conflicted files list: $merge_conflicts_file

$(language_instruction)

Inspect:
- git status --short --untracked-files=all
- git diff --name-only --diff-filter=U
- git diff --cc
- git diff --ours -- <conflicted files>
- git diff --theirs -- <conflicted files>
- git log --oneline --left-right --merge
- The conflicted files themselves, including conflict markers.
- Relevant tests and nearby code needed to preserve behavior.

Rules:
- Resolve only conflicts caused by pulling the detected main/base branch into the current branch.
- Preserve intended behavior from both the current branch and the main/base branch when compatible.
- If behavior is genuinely incompatible, choose the smallest coherent resolution and explain the tradeoff.
- Do not broaden feature scope, rewrite unrelated code, or reformat unrelated files.
- Remove all conflict markers.
- You may stage only the conflicted files after you have fully resolved them.
- Do not commit, push, create a PR, run git reset, git checkout --, git restore, or git clean.
- Run focused tests or static checks when practical. If you cannot run them, explain why.

At the end, report:
- Files resolved.
- Behavioral choices made for each non-trivial conflict.
- Verification commands run and outcomes.
- Any remaining manual steps.
EOF
    info "merge conflict resolver prompt: $prompt_file"
    prompt_text="$(cat "$prompt_file")"
    if [ "$yolo" -eq 1 ]; then
      run_codex_exec --yolo "$prompt_text" | tee "$final_file"
    else
      run_codex_exec "$prompt_text" | tee "$final_file"
    fi
    : > "$marker_file"
    while IFS= read -r path || [ -n "$path" ]; do
      [ -n "$path" ] || continue
      [ -f "$path" ] || continue
      grep -nE '^(<<<<<<<|=======|>>>>>>>)' -- "$path" | sed "s#^#$path:#" >> "$marker_file" || true
    done <<EOF
$conflicts_before
EOF
    if [ -s "$marker_file" ]; then
      die "Conflict marker scan found remaining markers. See $marker_file. Stashed work is still saved at ${stash_ref:-none}."
    fi
    git add --pathspec-from-file="$merge_conflicts_file"
    conflicts_after="$(git_unmerged_paths)"
    if [ -n "$conflicts_after" ]; then
      printf '%s\n' "$conflicts_after" > "$run_dir/remaining-merge-conflicted-files.txt"
      die "Codex returned but merge conflicts remain. See $run_dir/remaining-merge-conflicted-files.txt and $final_file. Stashed work is still saved at ${stash_ref:-none}."
    fi
    info "creating main-branch merge commit"
    cmd_commit --yes
  fi

  if [ "$stash_created" -eq 1 ]; then
    info "restoring stashed uncommitted work"
    set +e
    git stash apply stash@{0} > "$stash_apply_log" 2>&1
    apply_status=$?
    set -e
    if [ "$apply_status" -eq 0 ]; then
      stash_result="restored; autostash retained at $stash_ref"
      success "stashed work restored; retained autostash at $stash_ref for safety"
    else
      conflicts_before="$(git_unmerged_paths)"
      if [ -z "$conflicts_before" ]; then
        stash_result="restore-blocked; autostash retained at $stash_ref; see $stash_apply_log"
        warn "stash restore was blocked without merge conflicts; retained autostash at $stash_ref"
      else
      stash_result="restore-conflicts-resolved"
      printf '%s\n' "$conflicts_before" > "$stash_conflicts_file"
      prompt_file="$run_dir/codex-pull-main-stash-conflict-prompt.md"
      final_file="$run_dir/codex-pull-main-stash-conflict-final.md"
      cat > "$prompt_file" <<EOF
You are resolving conflicts from restoring uncommitted work after pulling the main branch.

Current branch: $branch
Detected main/base branch: $base
Autostash ref before restore: $stash_ref
Stash apply log: $stash_apply_log
Conflicted files list: $stash_conflicts_file

$(language_instruction)

Inspect:
- git status --short --untracked-files=all
- git diff --name-only --diff-filter=U
- git diff --cc
- The conflicted files themselves, including conflict markers.
- Relevant nearby code needed to preserve both the pulled main-branch changes and the user's pre-existing uncommitted work.

Rules:
- Resolve only conflicts caused by restoring the user's pre-existing uncommitted work after the main/base branch merge.
- Preserve the user's local uncommitted intent unless it is clearly incompatible with the pulled branch; if incompatible, choose the smallest coherent resolution and explain the tradeoff.
- Remove all conflict markers.
- You may stage only the conflicted files after you have fully resolved them.
- Do not commit, push, create a PR, run git reset, git checkout --, git restore, git clean, or drop the stash.
- Run focused tests or static checks when practical. If you cannot run them, explain why.

At the end, report:
- Files resolved.
- Behavioral choices made for each non-trivial conflict.
- Verification commands run and outcomes.
- Whether restored local work is staged or unstaged.
EOF
      info "stash restore conflict resolver prompt: $prompt_file"
      prompt_text="$(cat "$prompt_file")"
      if [ "$yolo" -eq 1 ]; then
        run_codex_exec --yolo "$prompt_text" | tee "$final_file"
      else
        run_codex_exec "$prompt_text" | tee "$final_file"
      fi
      : > "$marker_file"
      while IFS= read -r path || [ -n "$path" ]; do
        [ -n "$path" ] || continue
        [ -f "$path" ] || continue
        grep -nE '^(<<<<<<<|=======|>>>>>>>)' -- "$path" | sed "s#^#$path:#" >> "$marker_file" || true
      done <<EOF
$conflicts_before
EOF
      if [ -s "$marker_file" ]; then
        die "Conflict marker scan found remaining markers after stash restore. See $marker_file. Autostash is still saved at $stash_ref."
      fi
      git add --pathspec-from-file="$stash_conflicts_file"
      conflicts_after="$(git_unmerged_paths)"
      if [ -n "$conflicts_after" ]; then
        printf '%s\n' "$conflicts_after" > "$run_dir/remaining-stash-conflicted-files.txt"
        die "Codex returned but stash restore conflicts remain. See $run_dir/remaining-stash-conflicted-files.txt. Autostash is still saved at $stash_ref."
      fi
      stash_result="restore-conflicts-resolved; autostash retained at $stash_ref"
      success "stashed work restored after conflict resolution; retained autostash at $stash_ref for safety"
      fi
    fi
  fi

  after_head="$(git rev-parse HEAD)"
  cat > "$impact_prompt_file" <<EOF
You are assessing the impact of pulling the main branch into the current branch.

Current branch: $branch
Detected main/base branch: $base
Target ref used: $target_ref
Head before integration: $before_head
Head after integration: $after_head
Merge result: $merge_result
Stash result: $stash_result
Run directory: $run_dir

$(language_instruction)

Inspect:
- git status --short --untracked-files=all
- git log --oneline --left-right $before_head...HEAD
- git diff --stat $before_head..HEAD
- git diff --name-status $before_head..HEAD
- git diff --stat
- git diff
- Conflict resolver reports in $run_dir if present.

Return a concise Markdown report with:
- Main/base branch detected and target ref used.
- Integration result.
- Impact scope: affected files, modules, user-facing behavior, tests, docs, and release risk.
- Conflict resolution summary, if conflicts occurred.
- Stash restoration summary, if local work was stashed.
- Verification performed or recommended next verification.
- Remaining risks or follow-up actions.
EOF
  info "impact assessment prompt: $impact_prompt_file"
  prompt_text="$(cat "$impact_prompt_file")"
  run_codex_exec --sandbox read-only "$prompt_text" | tee "$impact_file"
  success "pull-main complete; impact report: $impact_file"
}

cmd_pr_resolve() {
  require_git_repo
  local base="" remote="" strategy="merge" no_fetch=0 yolo=0 no_commit=0 no_push=0 branch state target_ref run_dir prompt_file final_file log_file conflicts_file marker_file prompt_text conflicts_before conflicts_after integrate_status integrate_cmd path push_remote
  while [ $# -gt 0 ]; do
    case "$1" in
      --base) shift; base="${1:-}" ;;
      --remote) shift; remote="${1:-}" ;;
      --merge) strategy="merge" ;;
      --rebase) strategy="rebase" ;;
      --no-fetch) no_fetch=1 ;;
      --no-commit) no_commit=1 ;;
      --no-push) no_push=1 ;;
      --yolo) yolo=1 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow pr-resolve [--base BRANCH] [--remote NAME] [--merge|--rebase] [--no-fetch] [--no-commit] [--no-push] [--yolo]

Integrates the PR target branch into the current branch, then asks Codex to
resolve merge conflicts if Git stops with unmerged paths. For the default merge
strategy, the command stages resolved conflict paths, creates the merge-resolution
commit, and pushes the current branch unless disabled with options.

Options:
  --base BRANCH   Target/base branch. Defaults to branch gh-merge-base,
                  origin/HEAD, main, then master.
  --remote NAME   Remote to fetch the base branch from. Required in
                  non-interactive mode when multiple remotes exist. Also used
                  for the final push when provided.
  --merge         Merge the target branch into the current branch. Default.
  --rebase        Rebase the current branch onto the target branch.
  --no-fetch      Do not fetch before integrating; use an existing local or
                  remote-tracking base ref.
  --no-commit     Stop after resolving and staging conflicts.
  --no-push       Create the merge-resolution commit but do not push.
  --yolo          Run the Codex conflict resolver with yolo permissions.
EOF
        return 0 ;;
      *) die "Unknown pr-resolve option: $1" ;;
    esac
    shift
  done

  command_exists codex || die "codex CLI not found."
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || die "Cannot determine current branch."
  if [ -z "$base" ]; then base="$(guess_pr_base)"; fi
  [ "$branch" != "$base" ] || die "Current branch '$branch' matches base '$base'; switch to a PR branch before resolving target conflicts."

  state="$(git_integration_state)"
  if [ "$state" = "none" ]; then
    if [ -n "$(git status --porcelain --untracked-files=no)" ]; then
      die "Tracked working tree changes must be committed or stashed before starting PR target-branch integration, or resolve the existing conflict state first."
    fi
  else
    info "detected existing $state state; resolving current unmerged paths instead of starting a new integration."
  fi

  run_dir="$(state_dir)/runs/$(timestamp)-pr-resolve"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-pr-resolve-prompt.md"
  final_file="$run_dir/codex-pr-resolve-final.md"
  log_file="$run_dir/git-pr-resolve.log"
  conflicts_file="$run_dir/conflicted-files.txt"
  marker_file="$run_dir/remaining-conflict-markers.txt"

  target_ref="$base"
  if [ "$state" = "none" ]; then
    if [ "$no_fetch" -ne 1 ]; then
      remote="$(select_git_remote "$remote" "PR target conflict resolution")"
      info "fetching $base from $remote"
      git fetch "$remote" "$base" > "$log_file" 2>&1 || {
        cat "$log_file" >&2
        die "Failed to fetch $base from $remote. Log: $log_file"
      }
      target_ref="FETCH_HEAD"
      if git show-ref --verify --quiet "refs/remotes/$remote/$base"; then
        target_ref="$remote/$base"
      fi
    elif [ -n "$remote" ] && git show-ref --verify --quiet "refs/remotes/$remote/$base"; then
      target_ref="$remote/$base"
    elif git show-ref --verify --quiet "refs/remotes/origin/$base"; then
      target_ref="origin/$base"
    fi

    info "integrating target branch $target_ref into $branch with $strategy"
    set +e
    if [ "$strategy" = "rebase" ]; then
      integrate_cmd="git rebase $target_ref"
      git rebase "$target_ref" >> "$log_file" 2>&1
    else
      integrate_cmd="git merge --no-edit $target_ref"
      git merge --no-edit "$target_ref" >> "$log_file" 2>&1
    fi
    integrate_status=$?
    set -e
    if [ "$integrate_status" -eq 0 ]; then
      success "target branch integrated cleanly; log: $log_file"
      if [ "$strategy" = "merge" ] && [ "$no_push" -ne 1 ]; then
        push_remote="$remote"
        [ -n "$push_remote" ] || push_remote="$(current_branch_push_remote)"
        info "pushing resolved branch"
        if [ -n "$push_remote" ]; then
          cmd_push --remote "$push_remote"
        else
          cmd_push
        fi
      elif [ "$strategy" = "merge" ]; then
        info "--no-push set; integrated branch not pushed."
      fi
      return 0
    fi
  else
    integrate_cmd="existing $state state"
    git status --short --untracked-files=all > "$log_file"
  fi

  conflicts_before="$(git_unmerged_paths)"
  [ -n "$conflicts_before" ] || {
    cat "$log_file" >&2
    die "Integration failed but Git does not report unmerged paths. Log: $log_file"
  }
  printf '%s\n' "$conflicts_before" > "$conflicts_file"

  cat > "$prompt_file" <<EOF
You are resolving PR target branch conflicts in this repository.

Current branch: $branch
Target/base branch: $base
Target ref used: $target_ref
Integration strategy: $strategy
Integration command: $integrate_cmd
Git integration log: $log_file
Conflicted files list: $conflicts_file

$(language_instruction)

Inspect:
- git status --short --untracked-files=all
- git diff --name-only --diff-filter=U
- git diff --cc
- git diff --ours -- <conflicted files>
- git diff --theirs -- <conflicted files>
- git log --oneline --left-right --merge
- The conflicted files themselves, including conflict markers.
- Relevant tests and nearby code needed to preserve behavior.
- AGENTS.md and CLAUDE.md when present.

Rules:
- Resolve only the merge/rebase conflicts caused by integrating the PR target branch.
- Preserve the intended behavior from both the PR branch and the target branch when they are compatible.
- If behavior is genuinely incompatible, choose the smallest coherent resolution and explain the tradeoff.
- Do not broaden feature scope, rewrite unrelated code, or reformat unrelated files.
- Remove all conflict markers.
- You may stage only the conflicted files after you have fully resolved them.
- Do not commit.
- Do not run git merge --continue, git rebase --continue, git commit, git push, gh pr create, git reset, git checkout --, git restore, or git clean.
- Run focused tests or static checks when practical. If you cannot run them, explain why.

At the end, report:
- Files resolved.
- Behavioral choices made for each non-trivial conflict.
- Verification commands run and outcomes.
- Any remaining manual steps, especially whether the user should run git commit for merge or git rebase --continue for rebase.
EOF

  info "conflict resolver prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  if [ "$yolo" -eq 1 ]; then
    run_codex_exec --yolo "$prompt_text" | tee "$final_file"
  else
    run_codex_exec "$prompt_text" | tee "$final_file"
  fi

  : > "$marker_file"
  while IFS= read -r path || [ -n "$path" ]; do
    [ -n "$path" ] || continue
    [ -f "$path" ] || continue
    grep -nE '^(<<<<<<<|=======|>>>>>>>)' -- "$path" | sed "s#^#$path:#" >> "$marker_file" || true
  done <<EOF
$conflicts_before
EOF
  if [ -s "$marker_file" ]; then
    die "Conflict marker scan found remaining markers. See $marker_file"
  fi
  git add --pathspec-from-file="$conflicts_file"
  conflicts_after="$(git_unmerged_paths)"
  if [ -n "$conflicts_after" ]; then
    printf '%s\n' "$conflicts_after" > "$run_dir/remaining-conflicted-files.txt"
    die "Codex returned but unmerged paths remain. See $run_dir/remaining-conflicted-files.txt and $final_file"
  fi

  success "conflicts resolved; Codex report: $final_file"
  if [ "$strategy" = "rebase" ] || [ "$state" = "rebase" ]; then
    info "next step: run tests, stage resolved files if needed, then git rebase --continue"
  else
    if [ "$no_commit" -eq 1 ]; then
      info "--no-commit set; resolved conflict paths are staged. Next step: run tests, then humanize-flow commit --yes"
      return 0
    fi
    info "creating merge-resolution commit"
    cmd_commit --yes
    if [ "$no_push" -eq 1 ]; then
      success "--no-push set; merge-resolution commit created but not pushed."
      return 0
    fi
    push_remote="$remote"
    [ -n "$push_remote" ] || push_remote="$(current_branch_push_remote)"
    info "pushing resolved branch"
    if [ -n "$push_remote" ]; then
      cmd_push --remote "$push_remote"
    else
      cmd_push
    fi
  fi
}

cmd_pr() {
  require_git_repo
  local base="" head="" draft=0 dry_run=0 yes=0 push_first=0 remote="" pr_remote="" pr_repo="" run_dir prompt_file draft_file title_file body_file guides_file pr_output_file pr_error_file pr_url_file prompt_text branch merge_base pr_output pr_url answer pr_status
  while [ $# -gt 0 ]; do
    case "$1" in
      --base) shift; base="${1:-}" ;;
      --head) shift; head="${1:-}" ;;
      --remote) shift; remote="${1:-}" ;;
      --draft) draft=1 ;;
      --dry-run) dry_run=1 ;;
      --yes|-y) yes=1 ;;
      --push) push_first=1 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow pr [--base BRANCH] [--head BRANCH] [--draft] [--push] [--yes] [--dry-run]

Uses Codex to draft a detailed, professional pull request title and body, then
creates the PR with GitHub CLI. The generated PR text follows the configured
Humanize Flow i18n language.

Options:
  --base BRANCH   Base branch for the PR. Defaults to branch gh-merge-base,
                  origin/HEAD, main, then master.
  --head BRANCH   Head branch for the PR. Defaults to the current branch.
  --remote NAME   GitHub remote/repository used for PR creation and by --push.
  --draft         Create a draft PR.
  --push          Push the current branch before creating the PR.
  --yes, -y       Skip confirmation after showing the generated PR draft.
  --dry-run       Generate and show the draft, but do not create the PR.
EOF
        return 0 ;;
      *) die "Unknown pr option: $1" ;;
    esac
    shift
  done

  command_exists codex || die "codex CLI not found."
  if [ "$dry_run" -ne 1 ]; then
    command_exists gh || die "GitHub CLI 'gh' not found."
    if ! gh auth status >/dev/null 2>&1; then
      die "GitHub CLI authentication check failed. Run 'gh auth login -h github.com' and retry humanize-flow pr."
    fi
  fi
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || die "Cannot determine current branch."
  if [ -z "$head" ]; then head="$branch"; fi
  if [ -z "$base" ]; then base="$(guess_pr_base)"; fi
  [ "$head" != "$base" ] || die "Current/head branch '$head' matches base '$base'; create or switch to a feature branch before opening a PR."
  merge_base="$(git merge-base HEAD "$base" 2>/dev/null || git merge-base HEAD "origin/$base" 2>/dev/null || true)"
  [ -n "$merge_base" ] || die "Could not determine merge base for $base. Pass --base BRANCH or fetch the base branch."
  if git diff --quiet "$merge_base"..HEAD && [ -z "$(git log --oneline "$merge_base"..HEAD)" ]; then
    die "No commits or diff found between $base and HEAD."
  fi

  if [ "$push_first" -eq 1 ] && [ "$dry_run" -eq 1 ]; then
    warn "--dry-run set; skipping --push."
  fi
  if [ "$dry_run" -ne 1 ]; then
    pr_remote="$(select_git_remote "$remote" "GitHub PR creation")"
  fi
  if [ "$push_first" -eq 1 ] && [ "$dry_run" -ne 1 ]; then
    cmd_push --remote "$pr_remote"
  fi
  if [ "$dry_run" -ne 1 ]; then
    pr_repo="$(repo_arg_from_remote "$pr_remote")"
  fi

  run_dir="$(state_dir)/runs/$(timestamp)-pr"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-pr-prompt.md"
  draft_file="$run_dir/pr-draft.json"
  title_file="$run_dir/pr-title.txt"
  body_file="$run_dir/pr-body.md"
  guides_file="$run_dir/human-verification-guides.md"
  pr_output_file="$run_dir/gh-pr-create-output.txt"
  pr_error_file="$run_dir/gh-pr-create-error.txt"
  pr_url_file="$run_dir/pr-url.txt"
  collect_pr_human_verification_guides "$guides_file"

  cat > "$prompt_file" <<EOF
You are drafting a professional GitHub pull request for this repository.

Base branch: $base
Head branch: $head
Merge base: $merge_base
GitHub repository: ${pr_repo:-"(dry run or inferred by gh)"}
PR title output: $title_file
PR body output: $body_file
Human verification guide source snippets: $guides_file

$(language_instruction)

Inspect:
- git status --short
- git log --oneline $merge_base..HEAD
- git log --format=fuller $merge_base..HEAD
- git diff --stat $merge_base..HEAD
- git diff $merge_base..HEAD
- docs/humanize-flow artifacts relevant to this branch, especially request.md, jira-requirement.md, plan.md, acceptance.md, implementation summaries, and review reports.
- .humanize-flow/handoffs/*.json when relevant.
- AGENTS.md and CLAUDE.md when present.
- Human verification guide source snippets below, when present.

Human verification guide source snippets:
$(if [ -s "$guides_file" ]; then cat "$guides_file"; else printf 'None found.\n'; fi)

Return only JSON with this shape:
{
  "title": "concise PR title",
  "body": "professional Markdown PR body"
}

PR body requirements:
- Be detailed enough for a maintainer to review without reconstructing context from scratch.
- Prioritize WHY over HOW and WHAT: explain the problem, user or maintainer impact, constraints, decision rationale, and why this branch is the right change before listing implementation details.
- Include mature, conventional sections for Summary, Why / Context, Notable Changes, Verification, Human verification guide, Risks / Rollback, and Reviewer Notes. Localize section titles to the configured language.
- Mention Humanize Flow handoff, Beads task ids, plan, acceptance, implementation summary, and review artifact paths when relevant.
- If any passing Codex review report includes a "Human verification guide", include that guide in the PR body as reviewer-facing validation context. Preserve concrete manual test steps, checklist items, stop conditions, and source review artifact paths. Do not mark checklist items complete unless the repository evidence proves completion.
- Use concrete test commands and outcomes when visible. If verification is not visible, say that honestly.
- Do not invent issue numbers, test results, reviewers, or external facts.
- Keep machine-readable literals canonical: file paths, commands, labels, JSON keys, APIs, Beads IDs, branch names, and commit hashes.
- Do not include Markdown fences around the JSON.
EOF

  info "PR prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  run_codex_exec "$prompt_text" > "$draft_file"
  sed -i.bak '/^```/d' "$draft_file"
  rm -f "$draft_file.bak"
  run_python3 - "$draft_file" "$title_file" "$body_file" <<'PY'
import json, re, sys
from pathlib import Path

draft_path = Path(sys.argv[1])
title_path = Path(sys.argv[2])
body_path = Path(sys.argv[3])
raw = draft_path.read_text(encoding="utf-8").strip()
try:
    data = json.loads(raw)
except Exception:
    match = re.search(r"\{.*\}", raw, re.S)
    if not match:
        raise SystemExit(f"could not parse Codex PR JSON: {draft_path}")
    data = json.loads(match.group(0))
title = str(data.get("title") or "").strip()
body = str(data.get("body") or "").strip()
if not title:
    raise SystemExit("Codex returned an empty PR title")
if not body:
    raise SystemExit("Codex returned an empty PR body")
title_path.write_text(title.splitlines()[0].strip() + "\n", encoding="utf-8")
body_path.write_text(body.rstrip() + "\n", encoding="utf-8")
PY
  append_pr_human_verification_guide_if_missing "$body_file" "$guides_file"

  info "PR title: $title_file"
  info "PR body: $body_file"
  log ""
  printf 'Title: '
  sed -n '1p' "$title_file"
  log ""
  sed -n '1,220p' "$body_file"
  log ""

  if [ "$dry_run" -eq 1 ]; then
    info "--dry-run set; PR not created."
    return 0
  fi
  if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ]; then
    printf 'Create PR with this title and body? [y/N] '
    read -r answer
    case "$answer" in
      y|Y|yes|YES) ;;
      *) die "PR creation cancelled. Draft kept in $run_dir" ;;
    esac
  fi

  set +e
  if [ "$draft" -eq 1 ]; then
    gh pr create --base "$base" --head "$head" --repo "$pr_repo" --title "$(cat "$title_file")" --body-file "$body_file" --draft > "$pr_output_file" 2> "$pr_error_file"
  else
    gh pr create --base "$base" --head "$head" --repo "$pr_repo" --title "$(cat "$title_file")" --body-file "$body_file" > "$pr_output_file" 2> "$pr_error_file"
  fi
  pr_status=$?
  set -e
  pr_output="$(cat "$pr_output_file")"
  if [ "$pr_status" -ne 0 ]; then
    warn "GitHub CLI failed while running gh pr create. stdout: $pr_output_file stderr: $pr_error_file"
    if [ -s "$pr_error_file" ]; then
      cat "$pr_error_file" >&2
    fi
    die "PR creation failed via GitHub CLI. This command uses gh pr create; check gh auth/network status and retry."
  fi
  printf '%s\n' "$pr_output" > "$pr_output_file"
  pr_url="$(printf '%s\n' "$pr_output" | grep -Eo 'https://[^[:space:]]+' | sed -n '1p')"
  if [ -n "$pr_url" ]; then
    printf '%s\n' "$pr_url" > "$pr_url_file"
    success "PR creation output: $pr_output_file"
    success "PR URL saved: $pr_url_file"
    printf 'Pull request URL: %s\n' "$pr_url"
  else
    warn "GitHub CLI did not print a pull request URL. Raw output saved: $pr_output_file"
    if [ -n "$pr_output" ]; then
      printf '%s\n' "$pr_output"
    fi
    printf 'View pull request with: gh pr view --repo %s --web\n' "$pr_repo"
  fi
}

status_snapshot_json() {
  local limit ready_file
  limit="$1"
  ready_file=""
  if command_exists bd; then
    ready_file="$(state_dir)/tmp/status-bd-ready-$(timestamp).json"
    mkdir -p "$(dirname "$ready_file")"
    bd ready --json > "$ready_file" 2>/dev/null || ready_file=""
  fi
  run_python3 - "$(repo_root)" "$(state_dir)" "$(docs_dir)" "$limit" "$ready_file" "$HF_VERSION" <<'PY'
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

repo = Path(sys.argv[1])
state_dir = Path(sys.argv[2])
docs_dir = Path(sys.argv[3])
limit = int(sys.argv[4])
ready_file = Path(sys.argv[5]) if sys.argv[5] else None
version = sys.argv[6]

def rel(path):
    if not path:
        return ''
    try:
        return str(Path(path).resolve().relative_to(repo.resolve()))
    except Exception:
        return str(path)

def strip_suffix(text, suffix):
    return text[:-len(suffix)] if suffix and text.endswith(suffix) else text

def read_json(path):
    try:
        return json.loads(Path(path).read_text(encoding='utf-8'))
    except Exception:
        return None

def git(args):
    try:
        cp = subprocess.run(['git', *args], cwd=repo, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False)
        return cp.stdout.strip()
    except Exception:
        return ''

def parse_ready(data):
    if isinstance(data, dict):
        items = data.get('issues') or data.get('items') or data.get('data') or data.get('ready') or []
    elif isinstance(data, list):
        items = data
    else:
        items = []
    out = []
    for item in items:
        if not isinstance(item, dict):
            continue
        task_id = item.get('id') or item.get('issue_id') or item.get('bead_id')
        if not task_id:
            continue
        labels = item.get('labels') or item.get('label_names') or []
        if isinstance(labels, str):
            labels = [x.strip() for x in labels.split(',') if x.strip()]
        out.append({
            'id': task_id,
            'title': item.get('title') or item.get('summary') or item.get('name') or '',
            'status': item.get('status') or '',
            'type': item.get('type') or item.get('issue_type') or '',
            'priority': item.get('priority'),
            'labels': labels,
            'parent': item.get('parent_id') or item.get('parent') or item.get('epic_id') or '',
        })
    return out

verdict_patterns = [
    re.compile(r'^\s*Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\s*$', re.I | re.M),
    re.compile(r'^\s*(?:[-*]\s*)?(?:verdict|final verdict)\s*[:：]\s*`?(pass|changes_requested|blocked)`?\b', re.I | re.M),
    re.compile(r'^\s*`(pass|changes_requested|blocked)`\s*$', re.I | re.M),
    re.compile(r'^\s*(pass|changes_requested|blocked)\s*$', re.I | re.M),
]

def review_verdict(path):
    try:
        if path.stat().st_size <= 0:
            return ''
        text = path.read_text(encoding='utf-8', errors='replace')
    except Exception:
        return ''
    for pattern in verdict_patterns:
        match = pattern.search(text)
        if match:
            return match.group(1).lower()
    embedded = re.findall(r'Humanize-Flow-Verdict\s*:\s*`?(pass|changes_requested|blocked)`?\b', text, re.I)
    unique = sorted({item.lower() for item in embedded})
    if len(unique) == 1:
        return unique[0]
    return ''

def path_mtime(path):
    try:
        return path.stat().st_mtime
    except Exception:
        return 0

def latest_lines(path, max_lines=8):
    try:
        lines = path.read_text(encoding='utf-8', errors='replace').splitlines()
    except Exception:
        return []
    important = []
    tokens = (
        'ERROR', 'WARN', 'blocked', 'Blocker', 'changes_requested', 'REQUEST_CHANGES',
        'pass', 'Verdict', 'result', '[result]', 'hook_progress', 'hook_response',
        'YOLO review verdict', 'reached max rounds', 'humanize mode'
    )
    for line in lines:
        if any(token in line for token in tokens):
            important.append(line[:500])
    return (important or lines)[-max_lines:]

def safe_review_verification_path(review_path):
    safe = re.sub(r'[^A-Za-z0-9_.-]+', '-', str(review_path)).strip('-')
    if safe.endswith('.md'):
        safe = safe[:-3]
    return state_dir / 'verifications' / f'{safe}.json'

def matching_verification_for_review(review_path):
    candidate = safe_review_verification_path(review_path)
    if candidate.exists():
        return candidate
    return None

def verification_matches(data, refs):
    if not isinstance(data, dict):
        return False
    refs = {str(item) for item in refs if item}
    if not refs:
        return False
    values = {
        str(data.get('ref') or ''),
        str(data.get('bd_id') or ''),
        str(data.get('handoff_slug') or ''),
    }
    return bool(refs & values)

def latest_verification_for_refs(refs):
    verifications_dir = state_dir / 'verifications'
    if not verifications_dir.exists():
        return None
    matches = []
    for path in verifications_dir.glob('*.json'):
        data = read_json(path)
        if verification_matches(data, refs):
            matches.append(path)
    if not matches:
        return None
    return sorted(matches, key=path_mtime, reverse=True)[0]

def classify_run(path):
    name = path.name
    kind = 'other'
    ref = ''
    if '-run-' in name:
        kind = 'run'
        ref = name.split('-run-', 1)[1]
    elif '-review-feedback-' in name:
        kind = 'review-feedback'
        ref = name.split('-review-feedback-', 1)[1]
    elif '-review-' in name:
        kind = 'review'
        ref = name.split('-review-', 1)[1]
    elif name.endswith('-commit'):
        kind = 'commit'
    elif name.endswith('-pr'):
        kind = 'pr'
    elif name.endswith('-status'):
        kind = 'status'
    files = {p.name: p for p in path.iterdir() if p.is_file()} if path.is_dir() else {}
    status = 'unknown'
    evidence = []
    final = files.get('claude-final.md') or files.get('codex-worker-final.md')
    raw = files.get('claude-final.jsonl')
    review_prompt = files.get('codex-reviewer-prompt.md')
    feedback_prompt = files.get('codex-review-feedback-prompt.md')
    commit_log = files.get('git-commit.log')
    pr_url = files.get('pr-url.txt')
    if final and final.exists():
        text = final.read_text(encoding='utf-8', errors='replace')[-20000:]
        if re.search(r'\[result\]\s+success|"subtype"\s*:\s*"success"|Codex worker implemented', text):
            status = 'completed'
        if re.search(r'ERROR|Blocker|blocked|cannot proceed|denied|temporarily unavailable|reached max rounds', text, re.I):
            status = 'needs_attention'
        evidence.append(rel(final))
    if raw and raw.exists():
        evidence.append(rel(raw))
    if review_prompt and review_prompt.exists():
        evidence.append(rel(review_prompt))
    if feedback_prompt and feedback_prompt.exists():
        evidence.append(rel(feedback_prompt))
    if commit_log and commit_log.exists():
        status = 'failed'
        evidence.append(rel(commit_log))
    if pr_url and pr_url.exists():
        status = 'completed'
        evidence.append(rel(pr_url))
    if status == 'unknown' and kind in {'review', 'review-feedback', 'commit', 'pr', 'status'}:
        status = 'completed'
    return {
        'name': name,
        'kind': kind,
        'ref': ref,
        'status': status,
        'path': rel(path),
        'modified_at': datetime.fromtimestamp(path_mtime(path), timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z'),
        'evidence': evidence,
        'signals': latest_lines(final or commit_log, 8) if (final or commit_log) else [],
    }

handoffs = []
handoff_by_task = {}
tasks_by_handoff = {}
handoffs_dir = state_dir / 'handoffs'
if handoffs_dir.exists():
    for path in sorted(handoffs_dir.glob('*.json')):
        data = read_json(path)
        if not isinstance(data, dict):
            handoffs.append({'slug': path.stem, 'path': rel(path), 'invalid': True})
            continue
        bd = data.get('bd') or {}
        epic = bd.get('epic') or {}
        tasks = []
        if isinstance(epic, dict) and epic.get('bd_id'):
            handoff_by_task[epic.get('bd_id')] = data.get('slug') or path.stem
        for task in bd.get('tasks') or []:
            if isinstance(task, dict):
                task_id = task.get('bd_id') or ''
                if task_id:
                    handoff_by_task[task_id] = data.get('slug') or path.stem
                tasks.append({
                    'id': task_id,
                    'key': task.get('key') or '',
                    'title': task.get('title') or '',
                })
        source = data.get('source') or {}
        if isinstance(source, dict) and source.get('bd_id'):
            handoff_by_task[source.get('bd_id')] = data.get('slug') or path.stem
        tasks_by_handoff[data.get('slug') or path.stem] = [task.get('id') for task in tasks if task.get('id')]
        handoffs.append({
            'slug': data.get('slug') or path.stem,
            'path': rel(path),
            'state': data.get('state') or '',
            'approval': (data.get('approval') or {}).get('status') or '',
            'materialized': bool(bd.get('materialized')),
            'epic_id': epic.get('bd_id') if isinstance(epic, dict) else '',
            'current_bd_id': ((data.get('execution') or {}).get('current_bd_id') or (source.get('bd_id') if isinstance(source, dict) else '')),
            'task_count': len(tasks),
            'tasks': tasks,
            'latest_review': rel((data.get('artifacts') or {}).get('latest_review') or ''),
        })

ready = []
if ready_file and ready_file.exists():
    ready_data = read_json(ready_file)
    ready = parse_ready(ready_data)[:limit]
    for item in ready:
        item['handoff'] = handoff_by_task.get(item['id'], '')

reviews = []
if docs_dir.exists():
    for path in sorted(docs_dir.glob('*/reviews/*.md'), key=path_mtime, reverse=True):
        verdict = review_verdict(path)
        reviews.append({
            'path': rel(path),
            'slug': path.parent.parent.name,
            'name': path.name,
            'verdict': verdict or 'unparseable',
            'empty': path.stat().st_size <= 0,
            'modified_at': datetime.fromtimestamp(path_mtime(path), timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z'),
        })
        if len(reviews) >= limit:
            break

runs = []
runs_dir = state_dir / 'runs'
if runs_dir.exists():
    for path in sorted([p for p in runs_dir.iterdir() if p.is_dir()], key=path_mtime, reverse=True):
        run = classify_run(path)
        if run.get('kind') == 'status':
            continue
        runs.append(run)
        if len(runs) >= limit:
            break

inner_rlcr = []
rlcr_dir = repo / '.humanize' / 'rlcr'
if rlcr_dir.exists():
    for path in sorted([p for p in rlcr_dir.iterdir() if p.is_dir()], key=path_mtime, reverse=True):
        result_paths = sorted(path.glob('round-*-review-result.md'), key=path_mtime, reverse=True)
        latest = result_paths[0] if result_paths else None
        verdict = ''
        if latest:
            try:
                tail = latest.read_text(encoding='utf-8', errors='replace')[-4000:]
                if 'REQUEST_CHANGES' in tail:
                    verdict = 'REQUEST_CHANGES'
                elif 'PASS' in tail:
                    verdict = 'PASS'
            except Exception:
                pass
        inner_rlcr.append({
            'path': rel(path),
            'latest_review_result': rel(latest) if latest else '',
            'latest_signal': verdict,
            'modified_at': datetime.fromtimestamp(path_mtime(path), timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z'),
        })
        if len(inner_rlcr) >= min(limit, 5):
            break

dirty = git(['status', '--short', '--branch'])
branch_status = dirty.splitlines()[0] if dirty else ''
has_changes = any(line and not line.startswith('## ') for line in dirty.splitlines())
ahead_match = re.search(r'\bahead\s+(\d+)', branch_status)
behind_match = re.search(r'\bbehind\s+(\d+)', branch_status)
ahead = int(ahead_match.group(1)) if ahead_match else 0
behind = int(behind_match.group(1)) if behind_match else 0

latest_run = runs[0] if runs else None
latest_review = reviews[0] if reviews else None
summary = 'No Humanize Flow run history found.'
state = 'idle'
next_actions = []
warnings = []

if latest_run:
    state = latest_run['status']
    summary = f"Latest activity is {latest_run['kind']} `{latest_run['name']}` with status `{latest_run['status']}`."
    if latest_run['status'] in {'needs_attention', 'failed'}:
        next_actions.append(f"Inspect {latest_run['path']}")
if latest_review:
    if latest_review['verdict'] == 'pass':
        verification_path = None
        review_refs = {latest_review.get('slug') or ''}
        ref = strip_suffix(latest_review['name'], '.md').split('-', 2)[-1]
        review_refs.add(ref)
        slug_for_review = latest_review.get('slug') or ''
        if slug_for_review:
            review_refs.update(tasks_by_handoff.get(slug_for_review, []))
        linked_verification = matching_verification_for_review(latest_review['path'])
        if linked_verification:
            verification_path = rel(linked_verification)
        else:
            standalone_verification = latest_verification_for_refs(review_refs)
            if standalone_verification:
                verification_path = rel(standalone_verification)
        if verification_path:
            next_actions.append(f'Human verification already recorded: {verification_path}.')
            if has_changes:
                next_actions.append('Delivery is unlocked: run humanize-flow commit when ready.')
            elif ahead > 0:
                next_actions.append('Delivery is unlocked: run humanize-flow push or humanize-flow pr.')
        elif has_changes:
            next_actions.append(f'Delivery gate: complete the Human verification guide, then run humanize-flow verify {ref}.')
            next_actions.append('After verification, run humanize-flow commit when ready.')
        elif ahead > 0:
            next_actions.append(f'Delivery gate: run humanize-flow verify {ref} after manual testing; then run humanize-flow push or humanize-flow pr.')
        else:
            next_actions.append(f'Delivery gate: complete the Human verification guide, then run humanize-flow verify {ref}.')
    elif latest_review['verdict'] in {'changes_requested', 'blocked'}:
        ref = strip_suffix(latest_review['name'], '.md').split('-', 2)[-1]
        next_actions.append(f"Run humanize-flow run {ref} --yolo after reviewing {latest_review['path']}.")
if ready:
    first_ready = ready[0]
    if first_ready.get('handoff'):
        next_actions.append(f"Continue ready work: humanize-flow run {first_ready['id']} --yolo --max-round 5")
        next_actions.append(f"Continue the handoff/Epic queue: humanize-flow run {first_ready['handoff']} --yolo --max-round 5")
    else:
        next_actions.append(f"Continue ready work: humanize-flow run {first_ready['id']} --yolo --max-round 5")
        next_actions.append("Or pick interactively: humanize-flow run-next")
if inner_rlcr and latest_review and inner_rlcr[0].get('latest_signal') == 'REQUEST_CHANGES' and latest_review.get('verdict') == 'pass':
    warnings.append('Inner humanize/RLCR latest review requested changes, but the outer Humanize Flow review passed. Treat outer docs/humanize-flow review as the task-close gate unless you intentionally enabled nested RLCR.')
if not next_actions:
    if has_changes:
        next_actions.append('Working tree has changes. Inspect git status and run humanize-flow review or humanize-flow commit when appropriate.')
    elif ahead > 0:
        next_actions.append('Branch has local commits not pushed. Run humanize-flow push or humanize-flow pr when ready.')
    elif behind > 0:
        next_actions.append('Branch is behind upstream. Pull/rebase outside Humanize Flow before continuing.')
    else:
        next_actions.append('No obvious next command. Inspect the latest run/review evidence paths above.')

snapshot = {
    'schema_version': '1',
    'generated_at': datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z'),
    'humanize_flow_version': version,
    'repository': str(repo),
    'git': {
        'branch_status': branch_status,
        'has_changes': has_changes,
        'ahead': ahead,
        'behind': behind,
    },
    'state': state,
    'summary': summary,
    'next_actions': next_actions[:5],
    'warnings': warnings,
    'handoffs': handoffs,
    'ready': ready,
    'recent_reviews': reviews,
    'recent_runs': runs,
    'inner_rlcr': inner_rlcr,
}
print(json.dumps(snapshot, ensure_ascii=False, indent=2))
PY
}

status_render_text() {
  local snapshot_file
  snapshot_file="$1"
  run_python3 - "$snapshot_file" <<'PY'
import json
import sys

with open(sys.argv[1], encoding='utf-8') as fh:
    data = json.load(fh)

def line(text=''):
    print(text)

state = data.get('state', 'unknown')
state_icon = {
    'ready': '✅',
    'active': 'ℹ️',
    'needs_attention': '⚠️',
    'failed': '❌',
    'blocked': '⛔',
}.get(state, 'ℹ️')

line('Humanize Flow Status ℹ️')
line(f"- State: {state_icon} {state}")
line(f"- Summary: {data.get('summary', '')}")
git = data.get('git') or {}
line(f"- Git: {git.get('branch_status', '') or '(unknown)'}; changes={'yes' if git.get('has_changes') else 'no'}")
if git.get('ahead') or git.get('behind'):
    line(f"- Upstream: ahead={git.get('ahead', 0)} behind={git.get('behind', 0)}")
line(f"- Version: {data.get('humanize_flow_version', '')}")

warnings = data.get('warnings') or []
if warnings:
    line('')
    line('Warnings: ⚠️')
    for item in warnings:
        line(f"- {item}")

actions = data.get('next_actions') or []
if actions:
    line('')
    line('Next Actions: ➡️')
    for item in actions:
        line(f"- {item}")

runs = data.get('recent_runs') or []
line('')
line('Recent Activity: 🧭')
if not runs:
    line("- No run/review activity found.")
else:
    for item in runs[:8]:
        line(f"- {item.get('kind')} {item.get('ref') or item.get('name')}: {item.get('status')} ({item.get('path')})")
        for signal in (item.get('signals') or [])[-2:]:
            if signal:
                line(f"  signal: {signal}")

reviews = data.get('recent_reviews') or []
line('')
line('Recent Reviews: 📝')
if not reviews:
    line("- No review artifacts found.")
else:
    for item in reviews[:8]:
        line(f"- {item.get('verdict')}: {item.get('path')}")

ready = data.get('ready') or []
line('')
line('Ready Beads: ✅')
if not ready:
    line("- None reported by bd ready.")
else:
    for item in ready[:8]:
        handoff = f" handoff={item.get('handoff')}" if item.get('handoff') else ''
        title = f" - {item.get('title')}" if item.get('title') else ''
        line(f"- {item.get('id')} [{item.get('type') or 'task'}]{handoff}{title}")

handoffs = data.get('handoffs') or []
line('')
line('Handoffs: 📦')
if not handoffs:
    line("- No handoffs found.")
else:
    for item in handoffs:
        if item.get('invalid'):
            line(f"- {item.get('slug')}: invalid JSON ({item.get('path')})")
            continue
        line(f"- {item.get('slug')}: state={item.get('state') or '?'} approval={item.get('approval') or '?'} materialized={item.get('materialized')} tasks={item.get('task_count', 0)}")

inner = data.get('inner_rlcr') or []
if inner:
    line('')
    line('Inner humanize/RLCR: 🔁')
    for item in inner[:5]:
        signal = item.get('latest_signal') or 'unknown'
        line(f"- {signal}: {item.get('latest_review_result') or item.get('path')}")
PY
}

cmd_status() {
  require_git_repo
  local explain=0 json=0 limit=8 snapshot_file prompt_file explain_file prompt_text run_dir
  while [ $# -gt 0 ]; do
    case "$1" in
      --ai|--explain) explain=1 ;;
      --json) json=1 ;;
      --limit) shift; limit="${1:-}" ;;
      --help|-h|help)
        cat <<'EOF'
Usage:
  humanize-flow status [--ai|--explain] [--json] [--limit N]

Shows a one-glance Humanize Flow status view: repository state, latest run or
review activity, approved handoffs, Beads ready queue, suspicious blockers, and
suggested next commands.

Options:
  --ai         Ask Codex to explain the current status snapshot in plain human language.
  --explain    Alias for --ai.
  --json       Print the deterministic status snapshot as JSON.
  --limit N    Number of recent run/review directories and ready tasks to show. Default: 8.
EOF
        return 0 ;;
      --*) die "Unknown status option: $1" ;;
      *) die "Unexpected status argument: $1" ;;
    esac
    shift
  done
  case "$limit" in
    ''|*[!0-9]*) die "--limit must be a positive integer." ;;
  esac
  [ "$limit" -ge 1 ] || die "--limit must be at least 1."
  if [ "$json" -eq 1 ] && [ "$explain" -eq 0 ]; then
    status_snapshot_json "$limit"
    return 0
  fi
  if [ "$explain" -eq 1 ]; then
    command_exists codex || die "codex CLI not found; status --ai requires Codex."
    run_dir="$(state_dir)/runs/$(timestamp)-status"
    mkdir -p "$run_dir"
    snapshot_file="$run_dir/status-snapshot.json"
    prompt_file="$run_dir/codex-status-explain-prompt.md"
    explain_file="$run_dir/status-explanation.md"
    status_snapshot_json "$limit" > "$snapshot_file"
    status_render_text "$snapshot_file"
    cat > "$prompt_file" <<EOF
You are explaining a Humanize Flow status snapshot for a developer who wants to know whether the workflow is still making progress, stuck, failed, or ready for the next command.

$(language_instruction)

Use only the snapshot below. Do not inspect or modify files unless the user runs another command. Be concise and practical.

Explain:
- Current state in one sentence.
- Whether the workflow is running, blocked, passed, failed, or waiting for the next step.
- The evidence paths that justify that conclusion.
- The next command the user should run, if there is one.
- Any caveat when Humanize Flow outer review and inner humanize/RLCR review could be confused.

Status snapshot JSON:

$(cat "$snapshot_file")
EOF
    log ""
    info "status snapshot: $snapshot_file"
    info "status explain prompt: $prompt_file"
    prompt_text="$(cat "$prompt_file")"
    run_codex_exec --sandbox read-only "$prompt_text" | tee "$explain_file"
    success "status explanation written: $explain_file"
    return 0
  fi
  snapshot_file="$(state_dir)/tmp/status-snapshot-$(timestamp).json"
  mkdir -p "$(dirname "$snapshot_file")"
  status_snapshot_json "$limit" > "$snapshot_file"
  status_render_text "$snapshot_file"
}

main() {
  local cmd
  cmd="${1:-help}"
  if [ $# -gt 0 ]; then shift; fi
  case "$cmd" in
    help|--help|-h) usage ;;
    version|--version) log "$HF_VERSION" ;;
    paths) cmd_paths "$@" ;;
    doctor) cmd_doctor "$@" ;;
    init) cmd_init "$@" ;;
    plan) cmd_plan "$@" ;;
    plan-from-bd|from-bd) cmd_plan_from_bd "$@" ;;
    approve) cmd_approve "$@" ;;
    materialize-bd) cmd_materialize_bd "$@" ;;
    run) cmd_run "$@" ;;
    run-next) cmd_run_next "$@" ;;
    review) cmd_review "$@" ;;
    review-feedback) cmd_review_feedback "$@" ;;
    verify) cmd_verify "$@" ;;
    commit) cmd_commit "$@" ;;
    push) cmd_push "$@" ;;
    pull-main|main-pull) cmd_pull_main "$@" ;;
    pr) cmd_pr "$@" ;;
    pr-resolve|resolve-pr) cmd_pr_resolve "$@" ;;
    status) cmd_status "$@" ;;
    config) cmd_config "$@" ;;
    i18n) cmd_i18n "$@" ;;
    *) die "Unknown command: $cmd. Run 'humanize-flow help'." ;;
  esac
}

main "$@"
