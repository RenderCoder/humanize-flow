if tasks and (is_slug_ref or (epic_id and ref == epic_id)):
    for task_id in tasks:
        print(task_id)
    raise SystemExit(0)

if ref:
    print(ref)
    raise SystemExit(0)

if epic_id:
    print(epic_id)
    raise SystemExit(0)
for task_id in tasks:
    print(task_id)
    raise SystemExit(0)
raise SystemExit(1)
PY
}

