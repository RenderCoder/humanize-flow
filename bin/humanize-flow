  cat <<EOF
version: $HF_VERSION
dist_root: $DIST_ROOT
repo_root: $(repo_root)
state_dir: $(state_dir)
docs_dir: $(docs_dir)
user_config: $(user_config_path)
language: $(language_default)
python3: $(python3_bin)
claude.model: $(claude_model_default)
claude.permission_mode: $(claude_permission_mode_default)
claude.humanize: $(claude_humanize_default)
claude.env_file: $(display_optional_config "$(claude_env_file_default)" "(disabled)")
worker.provider: $(worker_provider_default)
worker.codex.model: $(worker_codex_model_default)
worker.codex.reasoning_effort: $(worker_codex_reasoning_effort_default)
yolo.max_round: $(yolo_max_round_default)
yolo.review_strategy: $(yolo_review_strategy_default)
codex.model: $(display_optional_config "$(codex_model_default)" "(codex default)")
codex.reasoning_effort: $(display_optional_config "$(codex_reasoning_effort_default)" "(codex default)")
review.yolo: $(review_yolo_default)
review.sandbox: $(review_sandbox_default)
codex_user_skills_dir: $HOME/.agents/skills
claude_user_skills_dir: ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills
EOF
}

cmd_doctor() {
  local failures=0 resolved_python
  info "version: $HF_VERSION"
  info "dist root: $DIST_ROOT"
  info "language: $(language_default)"
  if resolved_python="$(find_python3_bin)"; then
    info "python3: $resolved_python"
  else
    info "python3: not found"
  fi
  info "claude model: $(claude_model_default)"
  info "claude permission mode: $(claude_permission_mode_default)"
  info "claude humanize: $(claude_humanize_default)"
  info "claude env file: $(display_optional_config "$(claude_env_file_default)" "(disabled)")"
  info "worker provider: $(worker_provider_default)"
  info "worker codex model: $(worker_codex_model_default)"
  info "worker codex reasoning effort: $(worker_codex_reasoning_effort_default)"
  info "yolo max round: $(yolo_max_round_default)"
  info "yolo review strategy: $(yolo_review_strategy_default)"
  info "codex model: $(display_optional_config "$(codex_model_default)" "(codex default)")"
  info "codex reasoning effort: $(display_optional_config "$(codex_reasoning_effort_default)" "(codex default)")"
  info "review yolo: $(review_yolo_default)"
  info "review sandbox: $(review_sandbox_default)"

  for bin in git python3 gh codex claude bd jq; do
    if [ "$bin" = "python3" ] && [ -n "$resolved_python" ]; then
      doctor_line ok "$(printf '%-10s %s' "$bin" "$resolved_python")"
    elif command_exists "$bin"; then
      doctor_line ok "$(printf '%-10s %s' "$bin" "$(command -v "$bin")")"
    else
      case "$bin" in
        git|python3)
          doctor_line fail "$(printf '%-10s missing' "$bin")"
          failures=$((failures + 1))
          ;;
        *)
          doctor_line warn "$(printf '%-10s missing' "$bin")"
          ;;
      esac
    fi
  done

  if [ -d "$HOME/.agents/skills/humanize-flow-planner" ] || [ -d "$(repo_root)/.agents/skills/humanize-flow-planner" ]; then
    doctor_line ok "codex skill humanize-flow-planner installed"
  else
    doctor_line warn "codex skill humanize-flow-planner not found"
  fi

  if [ -d "$HOME/.agents/skills/humanize-flow-bd-planner" ] || [ -d "$(repo_root)/.agents/skills/humanize-flow-bd-planner" ]; then
    doctor_line ok "codex skill humanize-flow-bd-planner installed"
  else
    doctor_line warn "codex skill humanize-flow-bd-planner not found"
  fi

  if [ -d "$HOME/.agents/skills/humanize-flow-reviewer" ] || [ -d "$(repo_root)/.agents/skills/humanize-flow-reviewer" ]; then
    doctor_line ok "codex skill humanize-flow-reviewer installed"
  else
    doctor_line warn "codex skill humanize-flow-reviewer not found"
  fi

  if [ -d "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/humanize-flow-worker" ] || [ -d "$(repo_root)/.claude/skills/humanize-flow-worker" ]; then
    doctor_line ok "claude skill humanize-flow-worker installed"
  else
    doctor_line warn "claude skill humanize-flow-worker not found"
  fi

  if humanize_path="$(humanize_integration_path 2>/dev/null || true)" && [ -n "$humanize_path" ]; then
    doctor_line ok "humanize integration found: $humanize_path"
  else
    if [ "$(claude_humanize_default)" = "required" ]; then
      doctor_line fail "humanize integration not detected (claude.humanize=required)"
      failures=$((failures + 1))
    else
      doctor_line warn "humanize integration not detected (claude.humanize=$(claude_humanize_default))"
    fi
  fi

  if command_exists gh; then
    if gh auth status >/dev/null 2>&1; then
      doctor_line ok "gh auth status"
    else
      doctor_line warn "gh auth status failed; run gh auth login before using humanize-flow pr"
    fi
  fi

  if [ "$failures" -gt 0 ]; then
    die "$failures required tool(s) missing."
  fi
}

cmd_init() {
  require_git_repo
  local with_bd=0 stealth=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --with-bd) with_bd=1 ;;
      --bd-stealth) with_bd=1; stealth=1 ;;
      --help|-h)
        cat <<'EOF'
Usage: humanize-flow init [--with-bd] [--bd-stealth]

Creates .humanize-flow/ and docs/humanize-flow/ in the current git repository.
Use --with-bd to run 'bd init' when Beads is installed and not initialized.
Use --bd-stealth to run 'bd init --stealth' when supported.
EOF
        return 0 ;;
      *) die "Unknown init option: $1" ;;
    esac
    shift
  done

  mkdir -p "$(state_dir)/handoffs" "$(state_dir)/runs" "$(state_dir)/tmp" "$(state_dir)/verifications" "$(docs_dir)"
  if [ ! -f "$(state_dir)/config.json" ]; then
    cat > "$(state_dir)/config.json" <<EOF
{
  "schema_version": "1",
  "created_at": "$(iso_now)",
  "language": "$(language_default)",
  "default_docs_dir": "docs/humanize-flow",
  "default_state_dir": ".humanize-flow",
  "humanize_preferred": true
}
EOF
  fi
  if [ ! -f "$(state_dir)/README.md" ]; then
    cat > "$(state_dir)/README.md" <<'EOF'
# .humanize-flow

This directory stores Humanize Flow handoff manifests and run logs.

- `handoffs/` is intended to be committed when it describes approved work.
- `runs/`, `tmp/`, and `verifications/` are local runtime folders and may be ignored.
EOF
  fi

  if [ "$with_bd" -eq 1 ]; then
    if command_exists bd; then
      if bd info >/dev/null 2>&1; then
        success "Beads already initialized."
      else
        if [ "$stealth" -eq 1 ]; then
          info "running bd init --stealth"
          bd init --stealth
        else
          info "running bd init"
          bd init
        fi
      fi
    else
      warn "bd not installed; skipped bd init."
    fi
  fi

  success "initialized $(repo_root)"
}

write_request_file() {
  local slug request from target
  slug="$1"; request="$2"; from="$3"
  mkdir -p "$(docs_dir)/$slug"
  target="$(docs_dir)/$slug/request.md"
  if [ -n "$from" ]; then
    cp "$from" "$target"
  else
    cat > "$target" <<EOF
# Request: $slug

$request
EOF
  fi
  printf '%s\n' "$target"
}

cmd_plan() {
  require_git_repo
  local slug request from no_codex sandbox run_dir request_path prompt_file final_file prompt_text
  slug=""; request=""; from=""; no_codex=0; sandbox="workspace-write"
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug) shift; slug="${1:-}" ;;
      --request) shift; request="${1:-}" ;;
      --from) shift; from="${1:-}" ;;
      --no-codex) no_codex=1 ;;
      --sandbox) shift; sandbox="${1:-}" ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow plan --slug SLUG --from FILE
  humanize-flow plan --slug SLUG --request "text"

Runs Codex with the humanize-flow-planner skill. The planner should discuss
ambiguity when possible, then write Markdown artifacts and a draft handoff.
EOF
        return 0 ;;
      *) die "Unknown plan option: $1" ;;
    esac
    shift
  done

  if [ -z "$from" ] && [ -z "$request" ]; then die "plan requires --from FILE or --request TEXT."; fi
  if [ -n "$from" ] && [ ! -f "$from" ]; then die "request file not found: $from"; fi
  if [ -z "$slug" ]; then
    if [ -n "$request" ]; then slug="$(slugify "$request")"; else slug="$(slugify "$(basename "$from")")"; fi
  fi

  cmd_init >/dev/null
  request_path="$(write_request_file "$slug" "$request" "$from")"
  run_dir="$(state_dir)/runs/$(timestamp)-plan-$slug"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/planner-prompt.md"
  final_file="$run_dir/codex-final.md"

  cat > "$prompt_file" <<EOF
$(planner_skill_hint)

You are running the Humanize Flow planner for this repository.

Slug: $slug
Request file: $request_path
Required state dir: $(state_dir)
Required docs dir: $(docs_dir)
Required handoff path: $(handoff_path "$slug")

$(language_instruction)

Follow the humanize-flow-planner skill exactly:
- First understand the request and repository context.
- If important ambiguity remains and this is an interactive session, discuss it with the user before finalizing.
- If this is non-interactive and key ambiguity remains, write docs/humanize-flow/$slug/questions.md and stop with a concise summary.
- Do not modify implementation code.
- Produce request.md, jira-requirement.md, plan.md, acceptance.md, bd-plan.md, and .humanize-flow/handoffs/$slug.json.
- Write all generated Markdown and handoff prose, including jira-requirement.md, bd-plan.md, and Beads epic/task titles, descriptions, and acceptance criteria, in the configured language from the language policy above.
- Keep the handoff in state=draft and approval.status=pending unless the user explicitly approves in-session.
- Prepare Beads tasks in the handoff. Materialize them only after explicit human approval.
EOF

  info "planner prompt: $prompt_file"
  if [ "$no_codex" -eq 1 ]; then success "--no-codex set; prompt written but not executed."; return 0; fi
  command_exists codex || die "codex CLI not found."
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$final_file"
}

extract_bd_slug_seed() {
  run_python3 - "$1" "$2" <<'PY'
import json, re, sys
from pathlib import Path
path = Path(sys.argv[1])
fallback = sys.argv[2]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    print('bd-' + re.sub(r'[^a-z0-9]+', '-', fallback.lower()).strip('-'))
    raise SystemExit(0)

candidates = []

def walk(obj):
    if isinstance(obj, dict):
        for key in ('title', 'summary', 'name', 'text'):
            value = obj.get(key)
            if isinstance(value, str) and value.strip():
                candidates.append(value.strip())
        for value in obj.values():
            walk(value)
    elif isinstance(obj, list):
        for value in obj:
            walk(value)

walk(data)
seed = candidates[0] if candidates else fallback
seed = f"{fallback}-{seed}"
seed = seed.lower()
seed = re.sub(r'[^a-z0-9]+', '-', seed).strip('-')
print((seed[:80].strip('-') or 'bd-task'))
PY
}

cmd_plan_from_bd() {
  require_git_repo
  local bd_id slug no_codex sandbox run_dir prompt_file final_file prompt_text source_file tmp_source safe_bd_id
  bd_id=""; slug=""; no_codex=0; sandbox="workspace-write"
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug) shift; slug="${1:-}" ;;
      --no-codex) no_codex=1 ;;
      --sandbox) shift; sandbox="${1:-}" ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow plan-from-bd BD_ID [--slug SLUG]
  humanize-flow from-bd BD_ID [--slug SLUG]

Reads an existing Beads task with 'bd show BD_ID --json', captures it as
bd-source.json, and runs the humanize-flow-bd-planner Codex skill. This path
links the existing task instead of creating duplicate Beads tasks.

Options:
  --sandbox <mode>  Pass sandbox mode to codex exec; default is workspace-write.
  --no-codex        Capture the task and write the planner prompt, but do not execute Codex.
EOF
        return 0 ;;
      --*) die "Unknown plan-from-bd option: $1" ;;
      *)
        if [ -z "$bd_id" ]; then bd_id="$1"; else die "Unexpected extra argument: $1"; fi
        ;;
    esac
    shift
  done

  [ -n "$bd_id" ] || die "plan-from-bd requires a Beads task ID."
  command_exists bd || die "bd CLI not found; cannot read existing task $bd_id."
  cmd_init >/dev/null
  mkdir -p "$(state_dir)/tmp"
  safe_bd_id="$(slugify "$bd_id")"
  tmp_source="$(state_dir)/tmp/bd-source-$(timestamp)-$safe_bd_id.json"
  bd show "$bd_id" --json > "$tmp_source"

  if [ -z "$slug" ]; then
    slug="$(extract_bd_slug_seed "$tmp_source" "$bd_id")"
  fi

  mkdir -p "$(docs_dir)/$slug"
  source_file="$(docs_dir)/$slug/bd-source.json"
  cp "$tmp_source" "$source_file"

  run_dir="$(state_dir)/runs/$(timestamp)-plan-from-bd-$slug"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/bd-planner-prompt.md"
  final_file="$run_dir/codex-final.md"

  cat > "$prompt_file" <<EOF
$(bd_planner_skill_hint)

You are running the Humanize Flow existing-Beads-task planner for this repository.

Source Beads task id: $bd_id
Captured Beads source JSON: $source_file
Slug: $slug
Required state dir: $(state_dir)
Required docs dir: $(docs_dir)
Required handoff path: $(handoff_path "$slug")

$(language_instruction)

Follow the humanize-flow-bd-planner skill exactly:
- Read and understand the existing Beads task. Do not ask the user to repeat information already in bd.
- If important ambiguity remains and this is an interactive session, discuss it with the user before finalizing.
- If this is non-interactive and key ambiguity remains, write docs/humanize-flow/$slug/questions.md and stop with a concise summary.
- Do not modify implementation code.
- Do not invoke Claude Code.
- Do not create duplicate Beads tasks.
- Produce request.md, jira-requirement.md, plan.md, acceptance.md, bd-plan.md, and .humanize-flow/handoffs/$slug.json.
- Write all generated Markdown and handoff prose, including jira-requirement.md, bd-plan.md, and generated bd.tasks title, description, and acceptance criteria fields, in the configured language from the language policy above.
- Preserve $source_file as bd-source.json and reference it from the handoff artifacts map.
- Preserve source task text in bd-source.json/source metadata only; do not copy English source prose into generated plan or handoff bd.* prose when the configured language is different.
- In the handoff, set source.type=beads, source.bd_id=$bd_id, bd.materialized=true, and execution.current_bd_id=$bd_id.
- Keep the handoff in state=draft and approval.status=pending unless the user explicitly approves in-session.
- The normal next commands are: humanize-flow approve $slug ; humanize-flow run $bd_id ; humanize-flow review $bd_id
EOF

  info "bd planner prompt: $prompt_file"
  info "captured bd source: $source_file"
  if [ "$no_codex" -eq 1 ]; then success "--no-codex set; prompt written but not executed."; return 0; fi
  command_exists codex || die "codex CLI not found."
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$final_file"
}

cmd_approve() {
  require_git_repo
  local slug materialize file
  slug="${1:-}"; materialize=0
  [ -n "$slug" ] || die "Usage: humanize-flow approve SLUG [--materialize-bd]"
  shift || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --materialize-bd) materialize=1 ;;
      --help|-h) log "Usage: humanize-flow approve SLUG [--materialize-bd]"; return 0 ;;
      *) die "Unknown approve option: $1" ;;
    esac
    shift
  done
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || die "handoff not found: $file"
  run_python3 - "$file" <<'PY'
import json, sys, datetime, getpass
path = sys.argv[1]
with open(path, encoding='utf-8') as f:
    data = json.load(f)
data['state'] = 'approved'
data['updated_at'] = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
approval = data.setdefault('approval', {})
approval['required'] = True
approval['status'] = 'approved'
approval['approved_at'] = data['updated_at']
approval['approved_by'] = approval.get('approved_by') or getpass.getuser()
with open(path, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')
print(path)
PY
  success "approved $slug"
  if [ "$materialize" -eq 1 ]; then cmd_materialize_bd "$slug"; fi
}

cmd_materialize_bd() {
  require_git_repo
  local slug file lang
  slug="${1:-}"; [ -n "$slug" ] || die "Usage: humanize-flow materialize-bd SLUG"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || die "handoff not found: $file"
  command_exists bd || die "bd CLI not found. Install Beads or run without --materialize-bd."
  lang="$(language_default)"
  HUMANIZE_FLOW_LANGUAGE_EFFECTIVE="$lang" run_python3 - "$file" <<'PY'
import json, os, subprocess, sys, datetime, shlex
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding='utf-8'))
if data.get('approval', {}).get('status') != 'approved':
    raise SystemExit('handoff must be approved before materializing bd tasks')
bd = data.setdefault('bd', {})
if bd.get('materialized'):
    print('Beads tasks already materialized; nothing to do.')
    raise SystemExit(0)

def run(args):
    print('+ ' + ' '.join(shlex.quote(a) for a in args), file=sys.stderr)
    cp = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if cp.returncode != 0:
        sys.stderr.write(cp.stderr)
        raise SystemExit(cp.returncode)
    return cp.stdout.strip()

def find_id(obj):
    if isinstance(obj, dict):
        for key in ('id', 'issue_id', 'bead_id'):
            value = obj.get(key)
            if isinstance(value, str) and value:
                return value
        for value in obj.values():
            found = find_id(value)
            if found:
                return found
    elif isinstance(obj, list):
        for value in obj:
            found = find_id(value)
            if found:
                return found
    return None

lang = os.environ.get('HUMANIZE_FLOW_LANGUAGE_EFFECTIVE', 'en')
TEXT = {
    'en': {
        'context_header': 'Humanize Flow context:',
        'handoff': 'Handoff',
        'request': 'Request',
        'jira_requirement': 'Jira-style requirement',
        'plan': 'Plan',
        'acceptance': 'Acceptance',
        'bd_plan': 'Beads plan',
        'task_fallback': 'Humanize Flow task',
        'epic_fallback': 'Humanize Flow epic',
    },
    'zh': {
        'context_header': 'Humanize Flow 上下文:',
        'handoff': 'Handoff',
        'request': '需求',
        'jira_requirement': 'Jira 风格需求',
        'plan': '计划',
        'acceptance': '验收标准',
        'bd_plan': 'Beads 计划',
        'task_fallback': 'Humanize Flow 任务',
        'epic_fallback': 'Humanize Flow Epic',
    },
}.get(lang, {})

def text(key):
    return TEXT.get(key) or TEXT.get('en', {}).get(key) or key

def artifact_context():
    artifacts = data.get('artifacts') or {}
    slug = data.get('slug') or path.stem
    entries = [
        (text('handoff'), f'.humanize-flow/handoffs/{slug}.json'),
        (text('request'), artifacts.get('request')),
        (text('jira_requirement'), artifacts.get('jira_requirement')),
        (text('plan'), artifacts.get('plan')),
        (text('acceptance'), artifacts.get('acceptance')),
        (text('bd_plan'), artifacts.get('bd_plan')),
    ]
    lines = [text('context_header')]
    for label, value in entries:
        if value:
            lines.append(f'- {label}: `{value}`')
    return '\n'.join(lines)

def create_item(item, parent_id=None):
    title = item.get('title') or item.get('key') or text('task_fallback')
    typ = item.get('type') or 'task'
    priority = str(item.get('priority', 2))
    desc = item.get('description') or ''
    context = artifact_context()
    if 'Humanize Flow context:' not in desc and 'Humanize Flow 上下文:' not in desc:
        desc = desc.rstrip()
        if desc:
            desc += '\n\n'
        desc += context
    labels = list(item.get('labels') or [])
    if 'humanize-flow' not in labels:
        labels.insert(0, 'humanize-flow')
    if data.get('slug') and data.get('slug') not in labels:
        labels.append(data['slug'])
    args = ['bd', 'create', title, '-t', typ, '-p', priority, '--description', desc, '-l', ','.join(labels), '--json']
    if parent_id and typ != 'epic':
        args.extend(['--parent', parent_id])
    out = run(args)
    try:
        parsed = json.loads(out)
    except Exception:
        parsed = {'raw': out}
    bid = find_id(parsed)
    if not bid:
        raise SystemExit(f'could not parse bd id from output: {out}')
    item['bd_id'] = bid
    return bid

epic = bd.setdefault('epic', {'key': 'epic', 'title': data.get('summary') or data.get('slug') or text('epic_fallback'), 'type': 'epic', 'priority': 1, 'labels': []})
epic_id = create_item(epic, None)
key_to_id = {epic.get('key', 'epic'): epic_id}

tasks = bd.get('tasks') or []
for task in tasks:
    bid = create_item(task, epic_id)
    key_to_id[task.get('key') or bid] = bid

for task in tasks:
    child_id = task.get('bd_id')
    for dep_key in task.get('depends_on_keys') or []:
        parent_id = key_to_id.get(dep_key)
        if child_id and parent_id:
            run(['bd', 'dep', 'add', child_id, parent_id])

bd['materialized'] = True
data['bd'] = bd
data['state'] = 'approved'
data['updated_at'] = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n', encoding='utf-8')
print(f'Materialized {len(tasks)} task(s) under epic {epic_id}.')
PY
}

find_slug_for_bd_id() {
  local bd_id
  bd_id="$1"
  run_python3 - "$(state_dir)/handoffs" "$bd_id" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1]); target = sys.argv[2]
for path in sorted(root.glob('*.json')):
    try:
        data = json.loads(path.read_text(encoding='utf-8'))
    except Exception:
        continue
    ids = []
    source = data.get('source', {})
    if isinstance(source, dict):
        if source.get('bd_id'):
            ids.append(source.get('bd_id'))
        ids.extend(source.get('bd_ids') or [])
    execution = data.get('execution', {})
    if isinstance(execution, dict) and execution.get('current_bd_id'):
        ids.append(execution.get('current_bd_id'))
    epic = data.get('bd', {}).get('epic', {})
    if epic.get('bd_id'):
        ids.append(epic.get('bd_id'))
    for task in data.get('bd', {}).get('tasks', []):
        if task.get('bd_id'):
            ids.append(task.get('bd_id'))
    if target in ids:
        print(data.get('slug') or path.stem)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

find_handoff_for_ref() {
  local ref
  ref="$1"
  run_python3 - "$(state_dir)/handoffs" "$ref" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1])
target = sys.argv[2]
direct = root / f'{target}.json'
if direct.exists():
    try:
        data = json.loads(direct.read_text(encoding='utf-8'))
    except Exception:
        data = {}
    print(data.get('slug') or direct.stem)
    raise SystemExit(0)

for path in sorted(root.glob('*.json')):
    try:
        data = json.loads(path.read_text(encoding='utf-8'))
    except Exception:
        continue
    if target in {data.get('slug'), path.stem}:
        print(data.get('slug') or path.stem)
        raise SystemExit(0)
    ids = []
    source = data.get('source', {})
    if isinstance(source, dict):
        if source.get('bd_id'):
            ids.append(source.get('bd_id'))
        ids.extend(source.get('bd_ids') or [])
    execution = data.get('execution', {})
    if isinstance(execution, dict) and execution.get('current_bd_id'):
        ids.append(execution.get('current_bd_id'))
    epic = data.get('bd', {}).get('epic', {})
    if isinstance(epic, dict) and epic.get('bd_id'):
        ids.append(epic.get('bd_id'))
    for task in data.get('bd', {}).get('tasks', []):
        if isinstance(task, dict) and task.get('bd_id'):
            ids.append(task.get('bd_id'))
    if target in ids:
        print(data.get('slug') or path.stem)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

