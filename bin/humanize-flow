#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

HF_VERSION="0.5.11"
HF_NAME="humanize-flow"
HF_DEFAULT_CLAUDE_MODEL="claude-sonnet-4-6"
HF_DEFAULT_CLAUDE_PERMISSION_MODE="bypassPermissions"
HF_DEFAULT_CLAUDE_HUMANIZE="required"
HF_DEFAULT_WORKER_PROVIDER="claude"
HF_DEFAULT_WORKER_CODEX_MODEL="gpt-5.5"
HF_DEFAULT_WORKER_CODEX_REASONING_EFFORT="medium"
HF_DEFAULT_YOLO_MAX_ROUND="5"
HF_DEFAULT_YOLO_REVIEW_STRATEGY="final"
HF_DEFAULT_LANGUAGE="en"
HF_DEFAULT_CODEX_MODEL=""
HF_DEFAULT_CODEX_REASONING_EFFORT=""
HF_DEFAULT_REVIEW_SANDBOX="danger-full-access"
HF_DEFAULT_REVIEW_YOLO="true"

log() { printf '%s\n' "$*"; }

color_enabled() {
  local fd
  fd="$1"
  [ -z "${NO_COLOR:-}" ] || return 1
  [ -t "$fd" ]
}

colorize() {
  local fd code text
  fd="$1"; code="$2"; text="$3"
  if color_enabled "$fd"; then
    printf '\033[%sm%s\033[0m' "$code" "$text"
  else
    printf '%s' "$text"
  fi
}

emit() {
  local fd icon color label prefix
  fd="$1"; icon="$2"; color="$3"; label="$4"
  shift 4
  prefix="$(colorize "$fd" "$color" "$icon [$HF_NAME] $label")"
  if [ "$fd" = "2" ]; then
    printf '%s %s\n' "$prefix" "$*" >&2
  else
    printf '%s %s\n' "$prefix" "$*"
  fi
}

info() { emit 1 "ℹ️" "34" "INFO:" "$*"; }
success() { emit 1 "✅" "32" "SUCCESS:" "$*"; }
warn() { emit 2 "⚠️" "33" "WARN:" "$*"; }
die() { emit 2 "❌" "31" "ERROR:" "$*"; exit 1; }

doctor_line() {
  local status text icon color label
  status="$1"; shift
  text="$*"
  case "$status" in
    ok) icon="✅"; color="32"; label="OK" ;;
    warn) icon="⚠️"; color="33"; label="WARN" ;;
    fail) icon="❌"; color="31"; label="FAIL" ;;
    *) icon="ℹ️"; color="34"; label="INFO" ;;
  esac
  printf '  %s %s %s\n' "$icon" "$(colorize 1 "$color" "$label")" "$text"
}

usage() {
  cat <<'EOF'
humanize-flow - orchestrate Codex planning/review, Claude Code work, Beads tasks, and required-by-default humanize loops.

Usage:
  humanize-flow <command> [options]

Commands:
  help                         Show this help.
  version                      Show version.
  paths                        Show resolved installation paths.
  doctor                       Check local tools and skill installation.
  init [--with-bd]             Initialize .humanize-flow and docs/humanize-flow in the current git repo.
  plan --slug S --from FILE    Run Codex planner for a request file.
  plan --slug S --request TXT  Run Codex planner for inline request text.
  plan-from-bd BD_ID [--slug S]
                               Run Codex planner from an existing Beads task ID.
  from-bd BD_ID [--slug S]     Alias for plan-from-bd.
  approve SLUG [--materialize-bd]
                               Mark a handoff as approved; optionally create Beads tasks from it.
  materialize-bd SLUG          Create Beads epic/tasks from an approved handoff manifest.
  run BD_ID_OR_SLUG [options]  Run the configured worker for one Beads task.
  run-next                     Pick a ready Beads task, asking for Epic/task selection when needed, then run it.
  review BD_ID_OR_SLUG         Run Codex reviewer for one Beads task.
  review-feedback BD_ID_OR_SLUG [--note TEXT|--from FILE] [--review FILE]
                               Merge human review/test feedback into a new Codex review report.
  verify BD_ID_OR_SLUG         Record manual verification, linking a passing review when available.
  commit [--yes]               Use Codex to select changes, write a Lore message, and commit.
  push [--remote NAME]         Push the current branch, prompting for a remote when needed.
  pull-main [options]          Pull the main/base branch into the current branch.
  pr [options]                 Use Codex to draft a professional PR and create it with GitHub CLI.
  pr-resolve [options]         Merge or rebase the PR target branch and ask Codex to resolve conflicts.
  i18n [LANG]                  Show or set artifact language (en, zh).
  status [--ai|--explain|--json]
                               Show one-glance workflow status, logs, queue state, and next actions.
  config get KEY               Show resolved config value.
  config set KEY VALUE         Set a global config value.
  config show                  Show resolved Humanize Flow config.

Environment:
  HUMANIZE_FLOW_HOME           Distribution root. Default: ~/.local/share/humanize-flow when installed.
  HUMANIZE_FLOW_CLAUDE_ARGS    Extra Claude CLI args. Default: empty.
  HUMANIZE_FLOW_CLAUDE_MODEL   Override Claude Code model for worker runs.
  HUMANIZE_FLOW_CLAUDE_PERMISSION_MODE
                               Override Claude Code permission mode for worker runs.
  HUMANIZE_FLOW_CLAUDE_HUMANIZE
                               Override Claude Code humanize mode (required, auto, off).
  HUMANIZE_FLOW_WORKER_PROVIDER
                               Override worker provider (claude, codex).
  HUMANIZE_FLOW_WORKER_CODEX_MODEL
                               Override Codex worker model for YOLO runs.
  HUMANIZE_FLOW_WORKER_CODEX_REASONING_EFFORT
                               Override Codex worker reasoning effort for YOLO runs.
  HUMANIZE_FLOW_YOLO_MAX_ROUND Override default YOLO correction rounds.
  HUMANIZE_FLOW_YOLO_REVIEW_STRATEGY
                               Override YOLO review strategy (final, each-task).
  HUMANIZE_FLOW_CODEX_MODEL    Override Codex model for planner/review/commit/pr runs.
  HUMANIZE_FLOW_CODEX_REASONING_EFFORT
                               Override Codex reasoning effort for planner/review/commit/pr runs.
  HUMANIZE_FLOW_REVIEW_SANDBOX
                               Override Codex sandbox for review/review-feedback runs.
  HUMANIZE_FLOW_REVIEW_YOLO    Override Codex yolo mode for review/review-feedback runs.
  HUMANIZE_FLOW_LANGUAGE       Override artifact language for one command.
  HUMANIZE_FLOW_CODEX_ARGS     Extra Codex exec args. Default: empty.
  HUMANIZE_FLOW_PYTHON         Override Python 3 interpreter for internal helpers.
  HUMANIZE_FLOW_NONINTERACTIVE Set to 1 to avoid interactive prompts in scripts.

Examples:
  humanize-flow doctor
  humanize-flow init --with-bd
  humanize-flow plan --slug undo-redo --from docs/request.md
  humanize-flow plan-from-bd bd-1234 --slug undo-redo
  humanize-flow i18n zh
  humanize-flow approve undo-redo --materialize-bd
  humanize-flow run-next
  humanize-flow run bd-a1b2 --yolo
  humanize-flow review bd-a1b2
  humanize-flow review-feedback bd-a1b2
  humanize-flow commit
  humanize-flow commit --with-doc
  humanize-flow push
  humanize-flow pull-main
  humanize-flow pr --base main
  humanize-flow pr-resolve --base main
EOF
}

script_dir() { CDPATH= cd -- "$(dirname -- "$0")" && pwd; }

resolve_dist_root() {
  local sd parent
  sd="$(script_dir)"
  parent="$(CDPATH= cd -- "$sd/.." && pwd)"
  if [ -d "$parent/skills" ] && [ -d "$parent/schemas" ]; then
    printf '%s\n' "$parent"
    return 0
  fi
  if [ -n "${HUMANIZE_FLOW_HOME:-}" ]; then
    printf '%s\n' "$HUMANIZE_FLOW_HOME"
    return 0
  fi
  printf '%s\n' "$HOME/.local/share/humanize-flow"
}

DIST_ROOT="$(resolve_dist_root)"

repo_root() { git rev-parse --show-toplevel 2>/dev/null || pwd; }
require_git_repo() { git rev-parse --show-toplevel >/dev/null 2>&1 || die "Run this command inside a git repository."; }
command_exists() { command -v "$1" >/dev/null 2>&1; }
timestamp() { date -u +%Y%m%d-%H%M%S; }
iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
state_dir() { printf '%s/.humanize-flow\n' "$(repo_root)"; }
docs_dir() { printf '%s/docs/humanize-flow\n' "$(repo_root)"; }
handoff_path() { printf '%s/handoffs/%s.json\n' "$(state_dir)" "$1"; }
user_config_path() { printf '%s/humanize-flow/config.json\n' "${XDG_CONFIG_HOME:-$HOME/.config}"; }

HF_PYTHON3_BIN=""
HF_PYTHON3_ERROR=""

python3_candidate_usable() {
  local candidate
  candidate="$1"
  [ -n "$candidate" ] || return 1
  "$candidate" - <<'PY' >/dev/null 2>&1
import sys
raise SystemExit(0 if sys.version_info.major == 3 else 1)
PY
}

find_python3_bin() {
  local candidate command_candidate
  HF_PYTHON3_ERROR=""
  if [ -n "$HF_PYTHON3_BIN" ]; then
    printf '%s\n' "$HF_PYTHON3_BIN"
    return 0
  fi
  if [ -n "${HUMANIZE_FLOW_PYTHON:-}" ]; then
    if python3_candidate_usable "$HUMANIZE_FLOW_PYTHON"; then
      HF_PYTHON3_BIN="$HUMANIZE_FLOW_PYTHON"
      printf '%s\n' "$HF_PYTHON3_BIN"
      return 0
    fi
    HF_PYTHON3_ERROR="HUMANIZE_FLOW_PYTHON does not point to a usable Python 3 interpreter: $HUMANIZE_FLOW_PYTHON"
    return 1
  fi

  for command_candidate in python3 python; do
    candidate="$(command -v "$command_candidate" 2>/dev/null || true)"
    if python3_candidate_usable "$candidate"; then
      HF_PYTHON3_BIN="$candidate"
      printf '%s\n' "$HF_PYTHON3_BIN"
      return 0
    fi
  done

  for candidate in /opt/homebrew/bin/python3 /usr/local/bin/python3 /usr/bin/python3 "$HOME"/.pyenv/versions/*/bin/python3 "$HOME"/.pyenv/versions/*/bin/python3.[0-9]; do
    case "$candidate" in *'*'*) continue ;; esac
    if python3_candidate_usable "$candidate"; then
      HF_PYTHON3_BIN="$candidate"
      printf '%s\n' "$HF_PYTHON3_BIN"
      return 0
    fi
  done

  return 1
}

python3_bin() {
  find_python3_bin && return 0
  if [ -n "$HF_PYTHON3_ERROR" ]; then
    die "$HF_PYTHON3_ERROR"
  fi
  die "Python 3 is required. Install Python 3 or set HUMANIZE_FLOW_PYTHON=/path/to/python3."
}

run_python3() {
  local bin
  bin="$(python3_bin)"
  "$bin" "$@"
}

repo_relative_path() {
  local path root
  path="$1"
  root="$(repo_root)"
  case "$path" in
    "$root"/*) printf '%s\n' "${path#"$root"/}" ;;
    *) printf '%s\n' "$path" ;;
  esac
}

slugify() {
  run_python3 - "$@" <<'PY'
import re, sys
text = " ".join(sys.argv[1:]).strip().lower()
text = re.sub(r"[^a-z0-9]+", "-", text).strip("-")
print((text[:80].strip("-") or "request"))
PY
}

planner_skill_hint() { printf '%s\n' '$humanize-flow-planner'; }
bd_planner_skill_hint() { printf '%s\n' '$humanize-flow-bd-planner'; }
reviewer_skill_hint() { printf '%s\n' '$humanize-flow-reviewer'; }

json_get() {
  local file key default
  file="$1"; key="$2"; default="$3"
  run_python3 - "$file" "$key" "$default" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
key = sys.argv[2]
default = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    print(default)
    raise SystemExit(0)
value = data
for part in key.split('.'):
    if isinstance(value, dict) and part in value:
        value = value[part]
    else:
        print(default)
        raise SystemExit(0)
if isinstance(value, bool):
    print('true' if value else 'false')
elif value is None:
    print(default)
else:
    print(value)
PY
}

json_set() {
  local file key value
  file="$1"; key="$2"; value="$3"
  mkdir -p "$(dirname "$file")"
  run_python3 - "$file" "$key" "$value" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    data = {}
if not isinstance(data, dict):
    data = {}
cursor = data
parts = key.split('.')
for part in parts[:-1]:
    next_value = cursor.get(part)
    if not isinstance(next_value, dict):
        next_value = {}
        cursor[part] = next_value
    cursor = next_value
cursor[parts[-1]] = value
path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
PY
}

config_get_raw() {
  local key default value
  key="$1"; default="$2"
  value="$default"
  if [ -f "$(user_config_path)" ]; then
    value="$(json_get "$(user_config_path)" "$key" "$value")"
  fi
  if [ -f "$(state_dir)/config.json" ]; then
    value="$(json_get "$(state_dir)/config.json" "$key" "$value")"
  fi
  printf '%s\n' "$value"
}

config_get() {
  local key default env_name
  key="$1"; default="$2"; env_name="${3:-}"
  if [ -n "$env_name" ]; then
    eval "if [ -n \"\${$env_name:-}\" ]; then printf '%s\n' \"\${$env_name}\"; return 0; fi"
  fi
  config_get_raw "$key" "$default"
}

claude_model_default() {
  config_get "claude.model" "$HF_DEFAULT_CLAUDE_MODEL" "HUMANIZE_FLOW_CLAUDE_MODEL"
}

claude_permission_mode_default() {
  local raw normalized
  raw="$(config_get "claude.permission_mode" "$HF_DEFAULT_CLAUDE_PERMISSION_MODE" "HUMANIZE_FLOW_CLAUDE_PERMISSION_MODE")"
  normalized="$(normalize_claude_permission_mode "$raw")" || die "Unsupported Claude permission mode: $raw (supported: acceptEdits, auto, bypassPermissions, default, dontAsk, plan)"
  printf '%s\n' "$normalized"
}

claude_humanize_default() {
  local raw normalized
  raw="$(config_get "claude.humanize" "$HF_DEFAULT_CLAUDE_HUMANIZE" "HUMANIZE_FLOW_CLAUDE_HUMANIZE")"
  normalized="$(normalize_humanize_mode "$raw")" || die "Unsupported Claude humanize mode: $raw (supported: required, auto, off)"
  printf '%s\n' "$normalized"
}

codex_model_default() {
  config_get "codex.model" "$HF_DEFAULT_CODEX_MODEL" "HUMANIZE_FLOW_CODEX_MODEL"
}

codex_reasoning_effort_default() {
  config_get "codex.reasoning_effort" "$HF_DEFAULT_CODEX_REASONING_EFFORT" "HUMANIZE_FLOW_CODEX_REASONING_EFFORT"
}

review_sandbox_default() {
  local raw normalized
  raw="$(config_get "review.sandbox" "$HF_DEFAULT_REVIEW_SANDBOX" "HUMANIZE_FLOW_REVIEW_SANDBOX")"
  normalized="$(normalize_sandbox_mode "$raw")" || die "Unsupported review sandbox: $raw (supported: read-only, workspace-write, danger-full-access)"
  printf '%s\n' "$normalized"
}

review_yolo_default() {
  local raw normalized
  raw="$(config_get "review.yolo" "$HF_DEFAULT_REVIEW_YOLO" "HUMANIZE_FLOW_REVIEW_YOLO")"
  normalized="$(normalize_bool "$raw")" || die "Unsupported review yolo value: $raw (supported: true, false)"
  printf '%s\n' "$normalized"
}

claude_env_file_default() {
  config_get "claude.env_file" "" "HUMANIZE_FLOW_CLAUDE_ENV_FILE"
}

normalize_worker_provider() {
  case "$1" in
    claude|Claude|CLAUDE) printf 'claude\n' ;;
    codex|Codex|CODEX) printf 'codex\n' ;;
    *) return 1 ;;
  esac
}

worker_provider_default() {
  local raw normalized
  raw="$(config_get "worker.provider" "$HF_DEFAULT_WORKER_PROVIDER" "HUMANIZE_FLOW_WORKER_PROVIDER")"
  normalized="$(normalize_worker_provider "$raw")" || die "Unsupported worker provider: $raw (supported: claude, codex)"
  printf '%s\n' "$normalized"
}

worker_codex_model_default() {
  config_get "worker.codex.model" "$HF_DEFAULT_WORKER_CODEX_MODEL" "HUMANIZE_FLOW_WORKER_CODEX_MODEL"
}

worker_codex_reasoning_effort_default() {
  config_get "worker.codex.reasoning_effort" "$HF_DEFAULT_WORKER_CODEX_REASONING_EFFORT" "HUMANIZE_FLOW_WORKER_CODEX_REASONING_EFFORT"
}

yolo_max_round_default() {
  local raw
  raw="$(config_get "yolo.max_round" "$HF_DEFAULT_YOLO_MAX_ROUND" "HUMANIZE_FLOW_YOLO_MAX_ROUND")"
  case "$raw" in
    ''|*[!0-9]*) die "Unsupported yolo.max_round value: $raw (must be a positive integer)" ;;
  esac
  [ "$raw" -ge 1 ] || die "Unsupported yolo.max_round value: $raw (must be at least 1)"
  printf '%s\n' "$raw"
}

normalize_yolo_review_strategy() {
  case "$1" in
    final|review-at-end|final-review-only) printf 'final\n' ;;
    each-task|each|per-task|per_task) printf 'each-task\n' ;;
    *) return 1 ;;
  esac
}

yolo_review_strategy_default() {
  local raw normalized
  raw="$(config_get "yolo.review_strategy" "$HF_DEFAULT_YOLO_REVIEW_STRATEGY" "HUMANIZE_FLOW_YOLO_REVIEW_STRATEGY")"
  normalized="$(normalize_yolo_review_strategy "$raw")" || die "Unsupported yolo.review_strategy value: $raw (supported: final, each-task)"
  printf '%s\n' "$normalized"
}

normalize_reasoning_effort() {
  case "$1" in
    ""|low|medium|high|xhigh) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

normalize_bool() {
  case "$1" in
    true|TRUE|True|1|yes|YES|Yes|on|ON|On) printf 'true\n' ;;
    false|FALSE|False|0|no|NO|No|off|OFF|Off) printf 'false\n' ;;
    *) return 1 ;;
  esac
}

normalize_humanize_mode() {
  case "$1" in
    required|require|must|true|TRUE|True|1|yes|YES|Yes|on|ON|On) printf 'required\n' ;;
    auto|optional|prefer|preferred) printf 'auto\n' ;;
    off|none|disable|disabled|false|FALSE|False|0|no|NO|No) printf 'off\n' ;;
    *) return 1 ;;
  esac
}

normalize_claude_permission_mode() {
  case "$1" in
    acceptEdits|auto|bypassPermissions|default|dontAsk|plan) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

normalize_sandbox_mode() {
  case "$1" in
    read-only|workspace-write|danger-full-access) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

display_optional_config() {
  local value fallback
  value="$1"; fallback="$2"
  if [ -n "$value" ]; then printf '%s\n' "$value"; else printf '%s\n' "$fallback"; fi
}

language_name() {
  case "$1" in
    zh|zh-CN|zh_CN) printf 'Simplified Chinese\n' ;;
    en|en-US|en_US) printf 'English\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

normalize_language() {
  case "$1" in
    zh|zh-CN|zh_CN) printf 'zh\n' ;;
    en|en-US|en_US) printf 'en\n' ;;
    *) return 1 ;;
  esac
}

language_default() {
  local raw normalized
  raw="$(config_get "language" "$HF_DEFAULT_LANGUAGE" "HUMANIZE_FLOW_LANGUAGE")"
  normalized="$(normalize_language "$raw")" || die "Unsupported language: $raw (supported: en, zh)"
  printf '%s\n' "$normalized"
}

language_instruction() {
  local lang name
  lang="$(language_default)"
  name="$(language_name "$lang")"
  cat <<EOF
Language policy:
- Write human-facing generated artifacts in $name (language code: $lang), unless the user explicitly requests a different language in this run.
- This applies to Markdown artifacts (request.md, jira-requirement.md, plan.md, acceptance.md, bd-plan.md, questions.md), handoff prose fields (summary, assumptions, open_questions, bd.epic.title, bd.epic.description, bd.tasks[].title, bd.tasks[].description, bd.tasks[].acceptance_criteria), materialized Beads epic/task titles, descriptions, and embedded acceptance criteria, implementation summaries, review reports, pull request text, and commit message prose.
- For existing Beads tasks, preserve raw source content in bd-source.json and source.* fields, but write generated interpretation, scope, plan, acceptance criteria, and handoff bd.* prose in $name.
- Keep machine-readable literals in canonical form: JSON keys, enum values, labels, file paths, commands, API names, package names, code identifiers, and Beads IDs.
EOF
}

resolve_repo_path() {
  local path root
  path="$1"
  root="$(repo_root)"
  case "$path" in
    "") return 1 ;;
    /*) printf '%s\n' "$path" ;;
    *) printf '%s/%s\n' "$root" "$path" ;;
  esac
}

normalize_claude_env_file_value() {
  case "${1:-}" in
    ""|none|None|NONE|off|OFF|false|FALSE|disabled|DISABLED) printf '\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

load_claude_env_file() {
  local env_file entry env_entries
  env_file="${1:-}"
  [ -n "$env_file" ] || return 0
  env_file="$(resolve_repo_path "$env_file")"
  [ -f "$env_file" ] || die "Claude env file not found: $env_file"
  env_entries="$(run_python3 - "$env_file" <<'PY'
import re
import shlex
import sys
from pathlib import Path

path = Path(sys.argv[1])
key_re = re.compile(r'^[A-Za-z_][A-Za-z0-9_]*$')
for lineno, raw in enumerate(path.read_text(encoding='utf-8').splitlines(), 1):
    stripped = raw.strip()
    if not stripped or stripped.startswith('#'):
        continue
    if stripped.startswith('export '):
        stripped = stripped[len('export '):].lstrip()
    if '=' not in stripped:
        raise SystemExit(f'{path}:{lineno}: expected KEY=VALUE')
    key, value = stripped.split('=', 1)
    key = key.strip()
    if not key_re.match(key):
        raise SystemExit(f'{path}:{lineno}: invalid environment variable name: {key}')
    try:
        parsed = shlex.split(value, comments=True, posix=True)
    except ValueError as exc:
        raise SystemExit(f'{path}:{lineno}: invalid quoted value: {exc}')
    if len(parsed) > 1:
        raise SystemExit(f'{path}:{lineno}: unquoted whitespace is not supported; quote the value')
    value = parsed[0] if parsed else ''
    if '\n' in value or '\r' in value:
        raise SystemExit(f'{path}:{lineno}: multiline values are not supported')
    print(f'{key}={value}')
PY
)" || die "Could not parse Claude env file: $env_file"
  while IFS= read -r entry; do
    [ -n "$entry" ] || continue
    export "$entry"
  done <<EOF
$env_entries
EOF
}

run_codex_exec() {
  local sandbox="" yolo="false" prompt model reasoning
  local args
  while [ $# -gt 0 ]; do
    case "${1:-}" in
      --sandbox)
        shift
        sandbox="${1:-}"
        yolo="false"
        shift
        ;;
      --yolo)
        yolo="true"
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        break
        ;;
    esac
  done
  prompt="${1:-}"
  model="$(codex_model_default)"
  reasoning="$(codex_reasoning_effort_default)"
  reasoning="$(normalize_reasoning_effort "$reasoning")" || die "Unsupported Codex reasoning effort: $reasoning (supported: low, medium, high, xhigh)"

  args=(exec)
  if [ "$yolo" = "true" ]; then
    args+=(--dangerously-bypass-approvals-and-sandbox)
  elif [ -n "$sandbox" ]; then
    args+=(--sandbox "$sandbox")
  fi
  if [ -n "$model" ]; then args+=(--model "$model"); fi
  if [ -n "$reasoning" ]; then args+=(-c "model_reasoning_effort=\"$reasoning\""); fi

  if [ -n "${HUMANIZE_FLOW_CODEX_ARGS:-}" ]; then
    # shellcheck disable=SC2206
    # shellcheck disable=SC2086
    codex "${args[@]}" ${HUMANIZE_FLOW_CODEX_ARGS} "$prompt"
  else
    codex "${args[@]}" "$prompt"
  fi
}

run_codex_worker_exec() {
  local prompt model reasoning
  local args
  prompt="${1:-}"
  model="$(worker_codex_model_default)"
  [ -n "$model" ] || die "worker.codex.model cannot be empty."
  reasoning="$(worker_codex_reasoning_effort_default)"
  reasoning="$(normalize_reasoning_effort "$reasoning")" || die "Unsupported worker Codex reasoning effort: $reasoning (supported: low, medium, high, xhigh)"
  [ -n "$reasoning" ] || die "worker.codex.reasoning_effort cannot be empty."

  args=(exec --dangerously-bypass-approvals-and-sandbox --model "$model" -c "model_reasoning_effort=\"$reasoning\"")
  if [ -n "${HUMANIZE_FLOW_WORKER_CODEX_ARGS:-}" ]; then
    # shellcheck disable=SC2206
    # shellcheck disable=SC2086
    codex "${args[@]}" ${HUMANIZE_FLOW_WORKER_CODEX_ARGS} "$prompt"
  else
    codex "${args[@]}" "$prompt"
  fi
}

format_claude_stream_json() {
  run_python3 -c "$(cat <<'PY'
import json
import sys

def text_from_content(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for item in content:
            if isinstance(item, dict):
                if item.get('type') == 'text' and item.get('text'):
                    parts.append(str(item['text']))
                elif item.get('text'):
                    parts.append(str(item['text']))
            elif isinstance(item, str):
                parts.append(item)
        return ''.join(parts)
    return ''

def tool_name(block):
    if not isinstance(block, dict):
        return ''
    return block.get('name') or block.get('tool_name') or block.get('type') or ''

seen_partial = ''
for raw in sys.stdin:
    line = raw.rstrip('\n')
    if not line:
        continue
    try:
        event = json.loads(line)
    except Exception:
        print(line, flush=True)
        continue

    event_type = event.get('type') or event.get('event') or ''
    subtype = event.get('subtype') or ''

    if event_type == 'system':
        if subtype:
            print(f'[system] {subtype}', flush=True)
        continue

    if event_type in {'assistant', 'user'}:
        message = event.get('message') or event
        content = message.get('content')
        if isinstance(content, list):
            for block in content:
                if not isinstance(block, dict):
                    continue
                btype = block.get('type') or ''
                if btype == 'text':
                    text = block.get('text') or ''
                    if text:
                        print(text, flush=True)
                elif btype == 'tool_use':
                    name = tool_name(block)
                    tool_id = block.get('id') or ''
                    suffix = f' {tool_id}' if tool_id else ''
                    print(f'[tool] {name}{suffix}', flush=True)
                elif btype == 'tool_result':
                    tool_id = block.get('tool_use_id') or ''
                    status = 'error' if block.get('is_error') else 'ok'
                    prefix = f'[tool-result] {tool_id} {status}'.strip()
                    result_text = text_from_content(block.get('content'))
                    print(prefix, flush=True)
                    if result_text:
                        print(result_text, flush=True)
        else:
            text = text_from_content(content)
            if text:
                print(text, flush=True)
        continue

    if event_type in {'content_block_start', 'content_block_delta', 'content_block_stop'}:
        block = event.get('content_block') or {}
        delta = event.get('delta') or {}
        if event_type == 'content_block_start':
            if isinstance(block, dict) and block.get('type') == 'tool_use':
                print(f'[tool] {tool_name(block)}', flush=True)
            continue
        text = delta.get('text') or delta.get('partial_json') or ''
        if text and text != seen_partial:
            print(text, end='' if delta.get('text') else '\n', flush=True)
            seen_partial = text
        if event_type == 'content_block_stop':
            seen_partial = ''
        continue

    if event_type in {'hook', 'hook_event'} or subtype.endswith('_hook'):
        name = event.get('hook_name') or event.get('name') or subtype or 'hook'
        print(f'[hook] {name}', flush=True)
        continue

    if event_type == 'result':
        status = subtype or event.get('status') or 'done'
        print(f'\n[result] {status}', flush=True)
        result = event.get('result')
        if isinstance(result, str) and result:
            print(result, flush=True)
        cost = event.get('total_cost_usd')
        duration = event.get('duration_ms')
        if cost is not None or duration is not None:
            bits = []
            if duration is not None:
                bits.append(f'duration_ms={duration}')
            if cost is not None:
                bits.append(f'cost_usd={cost}')
            print('[usage] ' + ' '.join(bits), flush=True)
        continue

    label = event_type or subtype or 'event'
    print(f'[{label}] {json.dumps(event, ensure_ascii=False)}', flush=True)
PY
)"
}

cmd_config() {
  local sub key value normalized file
  sub="${1:-show}"
  if [ $# -gt 0 ]; then shift; fi
  file="$(user_config_path)"
  case "$sub" in
    show)
      cat <<EOF
user_config: $file
language: $(language_default)
claude.model: $(claude_model_default)
claude.permission_mode: $(claude_permission_mode_default)
claude.humanize: $(claude_humanize_default)
claude.env_file: $(display_optional_config "$(claude_env_file_default)" "(disabled)")
worker.provider: $(worker_provider_default)
worker.codex.model: $(worker_codex_model_default)
worker.codex.reasoning_effort: $(worker_codex_reasoning_effort_default)
yolo.max_round: $(yolo_max_round_default)
yolo.review_strategy: $(yolo_review_strategy_default)
codex.model: $(display_optional_config "$(codex_model_default)" "(codex default)")
codex.reasoning_effort: $(display_optional_config "$(codex_reasoning_effort_default)" "(codex default)")
review.yolo: $(review_yolo_default)
review.sandbox: $(review_sandbox_default)
EOF
      ;;
    get)
      key="${1:-}"; [ -n "$key" ] || die "Usage: humanize-flow config get KEY"
      case "$key" in
        language) language_default ;;
        claude.model) claude_model_default ;;
        claude.permission_mode) claude_permission_mode_default ;;
        claude.humanize) claude_humanize_default ;;
        claude.env_file) claude_env_file_default ;;
        worker.provider) worker_provider_default ;;
        worker.codex.model) worker_codex_model_default ;;
        worker.codex.reasoning_effort) worker_codex_reasoning_effort_default ;;
        yolo.max_round) yolo_max_round_default ;;
        yolo.review_strategy) yolo_review_strategy_default ;;
        codex.model) codex_model_default ;;
        codex.reasoning_effort) codex_reasoning_effort_default ;;
        review.yolo) review_yolo_default ;;
        review.sandbox) review_sandbox_default ;;
        *) config_get_raw "$key" "" ;;
      esac
      ;;
    set)
      key="${1:-}"; value="${2:-}"
      [ -n "$key" ] && [ -n "$value" ] || die "Usage: humanize-flow config set KEY VALUE"
      case "$key" in
        language)
          normalized="$(normalize_language "$value")" || die "Unsupported language: $value (supported: en, zh)"
          value="$normalized"
          ;;
        codex.reasoning_effort)
          normalized="$(normalize_reasoning_effort "$value")" || die "Unsupported Codex reasoning effort: $value (supported: low, medium, high, xhigh)"
          value="$normalized"
          ;;
        review.sandbox)
          normalized="$(normalize_sandbox_mode "$value")" || die "Unsupported review sandbox: $value (supported: read-only, workspace-write, danger-full-access)"
          value="$normalized"
          ;;
        review.yolo)
          normalized="$(normalize_bool "$value")" || die "Unsupported review yolo value: $value (supported: true, false)"
          value="$normalized"
          ;;
        claude.humanize)
          normalized="$(normalize_humanize_mode "$value")" || die "Unsupported Claude humanize mode: $value (supported: required, auto, off)"
          value="$normalized"
          ;;
        claude.permission_mode)
          normalized="$(normalize_claude_permission_mode "$value")" || die "Unsupported Claude permission mode: $value (supported: acceptEdits, auto, bypassPermissions, default, dontAsk, plan)"
          value="$normalized"
          ;;
        claude.env_file)
          normalized="$(normalize_claude_env_file_value "$value")"
          value="$normalized"
          ;;
        worker.provider)
          normalized="$(normalize_worker_provider "$value")" || die "Unsupported worker provider: $value (supported: claude, codex)"
          value="$normalized"
          ;;
        worker.codex.reasoning_effort)
          normalized="$(normalize_reasoning_effort "$value")" || die "Unsupported worker Codex reasoning effort: $value (supported: low, medium, high, xhigh)"
          [ -n "$normalized" ] || die "worker.codex.reasoning_effort cannot be empty."
          value="$normalized"
          ;;
        yolo.max_round)
          case "$value" in
            ''|*[!0-9]*) die "Unsupported yolo.max_round value: $value (must be a positive integer)" ;;
          esac
          [ "$value" -ge 1 ] || die "Unsupported yolo.max_round value: $value (must be at least 1)"
          ;;
        yolo.review_strategy)
          normalized="$(normalize_yolo_review_strategy "$value")" || die "Unsupported yolo.review_strategy value: $value (supported: final, each-task)"
          value="$normalized"
          ;;
        claude.model|codex.model|worker.codex.model) ;;
        *) die "Unsupported config key: $key" ;;
      esac
      json_set "$file" "$key" "$value"
      success "set $key=$value in $file"
      ;;
    --help|-h|help)
      cat <<'EOF'
Usage:
  humanize-flow config show
  humanize-flow config get language
  humanize-flow config set language zh
  humanize-flow config get claude.model
  humanize-flow config set claude.model claude-sonnet-4-6
  humanize-flow config set claude.permission_mode bypassPermissions
  humanize-flow config get claude.humanize
  humanize-flow config set claude.humanize required
  humanize-flow config get claude.env_file
  humanize-flow config set claude.env_file .humanize-flow/claude-provider.env
  humanize-flow config get worker.provider
  humanize-flow config set worker.provider codex
  humanize-flow config get worker.codex.model
  humanize-flow config set worker.codex.model gpt-5.5
  humanize-flow config get worker.codex.reasoning_effort
  humanize-flow config set worker.codex.reasoning_effort medium
  humanize-flow config get yolo.max_round
  humanize-flow config set yolo.max_round 5
  humanize-flow config get yolo.review_strategy
  humanize-flow config set yolo.review_strategy final
  humanize-flow config get codex.model
  humanize-flow config set codex.model gpt-5.5
  humanize-flow config get codex.reasoning_effort
  humanize-flow config set codex.reasoning_effort high
  humanize-flow config get review.yolo
  humanize-flow config set review.yolo false
  humanize-flow config get review.sandbox
  humanize-flow config set review.sandbox workspace-write
EOF
      ;;
    *) die "Unknown config command: $sub" ;;
  esac
}

cmd_i18n() {
  local lang
  lang="${1:-}"
  case "$lang" in
    "")
      printf '%s\n' "$(language_default)"
      ;;
    --help|-h|help)
      cat <<'EOF'
Usage:
  humanize-flow i18n
  humanize-flow i18n en
  humanize-flow i18n zh

Sets the global language for human-facing generated artifacts.
EOF
      ;;
    en|zh|zh-CN|zh_CN|en-US|en_US)
      lang="$(normalize_language "$lang")"
      json_set "$(user_config_path)" "language" "$lang"
      success "set language=$lang in $(user_config_path)"
      ;;
    *)
      die "Unsupported language: $lang (supported: en, zh)"
      ;;
  esac
}

worker_skill_file() {
  local p
  p="$DIST_ROOT/skills/claude/humanize-flow-worker/SKILL.md"
  if [ -f "$p" ]; then printf '%s\n' "$p"; return 0; fi
  p="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/humanize-flow-worker/SKILL.md"
  if [ -f "$p" ]; then printf '%s\n' "$p"; return 0; fi
  p="$(repo_root)/.claude/skills/humanize-flow-worker/SKILL.md"
  if [ -f "$p" ]; then printf '%s\n' "$p"; return 0; fi
  return 1
}

humanize_integration_path() {
  local p
  if command_exists humanize; then command -v humanize; return 0; fi
  p="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins"
  if [ -d "$p" ]; then
    p="$(find "$p" -type d -name humanize 2>/dev/null | head -n 1 || true)"
    if [ -n "$p" ]; then printf '%s\n' "$p"; return 0; fi
  fi
  p="$HOME/.codex/skills/humanize/scripts/setup-rlcr-loop.sh"
  if [ -x "$p" ]; then printf '%s\n' "$p"; return 0; fi
  return 1
}

ensure_humanize_available() {
  local mode found
  mode="$1"
  [ "$mode" = "required" ] || return 0
  found="$(humanize_integration_path 2>/dev/null || true)"
  [ -n "$found" ] || die "Claude humanize mode is required, but no humanize command, Claude plugin, or Codex humanize skill script was detected. Install humanize or run with --humanize-mode off / config set claude.humanize off."
}

humanize_worker_instruction() {
  local mode plan_path plan_display integration_path
  mode="$1"; plan_path="$2"
  if [ -n "$plan_path" ]; then plan_display="$(repo_relative_path "$plan_path")"; else plan_display="not-found"; fi
  integration_path="$(humanize_integration_path 2>/dev/null || true)"
  case "$mode" in
    required)
      cat <<EOF
Claude humanize mode: required
Humanize integration path detected before launch: ${integration_path:-not-detected}
Plan path for RLCR: $plan_display

Required humanize behavior:
- Before implementation, start humanize/RLCR inside this Claude Code session using the approved plan path above.
- Prefer the installed Claude plugin command: /humanize:start-rlcr-loop $plan_display --yolo
- If the slash command is unavailable but a humanize script is available, use the installed setup-rlcr-loop.sh equivalent for the same plan.
- If humanize/RLCR cannot be started, stop without editing code and report the blocker.
- Do not silently emulate humanize discipline in required mode.
EOF
      ;;
    auto)
      cat <<EOF
Claude humanize mode: auto
Humanize integration path detected before launch: ${integration_path:-not-detected}
Plan path for RLCR: $plan_display

Auto humanize behavior:
- Use humanize/RLCR for complex implementation when it is installed and safe in this Claude Code context.
- Prefer: /humanize:start-rlcr-loop $plan_display --yolo
- If the plan path is not-found, humanize is unavailable, or this is a tiny safe edit, implement directly while preserving the review boundary.
EOF
      ;;
    off)
      cat <<EOF
Claude humanize mode: off
Humanize integration is disabled for this run.

Required behavior:
- Do not start humanize/RLCR.
- Implement directly from the approved handoff, plan, and acceptance criteria.
- Preserve the Codex review boundary.
EOF
      ;;
  esac
}

