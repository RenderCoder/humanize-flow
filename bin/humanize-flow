except Exception:
    raise SystemExit(1)
execution = data.get('execution') or {}
if isinstance(execution, dict) and execution.get('current_bd_id'):
    print(execution['current_bd_id'])
    raise SystemExit(0)
source = data.get('source') or {}
if isinstance(source, dict) and source.get('bd_id'):
    print(source['bd_id'])
    raise SystemExit(0)
bd = data.get('bd') or {}
epic = bd.get('epic') or {}
if isinstance(epic, dict) and epic.get('bd_id'):
    print(epic['bd_id'])
    raise SystemExit(0)
for task in bd.get('tasks') or []:
    if isinstance(task, dict) and task.get('bd_id'):
        print(task['bd_id'])
        raise SystemExit(0)
raise SystemExit(1)
PY
}

