#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

HF_VERSION="0.5.0"
HF_NAME="humanize-flow"
HF_DEFAULT_CLAUDE_MODEL="claude-sonnet-4-6"
HF_DEFAULT_CLAUDE_PERMISSION_MODE="auto"
HF_DEFAULT_CLAUDE_HUMANIZE="required"
HF_DEFAULT_LANGUAGE="en"
HF_DEFAULT_CODEX_MODEL=""
HF_DEFAULT_CODEX_REASONING_EFFORT=""
HF_DEFAULT_REVIEW_SANDBOX="danger-full-access"
HF_DEFAULT_REVIEW_YOLO="true"

log() { printf '%s\n' "$*"; }
info() { printf '[humanize-flow] %s\n' "$*"; }
warn() { printf '[humanize-flow] WARN: %s\n' "$*" >&2; }
die() { printf '[humanize-flow] ERROR: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
humanize-flow - orchestrate Codex planning/review, Claude Code work, Beads tasks, and required-by-default humanize loops.

Usage:
  humanize-flow <command> [options]

Commands:
  help                         Show this help.
  version                      Show version.
  paths                        Show resolved installation paths.
  doctor                       Check local tools and skill installation.
  init [--with-bd]             Initialize .humanize-flow and docs/humanize-flow in the current git repo.
  plan --slug S --from FILE    Run Codex planner for a request file.
  plan --slug S --request TXT  Run Codex planner for inline request text.
  plan-from-bd BD_ID [--slug S]
                               Run Codex planner from an existing Beads task ID.
  from-bd BD_ID [--slug S]     Alias for plan-from-bd.
  approve SLUG [--materialize-bd]
                               Mark a handoff as approved; optionally create Beads tasks from it.
  materialize-bd SLUG          Create Beads epic/tasks from an approved handoff manifest.
  run BD_ID_OR_SLUG [options]  Run Claude Code worker for one Beads task.
  run-next                     Pick a ready Beads task, asking for Epic/task selection when needed, then run it.
  review BD_ID_OR_SLUG         Run Codex reviewer for one Beads task.
  review-feedback BD_ID_OR_SLUG [--note TEXT|--from FILE] [--review FILE]
                               Merge human review/test feedback into a new Codex review report.
  commit [--yes]               Use Codex to select changes, write a Lore message, and commit.
  push [--remote NAME]         Push the current branch, prompting for a remote when needed.
  pr [options]                 Use Codex to draft a professional PR and create it with GitHub CLI.
  i18n [LANG]                  Show or set artifact language (en, zh).
  status                       Show handoff and Beads queue status.
  config get KEY               Show resolved config value.
  config set KEY VALUE         Set a global config value.
  config show                  Show resolved Humanize Flow config.

Environment:
  HUMANIZE_FLOW_HOME           Distribution root. Default: ~/.local/share/humanize-flow when installed.
  HUMANIZE_FLOW_CLAUDE_ARGS    Extra Claude CLI args. Default: empty.
  HUMANIZE_FLOW_CLAUDE_MODEL   Override Claude Code model for worker runs.
  HUMANIZE_FLOW_CLAUDE_PERMISSION_MODE
                               Override Claude Code permission mode for worker runs.
  HUMANIZE_FLOW_CLAUDE_HUMANIZE
                               Override Claude Code humanize mode (required, auto, off).
  HUMANIZE_FLOW_CODEX_MODEL    Override Codex model for planner/review/commit/pr runs.
  HUMANIZE_FLOW_CODEX_REASONING_EFFORT
                               Override Codex reasoning effort for planner/review/commit/pr runs.
  HUMANIZE_FLOW_REVIEW_SANDBOX
                               Override Codex sandbox for review/review-feedback runs.
  HUMANIZE_FLOW_REVIEW_YOLO    Override Codex yolo mode for review/review-feedback runs.
  HUMANIZE_FLOW_LANGUAGE       Override artifact language for one command.
  HUMANIZE_FLOW_CODEX_ARGS     Extra Codex exec args. Default: empty.
  HUMANIZE_FLOW_NONINTERACTIVE Set to 1 to avoid interactive prompts in scripts.

Examples:
  humanize-flow doctor
  humanize-flow init --with-bd
  humanize-flow plan --slug undo-redo --from docs/request.md
  humanize-flow plan-from-bd bd-1234 --slug undo-redo
  humanize-flow i18n zh
  humanize-flow approve undo-redo --materialize-bd
  humanize-flow run-next
  humanize-flow run bd-a1b2 --yolo
  humanize-flow review bd-a1b2
  humanize-flow review-feedback bd-a1b2
  humanize-flow commit
  humanize-flow push
  humanize-flow pr --base main
EOF
}

script_dir() { CDPATH= cd -- "$(dirname -- "$0")" && pwd; }

resolve_dist_root() {
  local sd parent
  sd="$(script_dir)"
  parent="$(CDPATH= cd -- "$sd/.." && pwd)"
  if [ -d "$parent/skills" ] && [ -d "$parent/schemas" ]; then
    printf '%s\n' "$parent"
    return 0
  fi
  if [ -n "${HUMANIZE_FLOW_HOME:-}" ]; then
    printf '%s\n' "$HUMANIZE_FLOW_HOME"
    return 0
  fi
  printf '%s\n' "$HOME/.local/share/humanize-flow"
}

DIST_ROOT="$(resolve_dist_root)"

repo_root() { git rev-parse --show-toplevel 2>/dev/null || pwd; }
require_git_repo() { git rev-parse --show-toplevel >/dev/null 2>&1 || die "Run this command inside a git repository."; }
command_exists() { command -v "$1" >/dev/null 2>&1; }
timestamp() { date -u +%Y%m%d-%H%M%S; }
iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
state_dir() { printf '%s/.humanize-flow\n' "$(repo_root)"; }
docs_dir() { printf '%s/docs/humanize-flow\n' "$(repo_root)"; }
handoff_path() { printf '%s/handoffs/%s.json\n' "$(state_dir)" "$1"; }
user_config_path() { printf '%s/humanize-flow/config.json\n' "${XDG_CONFIG_HOME:-$HOME/.config}"; }

repo_relative_path() {
  local path root
  path="$1"
  root="$(repo_root)"
  case "$path" in
    "$root"/*) printf '%s\n' "${path#"$root"/}" ;;
    *) printf '%s\n' "$path" ;;
  esac
}

slugify() {
  python3 - "$@" <<'PY'
import re, sys
text = " ".join(sys.argv[1:]).strip().lower()
text = re.sub(r"[^a-z0-9]+", "-", text).strip("-")
print((text[:80].strip("-") or "request"))
PY
}

planner_skill_hint() { printf '%s\n' '$humanize-flow-planner'; }
bd_planner_skill_hint() { printf '%s\n' '$humanize-flow-bd-planner'; }
reviewer_skill_hint() { printf '%s\n' '$humanize-flow-reviewer'; }

json_get() {
  local file key default
  file="$1"; key="$2"; default="$3"
  python3 - "$file" "$key" "$default" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
key = sys.argv[2]
default = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    print(default)
    raise SystemExit(0)
value = data
for part in key.split('.'):
    if isinstance(value, dict) and part in value:
        value = value[part]
    else:
        print(default)
        raise SystemExit(0)
if isinstance(value, bool):
    print('true' if value else 'false')
elif value is None:
    print(default)
else:
    print(value)
PY
}

json_set() {
  local file key value
  file="$1"; key="$2"; value="$3"
  mkdir -p "$(dirname "$file")"
  python3 - "$file" "$key" "$value" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    data = {}
if not isinstance(data, dict):
    data = {}
cursor = data
parts = key.split('.')
for part in parts[:-1]:
    next_value = cursor.get(part)
    if not isinstance(next_value, dict):
        next_value = {}
        cursor[part] = next_value
    cursor = next_value
cursor[parts[-1]] = value
path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + '\n', encoding='utf-8')
PY
}

config_get_raw() {
  local key default value
  key="$1"; default="$2"
  value="$default"
  if [ -f "$(user_config_path)" ]; then
    value="$(json_get "$(user_config_path)" "$key" "$value")"
  fi
  if [ -f "$(state_dir)/config.json" ]; then
    value="$(json_get "$(state_dir)/config.json" "$key" "$value")"
  fi
  printf '%s\n' "$value"
}

config_get() {
  local key default env_name
  key="$1"; default="$2"; env_name="${3:-}"
  if [ -n "$env_name" ]; then
    eval "if [ -n \"\${$env_name:-}\" ]; then printf '%s\n' \"\${$env_name}\"; return 0; fi"
  fi
  config_get_raw "$key" "$default"
}

claude_model_default() {
  config_get "claude.model" "$HF_DEFAULT_CLAUDE_MODEL" "HUMANIZE_FLOW_CLAUDE_MODEL"
}

claude_permission_mode_default() {
  config_get "claude.permission_mode" "$HF_DEFAULT_CLAUDE_PERMISSION_MODE" "HUMANIZE_FLOW_CLAUDE_PERMISSION_MODE"
}

claude_humanize_default() {
  local raw normalized
  raw="$(config_get "claude.humanize" "$HF_DEFAULT_CLAUDE_HUMANIZE" "HUMANIZE_FLOW_CLAUDE_HUMANIZE")"
  normalized="$(normalize_humanize_mode "$raw")" || die "Unsupported Claude humanize mode: $raw (supported: required, auto, off)"
  printf '%s\n' "$normalized"
}

codex_model_default() {
  config_get "codex.model" "$HF_DEFAULT_CODEX_MODEL" "HUMANIZE_FLOW_CODEX_MODEL"
}

codex_reasoning_effort_default() {
  config_get "codex.reasoning_effort" "$HF_DEFAULT_CODEX_REASONING_EFFORT" "HUMANIZE_FLOW_CODEX_REASONING_EFFORT"
}

review_sandbox_default() {
  local raw normalized
  raw="$(config_get "review.sandbox" "$HF_DEFAULT_REVIEW_SANDBOX" "HUMANIZE_FLOW_REVIEW_SANDBOX")"
  normalized="$(normalize_sandbox_mode "$raw")" || die "Unsupported review sandbox: $raw (supported: read-only, workspace-write, danger-full-access)"
  printf '%s\n' "$normalized"
}

review_yolo_default() {
  local raw normalized
  raw="$(config_get "review.yolo" "$HF_DEFAULT_REVIEW_YOLO" "HUMANIZE_FLOW_REVIEW_YOLO")"
  normalized="$(normalize_bool "$raw")" || die "Unsupported review yolo value: $raw (supported: true, false)"
  printf '%s\n' "$normalized"
}

normalize_reasoning_effort() {
  case "$1" in
    ""|low|medium|high|xhigh) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

normalize_bool() {
  case "$1" in
    true|TRUE|True|1|yes|YES|Yes|on|ON|On) printf 'true\n' ;;
    false|FALSE|False|0|no|NO|No|off|OFF|Off) printf 'false\n' ;;
    *) return 1 ;;
  esac
}

normalize_humanize_mode() {
  case "$1" in
    required|require|must|true|TRUE|True|1|yes|YES|Yes|on|ON|On) printf 'required\n' ;;
    auto|optional|prefer|preferred) printf 'auto\n' ;;
    off|none|disable|disabled|false|FALSE|False|0|no|NO|No) printf 'off\n' ;;
    *) return 1 ;;
  esac
}

normalize_sandbox_mode() {
  case "$1" in
    read-only|workspace-write|danger-full-access) printf '%s\n' "$1" ;;
    *) return 1 ;;
  esac
}

display_optional_config() {
  local value fallback
  value="$1"; fallback="$2"
  if [ -n "$value" ]; then printf '%s\n' "$value"; else printf '%s\n' "$fallback"; fi
}

language_name() {
  case "$1" in
    zh|zh-CN|zh_CN) printf 'Simplified Chinese\n' ;;
    en|en-US|en_US) printf 'English\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

normalize_language() {
  case "$1" in
    zh|zh-CN|zh_CN) printf 'zh\n' ;;
    en|en-US|en_US) printf 'en\n' ;;
    *) return 1 ;;
  esac
}

language_default() {
  local raw normalized
  raw="$(config_get "language" "$HF_DEFAULT_LANGUAGE" "HUMANIZE_FLOW_LANGUAGE")"
  normalized="$(normalize_language "$raw")" || die "Unsupported language: $raw (supported: en, zh)"
  printf '%s\n' "$normalized"
}

language_instruction() {
  local lang name
  lang="$(language_default)"
  name="$(language_name "$lang")"
  cat <<EOF
Language policy:
- Write human-facing generated artifacts in $name (language code: $lang), unless the user explicitly requests a different language in this run.
- This applies to Markdown artifacts (request.md, plan.md, acceptance.md, bd-plan.md, questions.md), handoff prose fields (summary, assumptions, open_questions, bd.epic.title, bd.epic.description, bd.tasks[].title, bd.tasks[].description, bd.tasks[].acceptance_criteria), materialized Beads epic/task titles, descriptions, and embedded acceptance criteria, implementation summaries, review reports, pull request text, and commit message prose.
- For existing Beads tasks, preserve raw source content in bd-source.json and source.* fields, but write generated interpretation, scope, plan, acceptance criteria, and handoff bd.* prose in $name.
- Keep machine-readable literals in canonical form: JSON keys, enum values, labels, file paths, commands, API names, package names, code identifiers, and Beads IDs.
EOF
}

run_codex_exec() {
  local sandbox="" yolo="false" prompt model reasoning
  local args
  while [ $# -gt 0 ]; do
    case "${1:-}" in
      --sandbox)
        shift
        sandbox="${1:-}"
        yolo="false"
        shift
        ;;
      --yolo)
        yolo="true"
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        break
        ;;
    esac
  done
  prompt="${1:-}"
  model="$(codex_model_default)"
  reasoning="$(codex_reasoning_effort_default)"
  reasoning="$(normalize_reasoning_effort "$reasoning")" || die "Unsupported Codex reasoning effort: $reasoning (supported: low, medium, high, xhigh)"

  args=(exec)
  if [ "$yolo" = "true" ]; then
    args+=(--dangerously-bypass-approvals-and-sandbox)
  elif [ -n "$sandbox" ]; then
    args+=(--sandbox "$sandbox")
  fi
  if [ -n "$model" ]; then args+=(--model "$model"); fi
  if [ -n "$reasoning" ]; then args+=(-c "model_reasoning_effort=\"$reasoning\""); fi

  if [ -n "${HUMANIZE_FLOW_CODEX_ARGS:-}" ]; then
    # shellcheck disable=SC2206
    # shellcheck disable=SC2086
    codex "${args[@]}" ${HUMANIZE_FLOW_CODEX_ARGS} "$prompt"
  else
    codex "${args[@]}" "$prompt"
  fi
}

format_claude_stream_json() {
  python3 -c "$(cat <<'PY'
import json
import sys

def text_from_content(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts = []
        for item in content:
            if isinstance(item, dict):
                if item.get('type') == 'text' and item.get('text'):
                    parts.append(str(item['text']))
                elif item.get('text'):
                    parts.append(str(item['text']))
            elif isinstance(item, str):
                parts.append(item)
        return ''.join(parts)
    return ''

def tool_name(block):
    if not isinstance(block, dict):
        return ''
    return block.get('name') or block.get('tool_name') or block.get('type') or ''

seen_partial = ''
for raw in sys.stdin:
    line = raw.rstrip('\n')
    if not line:
        continue
    try:
        event = json.loads(line)
    except Exception:
        print(line, flush=True)
        continue

    event_type = event.get('type') or event.get('event') or ''
    subtype = event.get('subtype') or ''

    if event_type == 'system':
        if subtype:
            print(f'[system] {subtype}', flush=True)
        continue

    if event_type in {'assistant', 'user'}:
        message = event.get('message') or event
        content = message.get('content')
        if isinstance(content, list):
            for block in content:
                if not isinstance(block, dict):
                    continue
                btype = block.get('type') or ''
                if btype == 'text':
                    text = block.get('text') or ''
                    if text:
                        print(text, flush=True)
                elif btype == 'tool_use':
                    name = tool_name(block)
                    tool_id = block.get('id') or ''
                    suffix = f' {tool_id}' if tool_id else ''
                    print(f'[tool] {name}{suffix}', flush=True)
                elif btype == 'tool_result':
                    tool_id = block.get('tool_use_id') or ''
                    status = 'error' if block.get('is_error') else 'ok'
                    prefix = f'[tool-result] {tool_id} {status}'.strip()
                    result_text = text_from_content(block.get('content'))
                    print(prefix, flush=True)
                    if result_text:
                        print(result_text, flush=True)
        else:
            text = text_from_content(content)
            if text:
                print(text, flush=True)
        continue

    if event_type in {'content_block_start', 'content_block_delta', 'content_block_stop'}:
        block = event.get('content_block') or {}
        delta = event.get('delta') or {}
        if event_type == 'content_block_start':
            if isinstance(block, dict) and block.get('type') == 'tool_use':
                print(f'[tool] {tool_name(block)}', flush=True)
            continue
        text = delta.get('text') or delta.get('partial_json') or ''
        if text and text != seen_partial:
            print(text, end='' if delta.get('text') else '\n', flush=True)
            seen_partial = text
        if event_type == 'content_block_stop':
            seen_partial = ''
        continue

    if event_type in {'hook', 'hook_event'} or subtype.endswith('_hook'):
        name = event.get('hook_name') or event.get('name') or subtype or 'hook'
        print(f'[hook] {name}', flush=True)
        continue

    if event_type == 'result':
        status = subtype or event.get('status') or 'done'
        print(f'\n[result] {status}', flush=True)
        result = event.get('result')
        if isinstance(result, str) and result:
            print(result, flush=True)
        cost = event.get('total_cost_usd')
        duration = event.get('duration_ms')
        if cost is not None or duration is not None:
            bits = []
            if duration is not None:
                bits.append(f'duration_ms={duration}')
            if cost is not None:
                bits.append(f'cost_usd={cost}')
            print('[usage] ' + ' '.join(bits), flush=True)
        continue

    label = event_type or subtype or 'event'
    print(f'[{label}] {json.dumps(event, ensure_ascii=False)}', flush=True)
PY
)"
}

cmd_config() {
  local sub key value normalized file
  sub="${1:-show}"
  if [ $# -gt 0 ]; then shift; fi
  file="$(user_config_path)"
  case "$sub" in
    show)
      cat <<EOF
user_config: $file
language: $(language_default)
claude.model: $(claude_model_default)
claude.permission_mode: $(claude_permission_mode_default)
claude.humanize: $(claude_humanize_default)
codex.model: $(display_optional_config "$(codex_model_default)" "(codex default)")
codex.reasoning_effort: $(display_optional_config "$(codex_reasoning_effort_default)" "(codex default)")
review.yolo: $(review_yolo_default)
review.sandbox: $(review_sandbox_default)
EOF
      ;;
    get)
      key="${1:-}"; [ -n "$key" ] || die "Usage: humanize-flow config get KEY"
      case "$key" in
        language) language_default ;;
        claude.model) claude_model_default ;;
        claude.permission_mode) claude_permission_mode_default ;;
        claude.humanize) claude_humanize_default ;;
        codex.model) codex_model_default ;;
        codex.reasoning_effort) codex_reasoning_effort_default ;;
        review.yolo) review_yolo_default ;;
        review.sandbox) review_sandbox_default ;;
        *) config_get_raw "$key" "" ;;
      esac
      ;;
    set)
      key="${1:-}"; value="${2:-}"
      [ -n "$key" ] && [ -n "$value" ] || die "Usage: humanize-flow config set KEY VALUE"
      case "$key" in
        language)
          normalized="$(normalize_language "$value")" || die "Unsupported language: $value (supported: en, zh)"
          value="$normalized"
          ;;
        codex.reasoning_effort)
          normalized="$(normalize_reasoning_effort "$value")" || die "Unsupported Codex reasoning effort: $value (supported: low, medium, high, xhigh)"
          value="$normalized"
          ;;
        review.sandbox)
          normalized="$(normalize_sandbox_mode "$value")" || die "Unsupported review sandbox: $value (supported: read-only, workspace-write, danger-full-access)"
          value="$normalized"
          ;;
        review.yolo)
          normalized="$(normalize_bool "$value")" || die "Unsupported review yolo value: $value (supported: true, false)"
          value="$normalized"
          ;;
        claude.humanize)
          normalized="$(normalize_humanize_mode "$value")" || die "Unsupported Claude humanize mode: $value (supported: required, auto, off)"
          value="$normalized"
          ;;
        claude.model|claude.permission_mode|codex.model) ;;
        *) die "Unsupported config key: $key" ;;
      esac
      json_set "$file" "$key" "$value"
      info "set $key=$value in $file"
      ;;
    --help|-h|help)
      cat <<'EOF'
Usage:
  humanize-flow config show
  humanize-flow config get language
  humanize-flow config set language zh
  humanize-flow config get claude.model
  humanize-flow config set claude.model claude-sonnet-4-6
  humanize-flow config set claude.permission_mode auto
  humanize-flow config get claude.humanize
  humanize-flow config set claude.humanize required
  humanize-flow config get codex.model
  humanize-flow config set codex.model gpt-5.5
  humanize-flow config get codex.reasoning_effort
  humanize-flow config set codex.reasoning_effort high
  humanize-flow config get review.yolo
  humanize-flow config set review.yolo false
  humanize-flow config get review.sandbox
  humanize-flow config set review.sandbox workspace-write
EOF
      ;;
    *) die "Unknown config command: $sub" ;;
  esac
}

cmd_i18n() {
  local lang
  lang="${1:-}"
  case "$lang" in
    "")
      printf '%s\n' "$(language_default)"
      ;;
    --help|-h|help)
      cat <<'EOF'
Usage:
  humanize-flow i18n
  humanize-flow i18n en
  humanize-flow i18n zh

Sets the global language for human-facing generated artifacts.
EOF
      ;;
    en|zh|zh-CN|zh_CN|en-US|en_US)
      lang="$(normalize_language "$lang")"
      json_set "$(user_config_path)" "language" "$lang"
      info "set language=$lang in $(user_config_path)"
      ;;
    *)
      die "Unsupported language: $lang (supported: en, zh)"
      ;;
  esac
}

worker_skill_file() {
  local p
  p="$DIST_ROOT/skills/claude/humanize-flow-worker/SKILL.md"
  if [ -f "$p" ]; then printf '%s\n' "$p"; return 0; fi
  p="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/humanize-flow-worker/SKILL.md"
  if [ -f "$p" ]; then printf '%s\n' "$p"; return 0; fi
  p="$(repo_root)/.claude/skills/humanize-flow-worker/SKILL.md"
  if [ -f "$p" ]; then printf '%s\n' "$p"; return 0; fi
  return 1
}

humanize_integration_path() {
  local p
  if command_exists humanize; then command -v humanize; return 0; fi
  p="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/plugins"
  if [ -d "$p" ]; then
    p="$(find "$p" -type d -name humanize 2>/dev/null | head -n 1 || true)"
    if [ -n "$p" ]; then printf '%s\n' "$p"; return 0; fi
  fi
  p="$HOME/.codex/skills/humanize/scripts/setup-rlcr-loop.sh"
  if [ -x "$p" ]; then printf '%s\n' "$p"; return 0; fi
  return 1
}

ensure_humanize_available() {
  local mode found
  mode="$1"
  [ "$mode" = "required" ] || return 0
  found="$(humanize_integration_path 2>/dev/null || true)"
  [ -n "$found" ] || die "Claude humanize mode is required, but no humanize command, Claude plugin, or Codex humanize skill script was detected. Install humanize or run with --humanize-mode off / config set claude.humanize off."
}

humanize_worker_instruction() {
  local mode plan_path plan_display integration_path
  mode="$1"; plan_path="$2"
  if [ -n "$plan_path" ]; then plan_display="$(repo_relative_path "$plan_path")"; else plan_display="not-found"; fi
  integration_path="$(humanize_integration_path 2>/dev/null || true)"
  case "$mode" in
    required)
      cat <<EOF
Claude humanize mode: required
Humanize integration path detected before launch: ${integration_path:-not-detected}
Plan path for RLCR: $plan_display

Required humanize behavior:
- Before implementation, start humanize/RLCR inside this Claude Code session using the approved plan path above.
- Prefer the installed Claude plugin command: /humanize:start-rlcr-loop $plan_display --yolo
- If the slash command is unavailable but a humanize script is available, use the installed setup-rlcr-loop.sh equivalent for the same plan.
- If humanize/RLCR cannot be started, stop without editing code and report the blocker.
- Do not silently emulate humanize discipline in required mode.
EOF
      ;;
    auto)
      cat <<EOF
Claude humanize mode: auto
Humanize integration path detected before launch: ${integration_path:-not-detected}
Plan path for RLCR: $plan_display

Auto humanize behavior:
- Use humanize/RLCR for complex implementation when it is installed and safe in this Claude Code context.
- Prefer: /humanize:start-rlcr-loop $plan_display --yolo
- If the plan path is not-found, humanize is unavailable, or this is a tiny safe edit, implement directly while preserving the review boundary.
EOF
      ;;
    off)
      cat <<EOF
Claude humanize mode: off
Humanize integration is disabled for this run.

Required behavior:
- Do not start humanize/RLCR.
- Implement directly from the approved handoff, plan, and acceptance criteria.
- Preserve the Codex review boundary.
EOF
      ;;
  esac
}

cmd_paths() {
  cat <<EOF
version: $HF_VERSION
dist_root: $DIST_ROOT
repo_root: $(repo_root)
state_dir: $(state_dir)
docs_dir: $(docs_dir)
user_config: $(user_config_path)
language: $(language_default)
claude.model: $(claude_model_default)
claude.permission_mode: $(claude_permission_mode_default)
claude.humanize: $(claude_humanize_default)
codex.model: $(display_optional_config "$(codex_model_default)" "(codex default)")
codex.reasoning_effort: $(display_optional_config "$(codex_reasoning_effort_default)" "(codex default)")
review.yolo: $(review_yolo_default)
review.sandbox: $(review_sandbox_default)
codex_user_skills_dir: $HOME/.agents/skills
claude_user_skills_dir: ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills
EOF
}

cmd_doctor() {
  local failures=0
  info "version: $HF_VERSION"
  info "dist root: $DIST_ROOT"
  info "language: $(language_default)"
  info "claude model: $(claude_model_default)"
  info "claude permission mode: $(claude_permission_mode_default)"
  info "claude humanize: $(claude_humanize_default)"
  info "codex model: $(display_optional_config "$(codex_model_default)" "(codex default)")"
  info "codex reasoning effort: $(display_optional_config "$(codex_reasoning_effort_default)" "(codex default)")"
  info "review yolo: $(review_yolo_default)"
  info "review sandbox: $(review_sandbox_default)"

  for bin in git python3 codex claude bd jq; do
    if command_exists "$bin"; then
      printf '  OK   %-10s %s\n' "$bin" "$(command -v "$bin")"
    else
      case "$bin" in
        git|python3)
          printf '  FAIL %-10s missing\n' "$bin"
          failures=$((failures + 1))
          ;;
        *)
          printf '  WARN %-10s missing\n' "$bin"
          ;;
      esac
    fi
  done

  if [ -d "$HOME/.agents/skills/humanize-flow-planner" ] || [ -d "$(repo_root)/.agents/skills/humanize-flow-planner" ]; then
    printf '  OK   codex skill humanize-flow-planner installed\n'
  else
    printf '  WARN codex skill humanize-flow-planner not found\n'
  fi

  if [ -d "$HOME/.agents/skills/humanize-flow-bd-planner" ] || [ -d "$(repo_root)/.agents/skills/humanize-flow-bd-planner" ]; then
    printf '  OK   codex skill humanize-flow-bd-planner installed\n'
  else
    printf '  WARN codex skill humanize-flow-bd-planner not found\n'
  fi

  if [ -d "$HOME/.agents/skills/humanize-flow-reviewer" ] || [ -d "$(repo_root)/.agents/skills/humanize-flow-reviewer" ]; then
    printf '  OK   codex skill humanize-flow-reviewer installed\n'
  else
    printf '  WARN codex skill humanize-flow-reviewer not found\n'
  fi

  if [ -d "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/humanize-flow-worker" ] || [ -d "$(repo_root)/.claude/skills/humanize-flow-worker" ]; then
    printf '  OK   claude skill humanize-flow-worker installed\n'
  else
    printf '  WARN claude skill humanize-flow-worker not found\n'
  fi

  if humanize_path="$(humanize_integration_path 2>/dev/null || true)" && [ -n "$humanize_path" ]; then
    printf '  OK   humanize integration found: %s\n' "$humanize_path"
  else
    if [ "$(claude_humanize_default)" = "required" ]; then
      printf '  FAIL humanize integration not detected (claude.humanize=required)\n'
      failures=$((failures + 1))
    else
      printf '  WARN humanize integration not detected (claude.humanize=$(claude_humanize_default))\n'
    fi
  fi

  if [ "$failures" -gt 0 ]; then
    die "$failures required tool(s) missing."
  fi
}

cmd_init() {
  require_git_repo
  local with_bd=0 stealth=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --with-bd) with_bd=1 ;;
      --bd-stealth) with_bd=1; stealth=1 ;;
      --help|-h)
        cat <<'EOF'
Usage: humanize-flow init [--with-bd] [--bd-stealth]

Creates .humanize-flow/ and docs/humanize-flow/ in the current git repository.
Use --with-bd to run 'bd init' when Beads is installed and not initialized.
Use --bd-stealth to run 'bd init --stealth' when supported.
EOF
        return 0 ;;
      *) die "Unknown init option: $1" ;;
    esac
    shift
  done

  mkdir -p "$(state_dir)/handoffs" "$(state_dir)/runs" "$(state_dir)/tmp" "$(docs_dir)"
  if [ ! -f "$(state_dir)/config.json" ]; then
    cat > "$(state_dir)/config.json" <<EOF
{
  "schema_version": "1",
  "created_at": "$(iso_now)",
  "language": "$(language_default)",
  "default_docs_dir": "docs/humanize-flow",
  "default_state_dir": ".humanize-flow",
  "humanize_preferred": true
}
EOF
  fi
  if [ ! -f "$(state_dir)/README.md" ]; then
    cat > "$(state_dir)/README.md" <<'EOF'
# .humanize-flow

This directory stores Humanize Flow handoff manifests and run logs.

- `handoffs/` is intended to be committed when it describes approved work.
- `runs/` and `tmp/` are local runtime folders and may be ignored.
EOF
  fi

  if [ "$with_bd" -eq 1 ]; then
    if command_exists bd; then
      if bd info >/dev/null 2>&1; then
        info "Beads already initialized."
      else
        if [ "$stealth" -eq 1 ]; then
          info "running bd init --stealth"
          bd init --stealth
        else
          info "running bd init"
          bd init
        fi
      fi
    else
      warn "bd not installed; skipped bd init."
    fi
  fi

  info "initialized $(repo_root)"
}

write_request_file() {
  local slug request from target
  slug="$1"; request="$2"; from="$3"
  mkdir -p "$(docs_dir)/$slug"
  target="$(docs_dir)/$slug/request.md"
  if [ -n "$from" ]; then
    cp "$from" "$target"
  else
    cat > "$target" <<EOF
# Request: $slug

$request
EOF
  fi
  printf '%s\n' "$target"
}

cmd_plan() {
  require_git_repo
  local slug request from no_codex sandbox run_dir request_path prompt_file final_file prompt_text
  slug=""; request=""; from=""; no_codex=0; sandbox="workspace-write"
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug) shift; slug="${1:-}" ;;
      --request) shift; request="${1:-}" ;;
      --from) shift; from="${1:-}" ;;
      --no-codex) no_codex=1 ;;
      --sandbox) shift; sandbox="${1:-}" ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow plan --slug SLUG --from FILE
  humanize-flow plan --slug SLUG --request "text"

Runs Codex with the humanize-flow-planner skill. The planner should discuss
ambiguity when possible, then write Markdown artifacts and a draft handoff.
EOF
        return 0 ;;
      *) die "Unknown plan option: $1" ;;
    esac
    shift
  done

  if [ -z "$from" ] && [ -z "$request" ]; then die "plan requires --from FILE or --request TEXT."; fi
  if [ -n "$from" ] && [ ! -f "$from" ]; then die "request file not found: $from"; fi
  if [ -z "$slug" ]; then
    if [ -n "$request" ]; then slug="$(slugify "$request")"; else slug="$(slugify "$(basename "$from")")"; fi
  fi

  cmd_init >/dev/null
  request_path="$(write_request_file "$slug" "$request" "$from")"
  run_dir="$(state_dir)/runs/$(timestamp)-plan-$slug"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/planner-prompt.md"
  final_file="$run_dir/codex-final.md"

  cat > "$prompt_file" <<EOF
$(planner_skill_hint)

You are running the Humanize Flow planner for this repository.

Slug: $slug
Request file: $request_path
Required state dir: $(state_dir)
Required docs dir: $(docs_dir)
Required handoff path: $(handoff_path "$slug")

$(language_instruction)

Follow the humanize-flow-planner skill exactly:
- First understand the request and repository context.
- If important ambiguity remains and this is an interactive session, discuss it with the user before finalizing.
- If this is non-interactive and key ambiguity remains, write docs/humanize-flow/$slug/questions.md and stop with a concise summary.
- Do not modify implementation code.
- Produce request.md, plan.md, acceptance.md, bd-plan.md, and .humanize-flow/handoffs/$slug.json.
- Write all generated Markdown and handoff prose, including bd-plan.md and Beads epic/task titles, descriptions, and acceptance criteria, in the configured language from the language policy above.
- Keep the handoff in state=draft and approval.status=pending unless the user explicitly approves in-session.
- Prepare Beads tasks in the handoff. Materialize them only after explicit human approval.
EOF

  info "planner prompt: $prompt_file"
  if [ "$no_codex" -eq 1 ]; then info "--no-codex set; prompt written but not executed."; return 0; fi
  command_exists codex || die "codex CLI not found."
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$final_file"
}

extract_bd_slug_seed() {
  python3 - "$1" "$2" <<'PY'
import json, re, sys
from pathlib import Path
path = Path(sys.argv[1])
fallback = sys.argv[2]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    print('bd-' + re.sub(r'[^a-z0-9]+', '-', fallback.lower()).strip('-'))
    raise SystemExit(0)

candidates = []

def walk(obj):
    if isinstance(obj, dict):
        for key in ('title', 'summary', 'name', 'text'):
            value = obj.get(key)
            if isinstance(value, str) and value.strip():
                candidates.append(value.strip())
        for value in obj.values():
            walk(value)
    elif isinstance(obj, list):
        for value in obj:
            walk(value)

walk(data)
seed = candidates[0] if candidates else fallback
seed = f"{fallback}-{seed}"
seed = seed.lower()
seed = re.sub(r'[^a-z0-9]+', '-', seed).strip('-')
print((seed[:80].strip('-') or 'bd-task'))
PY
}

cmd_plan_from_bd() {
  require_git_repo
  local bd_id slug no_codex sandbox run_dir prompt_file final_file prompt_text source_file tmp_source safe_bd_id
  bd_id=""; slug=""; no_codex=0; sandbox="workspace-write"
  while [ $# -gt 0 ]; do
    case "$1" in
      --slug) shift; slug="${1:-}" ;;
      --no-codex) no_codex=1 ;;
      --sandbox) shift; sandbox="${1:-}" ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow plan-from-bd BD_ID [--slug SLUG]
  humanize-flow from-bd BD_ID [--slug SLUG]

Reads an existing Beads task with 'bd show BD_ID --json', captures it as
bd-source.json, and runs the humanize-flow-bd-planner Codex skill. This path
links the existing task instead of creating duplicate Beads tasks.

Options:
  --sandbox <mode>  Pass sandbox mode to codex exec; default is workspace-write.
  --no-codex        Capture the task and write the planner prompt, but do not execute Codex.
EOF
        return 0 ;;
      --*) die "Unknown plan-from-bd option: $1" ;;
      *)
        if [ -z "$bd_id" ]; then bd_id="$1"; else die "Unexpected extra argument: $1"; fi
        ;;
    esac
    shift
  done

  [ -n "$bd_id" ] || die "plan-from-bd requires a Beads task ID."
  command_exists bd || die "bd CLI not found; cannot read existing task $bd_id."
  cmd_init >/dev/null
  mkdir -p "$(state_dir)/tmp"
  safe_bd_id="$(slugify "$bd_id")"
  tmp_source="$(state_dir)/tmp/bd-source-$(timestamp)-$safe_bd_id.json"
  bd show "$bd_id" --json > "$tmp_source"

  if [ -z "$slug" ]; then
    slug="$(extract_bd_slug_seed "$tmp_source" "$bd_id")"
  fi

  mkdir -p "$(docs_dir)/$slug"
  source_file="$(docs_dir)/$slug/bd-source.json"
  cp "$tmp_source" "$source_file"

  run_dir="$(state_dir)/runs/$(timestamp)-plan-from-bd-$slug"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/bd-planner-prompt.md"
  final_file="$run_dir/codex-final.md"

  cat > "$prompt_file" <<EOF
$(bd_planner_skill_hint)

You are running the Humanize Flow existing-Beads-task planner for this repository.

Source Beads task id: $bd_id
Captured Beads source JSON: $source_file
Slug: $slug
Required state dir: $(state_dir)
Required docs dir: $(docs_dir)
Required handoff path: $(handoff_path "$slug")

$(language_instruction)

Follow the humanize-flow-bd-planner skill exactly:
- Read and understand the existing Beads task. Do not ask the user to repeat information already in bd.
- If important ambiguity remains and this is an interactive session, discuss it with the user before finalizing.
- If this is non-interactive and key ambiguity remains, write docs/humanize-flow/$slug/questions.md and stop with a concise summary.
- Do not modify implementation code.
- Do not invoke Claude Code.
- Do not create duplicate Beads tasks.
- Produce request.md, plan.md, acceptance.md, bd-plan.md, and .humanize-flow/handoffs/$slug.json.
- Write all generated Markdown and handoff prose, including bd-plan.md and generated bd.tasks title, description, and acceptance criteria fields, in the configured language from the language policy above.
- Preserve $source_file as bd-source.json and reference it from the handoff artifacts map.
- Preserve source task text in bd-source.json/source metadata only; do not copy English source prose into generated plan or handoff bd.* prose when the configured language is different.
- In the handoff, set source.type=beads, source.bd_id=$bd_id, bd.materialized=true, and execution.current_bd_id=$bd_id.
- Keep the handoff in state=draft and approval.status=pending unless the user explicitly approves in-session.
- The normal next commands are: humanize-flow approve $slug ; humanize-flow run $bd_id ; humanize-flow review $bd_id
EOF

  info "bd planner prompt: $prompt_file"
  info "captured bd source: $source_file"
  if [ "$no_codex" -eq 1 ]; then info "--no-codex set; prompt written but not executed."; return 0; fi
  command_exists codex || die "codex CLI not found."
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$final_file"
}

cmd_approve() {
  require_git_repo
  local slug materialize file
  slug="${1:-}"; materialize=0
  [ -n "$slug" ] || die "Usage: humanize-flow approve SLUG [--materialize-bd]"
  shift || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --materialize-bd) materialize=1 ;;
      --help|-h) log "Usage: humanize-flow approve SLUG [--materialize-bd]"; return 0 ;;
      *) die "Unknown approve option: $1" ;;
    esac
    shift
  done
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || die "handoff not found: $file"
  python3 - "$file" <<'PY'
import json, sys, datetime, getpass
path = sys.argv[1]
with open(path, encoding='utf-8') as f:
    data = json.load(f)
data['state'] = 'approved'
data['updated_at'] = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
approval = data.setdefault('approval', {})
approval['required'] = True
approval['status'] = 'approved'
approval['approved_at'] = data['updated_at']
approval['approved_by'] = approval.get('approved_by') or getpass.getuser()
with open(path, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')
print(path)
PY
  info "approved $slug"
  if [ "$materialize" -eq 1 ]; then cmd_materialize_bd "$slug"; fi
}

cmd_materialize_bd() {
  require_git_repo
  local slug file lang
  slug="${1:-}"; [ -n "$slug" ] || die "Usage: humanize-flow materialize-bd SLUG"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || die "handoff not found: $file"
  command_exists bd || die "bd CLI not found. Install Beads or run without --materialize-bd."
  lang="$(language_default)"
  HUMANIZE_FLOW_LANGUAGE_EFFECTIVE="$lang" python3 - "$file" <<'PY'
import json, os, subprocess, sys, datetime, shlex
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding='utf-8'))
if data.get('approval', {}).get('status') != 'approved':
    raise SystemExit('handoff must be approved before materializing bd tasks')
bd = data.setdefault('bd', {})
if bd.get('materialized'):
    print('Beads tasks already materialized; nothing to do.')
    raise SystemExit(0)

def run(args):
    print('+ ' + ' '.join(shlex.quote(a) for a in args), file=sys.stderr)
    cp = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if cp.returncode != 0:
        sys.stderr.write(cp.stderr)
        raise SystemExit(cp.returncode)
    return cp.stdout.strip()

def find_id(obj):
    if isinstance(obj, dict):
        for key in ('id', 'issue_id', 'bead_id'):
            value = obj.get(key)
            if isinstance(value, str) and value:
                return value
        for value in obj.values():
            found = find_id(value)
            if found:
                return found
    elif isinstance(obj, list):
        for value in obj:
            found = find_id(value)
            if found:
                return found
    return None

lang = os.environ.get('HUMANIZE_FLOW_LANGUAGE_EFFECTIVE', 'en')
TEXT = {
    'en': {
        'context_header': 'Humanize Flow context:',
        'handoff': 'Handoff',
        'request': 'Request',
        'plan': 'Plan',
        'acceptance': 'Acceptance',
        'bd_plan': 'Beads plan',
        'task_fallback': 'Humanize Flow task',
        'epic_fallback': 'Humanize Flow epic',
    },
    'zh': {
        'context_header': 'Humanize Flow 上下文:',
        'handoff': 'Handoff',
        'request': '需求',
        'plan': '计划',
        'acceptance': '验收标准',
        'bd_plan': 'Beads 计划',
        'task_fallback': 'Humanize Flow 任务',
        'epic_fallback': 'Humanize Flow Epic',
    },
}.get(lang, {})

def text(key):
    return TEXT.get(key) or TEXT.get('en', {}).get(key) or key

def artifact_context():
    artifacts = data.get('artifacts') or {}
    slug = data.get('slug') or path.stem
    entries = [
        (text('handoff'), f'.humanize-flow/handoffs/{slug}.json'),
        (text('request'), artifacts.get('request')),
        (text('plan'), artifacts.get('plan')),
        (text('acceptance'), artifacts.get('acceptance')),
        (text('bd_plan'), artifacts.get('bd_plan')),
    ]
    lines = [text('context_header')]
    for label, value in entries:
        if value:
            lines.append(f'- {label}: `{value}`')
    return '\n'.join(lines)

def create_item(item, parent_id=None):
    title = item.get('title') or item.get('key') or text('task_fallback')
    typ = item.get('type') or 'task'
    priority = str(item.get('priority', 2))
    desc = item.get('description') or ''
    context = artifact_context()
    if 'Humanize Flow context:' not in desc and 'Humanize Flow 上下文:' not in desc:
        desc = desc.rstrip()
        if desc:
            desc += '\n\n'
        desc += context
    labels = list(item.get('labels') or [])
    if 'humanize-flow' not in labels:
        labels.insert(0, 'humanize-flow')
    if data.get('slug') and data.get('slug') not in labels:
        labels.append(data['slug'])
    args = ['bd', 'create', title, '-t', typ, '-p', priority, '--description', desc, '-l', ','.join(labels), '--json']
    if parent_id and typ != 'epic':
        args.extend(['--parent', parent_id])
    out = run(args)
    try:
        parsed = json.loads(out)
    except Exception:
        parsed = {'raw': out}
    bid = find_id(parsed)
    if not bid:
        raise SystemExit(f'could not parse bd id from output: {out}')
    item['bd_id'] = bid
    return bid

epic = bd.setdefault('epic', {'key': 'epic', 'title': data.get('summary') or data.get('slug') or text('epic_fallback'), 'type': 'epic', 'priority': 1, 'labels': []})
epic_id = create_item(epic, None)
key_to_id = {epic.get('key', 'epic'): epic_id}

tasks = bd.get('tasks') or []
for task in tasks:
    bid = create_item(task, epic_id)
    key_to_id[task.get('key') or bid] = bid

for task in tasks:
    child_id = task.get('bd_id')
    for dep_key in task.get('depends_on_keys') or []:
        parent_id = key_to_id.get(dep_key)
        if child_id and parent_id:
            run(['bd', 'dep', 'add', child_id, parent_id])

bd['materialized'] = True
data['bd'] = bd
data['state'] = 'approved'
data['updated_at'] = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n', encoding='utf-8')
print(f'Materialized {len(tasks)} task(s) under epic {epic_id}.')
PY
}

find_slug_for_bd_id() {
  local bd_id
  bd_id="$1"
  python3 - "$(state_dir)/handoffs" "$bd_id" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1]); target = sys.argv[2]
for path in sorted(root.glob('*.json')):
    try:
        data = json.loads(path.read_text(encoding='utf-8'))
    except Exception:
        continue
    ids = []
    source = data.get('source', {})
    if isinstance(source, dict):
        if source.get('bd_id'):
            ids.append(source.get('bd_id'))
        ids.extend(source.get('bd_ids') or [])
    execution = data.get('execution', {})
    if isinstance(execution, dict) and execution.get('current_bd_id'):
        ids.append(execution.get('current_bd_id'))
    epic = data.get('bd', {}).get('epic', {})
    if epic.get('bd_id'):
        ids.append(epic.get('bd_id'))
    for task in data.get('bd', {}).get('tasks', []):
        if task.get('bd_id'):
            ids.append(task.get('bd_id'))
    if target in ids:
        print(data.get('slug') or path.stem)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

find_handoff_for_ref() {
  local ref
  ref="$1"
  python3 - "$(state_dir)/handoffs" "$ref" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1])
target = sys.argv[2]
direct = root / f'{target}.json'
if direct.exists():
    try:
        data = json.loads(direct.read_text(encoding='utf-8'))
    except Exception:
        data = {}
    print(data.get('slug') or direct.stem)
    raise SystemExit(0)

for path in sorted(root.glob('*.json')):
    try:
        data = json.loads(path.read_text(encoding='utf-8'))
    except Exception:
        continue
    if target in {data.get('slug'), path.stem}:
        print(data.get('slug') or path.stem)
        raise SystemExit(0)
    ids = []
    source = data.get('source', {})
    if isinstance(source, dict):
        if source.get('bd_id'):
            ids.append(source.get('bd_id'))
        ids.extend(source.get('bd_ids') or [])
    execution = data.get('execution', {})
    if isinstance(execution, dict) and execution.get('current_bd_id'):
        ids.append(execution.get('current_bd_id'))
    epic = data.get('bd', {}).get('epic', {})
    if isinstance(epic, dict) and epic.get('bd_id'):
        ids.append(epic.get('bd_id'))
    for task in data.get('bd', {}).get('tasks', []):
        if isinstance(task, dict) and task.get('bd_id'):
            ids.append(task.get('bd_id'))
    if target in ids:
        print(data.get('slug') or path.stem)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

default_bd_id_for_slug() {
  local slug
  slug="$1"
  python3 - "$(handoff_path "$slug")" <<'PY'
import json, sys
from pathlib import Path
path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)
execution = data.get('execution') or {}
if isinstance(execution, dict) and execution.get('current_bd_id'):
    print(execution['current_bd_id'])
    raise SystemExit(0)
source = data.get('source') or {}
if isinstance(source, dict) and source.get('bd_id'):
    print(source['bd_id'])
    raise SystemExit(0)
bd = data.get('bd') or {}
epic = bd.get('epic') or {}
if isinstance(epic, dict) and epic.get('bd_id'):
    print(epic['bd_id'])
    raise SystemExit(0)
for task in bd.get('tasks') or []:
    if isinstance(task, dict) and task.get('bd_id'):
        print(task['bd_id'])
        raise SystemExit(0)
raise SystemExit(1)
PY
}

latest_review_for_slug() {
  local slug review_dir
  slug="$1"
  review_dir="$(docs_dir)/$slug/reviews"
  [ -d "$review_dir" ] || return 1
  find "$review_dir" -maxdepth 1 -type f -name '*.md' -print | sort | tail -n 1
}

review_verdict() {
  local review_file
  review_file="$1"
  [ -f "$review_file" ] || return 1
  python3 - "$review_file" <<'PY'
import re
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text(encoding='utf-8', errors='replace')
patterns = [
    r'(?im)^\s*(?:[-*]\s*)?(?:verdict|final verdict)\s*[:：]\s*`?(pass|changes_requested|blocked)`?\b',
    r'(?im)^\s*`(pass|changes_requested|blocked)`\s*$',
    r'(?im)^\s*(pass|changes_requested|blocked)\s*$',
]
for pattern in patterns:
    match = re.search(pattern, text)
    if match:
        print(match.group(1).lower())
        raise SystemExit(0)
raise SystemExit(1)
PY
}

handoff_artifact_path() {
  local slug key file value root
  slug="$1"; key="$2"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || return 1
  value="$(json_get "$file" "artifacts.$key" "")"
  [ -n "$value" ] || return 1
  root="$(repo_root)"
  case "$value" in
    /*) printf '%s\n' "$value" ;;
    *) printf '%s/%s\n' "$root" "$value" ;;
  esac
}

ensure_approved_handoff_for_slug() {
  local slug file
  slug="$1"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || die "handoff not found for yolo run: $file"
  python3 - "$file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception as exc:
    raise SystemExit(f'invalid handoff JSON: {path}: {exc}')
if data.get('approval', {}).get('status') != 'approved':
    raise SystemExit(f'handoff is not approved: {path}')
PY
}

set_handoff_artifact() {
  local slug key value file
  slug="$1"; key="$2"; value="$3"
  file="$(handoff_path "$slug")"
  [ -f "$file" ] || return 0
  python3 - "$file" "$key" "$value" <<'PY'
import json, sys, datetime
from pathlib import Path

path = Path(sys.argv[1])
key = sys.argv[2]
value = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(0)
artifacts = data.setdefault('artifacts', {})
artifacts[key] = value
data['updated_at'] = datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat().replace('+00:00', 'Z')
path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + '\n', encoding='utf-8')
PY
}

cmd_run_once() {
  require_git_repo
  local ref mode model permission_mode output_format verbose partial hook_events humanize_mode
  local bd_id slug file latest_review latest_review_display plan_path plan_display humanize_text run_dir prompt_file final_file raw_file skill_file skill_text prompt_text claude_args
  ref="$1"; mode="$2"; model="$3"; permission_mode="$4"; output_format="$5"; verbose="$6"; partial="$7"; hook_events="$8"; humanize_mode="$9"
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG"
  [ -n "$model" ] || die "Claude model cannot be empty."
  [ -n "$permission_mode" ] || die "Claude permission mode cannot be empty."
  humanize_mode="$(normalize_humanize_mode "$humanize_mode")" || die "Unsupported Claude humanize mode: $humanize_mode (supported: required, auto, off)"
  command_exists claude || die "claude CLI not found."
  command_exists bd || warn "bd CLI not found; worker prompt will still reference task id."
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then
    bd_id="$(default_bd_id_for_slug "$slug" 2>/dev/null || true)"
  fi
  if [ -z "$bd_id" ]; then bd_id="$ref"; fi
  if [ -n "$slug" ]; then file="$(handoff_path "$slug")"; else file=""; fi
  if [ -n "$slug" ]; then latest_review="$(latest_review_for_slug "$slug" 2>/dev/null || true)"; else latest_review=""; fi
  if [ -n "$latest_review" ]; then latest_review_display="$(repo_relative_path "$latest_review")"; else latest_review_display=""; fi
  if [ -n "$slug" ]; then plan_path="$(handoff_artifact_path "$slug" "plan" 2>/dev/null || true)"; else plan_path=""; fi
  if [ -n "$plan_path" ]; then plan_display="$(repo_relative_path "$plan_path")"; else plan_display="not-found"; fi
  ensure_humanize_available "$humanize_mode"
  if [ "$humanize_mode" = "required" ] && { [ -z "$plan_path" ] || [ ! -f "$plan_path" ]; }; then
    die "Claude humanize mode is required, but the approved plan artifact was not found for $ref. Expected plan path: $plan_display"
  fi
  humanize_text="$(humanize_worker_instruction "$humanize_mode" "$plan_path")"
  run_dir="$(state_dir)/runs/$(timestamp)-run-$bd_id"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/claude-worker-prompt.md"
  final_file="$run_dir/claude-final.md"
  raw_file="$run_dir/claude-final.jsonl"
  skill_file="$(worker_skill_file || true)"

  if [ -n "$skill_file" ]; then skill_text="$(cat "$skill_file")"; else skill_text=""; fi

  cat > "$prompt_file" <<EOF
You are the Claude Code implementer in the Humanize Flow workflow.

Task id: $bd_id
Handoff slug: ${slug:-unknown}
Handoff path: ${file:-not-found}
Plan path: $plan_display
Latest review path: ${latest_review_display:-not-found}
Repository root: $(repo_root)

$(language_instruction)

Embedded worker skill instructions follow. Treat them as authoritative for this run.

--- BEGIN humanize-flow-worker SKILL.md ---
$skill_text
--- END humanize-flow-worker SKILL.md ---

Required behavior:
- Read the Beads task with: bd show $bd_id --json
- Read the approved handoff, plan, and acceptance criteria before implementing.
- If the approved handoff, plan, or acceptance criteria cannot be found, stop and report the missing artifact instead of implementing from the brief Beads task alone.
- If the latest review path is not "not-found", read that review as the current correction target before editing.
- Do not bulk-load docs/humanize-flow/${slug:-unknown}/reviews/ or older review reports. Inspect older reviews only when the latest review explicitly references them or the user asks for review history.
- Do not expand scope beyond this task.
$humanize_text
- Run relevant tests.
- Write an implementation summary under docs/humanize-flow/<slug>/implementation/ when a slug is known.
- Update Beads notes/status with what changed, tests run, and remaining risks.
- Stop with a clear summary and request Codex review via: humanize-flow review $bd_id
- Use the actual Beads task id in the review command. If you mention the handoff slug (${slug:-unknown}), present it only as an alternative supported by newer humanize-flow versions.
EOF

  info "worker prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  claude_args="${HUMANIZE_FLOW_CLAUDE_ARGS:-}"
  if [ "$mode" = "interactive" ]; then
    info "starting Claude Code interactive worker session"
    info "model: $model"
    info "permission mode: $permission_mode"
    info "humanize mode: $humanize_mode"
    info "final output is not captured in print-mode log for interactive sessions"
    # shellcheck disable=SC2086
    claude --model "$model" --permission-mode "$permission_mode" $claude_args "$prompt_text"
  else
    info "starting Claude Code print worker session"
    info "model: $model"
    info "permission mode: $permission_mode"
    info "humanize mode: $humanize_mode"
    info "output format: $output_format"
    if [ "$output_format" = "stream-json" ]; then
      info "human-readable log: $final_file"
      info "raw stream log: $raw_file"
      if [ "$verbose" -eq 1 ]; then
        if [ "$partial" -eq 1 ] && [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages --include-hook-events --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$partial" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-hook-events --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        else
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --verbose $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        fi
      else
        if [ "$partial" -eq 1 ] && [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages --include-hook-events $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$partial" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-partial-messages $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        elif [ "$hook_events" -eq 1 ]; then
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json --include-hook-events $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        else
          # shellcheck disable=SC2086
          claude -p --model "$model" --permission-mode "$permission_mode" --output-format stream-json $claude_args "$prompt_text" | tee "$raw_file" | format_claude_stream_json | tee "$final_file"
        fi
      fi
    else
      if [ "$verbose" -eq 1 ]; then
        # shellcheck disable=SC2086
        claude -p --model "$model" --permission-mode "$permission_mode" --output-format text --verbose $claude_args "$prompt_text" | tee "$final_file"
      else
        # shellcheck disable=SC2086
        claude -p --model "$model" --permission-mode "$permission_mode" --output-format text $claude_args "$prompt_text" | tee "$final_file"
      fi
    fi
  fi
}

cmd_run_yolo() {
  require_git_repo
  local ref max_round model output_format verbose partial hook_events humanize_mode slug bd_id round latest_review verdict
  ref="$1"; max_round="$2"; model="$3"; output_format="$4"; verbose="$5"; partial="$6"; hook_events="$7"; humanize_mode="$8"
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG --yolo"
  case "$max_round" in
    ''|*[!0-9]*) die "--max-round must be a positive integer." ;;
  esac
  [ "$max_round" -ge 1 ] || die "--max-round must be at least 1."
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  [ -n "$slug" ] || die "YOLO mode requires an approved Humanize Flow handoff for: $ref"
  ensure_approved_handoff_for_slug "$slug"
  bd_id="$(default_bd_id_for_slug "$slug" 2>/dev/null || true)"
  [ -n "$bd_id" ] || bd_id="$ref"

  info "starting YOLO mode"
  info "handoff slug: $slug"
  info "task id: $bd_id"
  info "max rounds: $max_round"
  info "humanize mode: $humanize_mode"
  round=1
  while [ "$round" -le "$max_round" ]; do
    info "YOLO round $round/$max_round: Claude Code worker"
    cmd_run_once "$bd_id" "print" "$model" "auto" "$output_format" "$verbose" "$partial" "$hook_events" "$humanize_mode"
    info "YOLO round $round/$max_round: Codex review"
    cmd_review "$bd_id" --yolo
    latest_review="$(latest_review_for_slug "$slug" 2>/dev/null || true)"
    [ -n "$latest_review" ] || die "YOLO review did not produce a review artifact for $slug"
    verdict="$(review_verdict "$latest_review" 2>/dev/null || true)"
    info "YOLO review verdict: ${verdict:-unknown}"
    case "$verdict" in
      pass)
        info "YOLO mode completed after $round round(s): review passed."
        return 0
        ;;
      changes_requested|blocked|"")
        if [ "$round" -ge "$max_round" ]; then
          die "YOLO mode reached max rounds ($max_round) without a passing review. Latest review: $latest_review"
        fi
        info "YOLO mode will run another correction round using latest review: $(repo_relative_path "$latest_review")"
        ;;
      *)
        if [ "$round" -ge "$max_round" ]; then
          die "YOLO mode could not parse a passing review before max rounds. Latest verdict: $verdict. Latest review: $latest_review"
        fi
        warn "Unrecognized review verdict '$verdict'; continuing correction loop."
        ;;
    esac
    round=$((round + 1))
  done
}

cmd_run() {
  require_git_repo
  local ref mode model permission_mode output_format verbose partial hook_events humanize_mode yolo max_round
  ref=""; mode="print"; model="$(claude_model_default)"; permission_mode="$(claude_permission_mode_default)"
  humanize_mode="$(claude_humanize_default)"
  output_format="stream-json"; verbose=1; partial=1; hook_events=1; yolo=0; max_round=3
  while [ $# -gt 0 ]; do
    case "$1" in
      --interactive|-i) mode="interactive" ;;
      --model) shift; model="${1:-}" ;;
      --permission-mode) shift; permission_mode="${1:-}" ;;
      --humanize) humanize_mode="required" ;;
      --no-humanize) humanize_mode="off" ;;
      --humanize-mode) shift; humanize_mode="${1:-}" ;;
      --yolo) yolo=1; permission_mode="auto" ;;
      --max-round) shift; max_round="${1:-}" ;;
      --text) output_format="text"; partial=0; hook_events=0 ;;
      --stream-json) output_format="stream-json"; partial=1; hook_events=1 ;;
      --no-partial) partial=0 ;;
      --no-hook-events) hook_events=0 ;;
      --no-verbose) verbose=0 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow run BD_ID_OR_SLUG [options]

BD_ID_OR_SLUG may be either a Beads task id or a Humanize Flow handoff slug.

Options:
  --interactive, -i          Open a Claude Code interactive session instead of print mode.
  --model MODEL              Override the configured Claude model for this run.
  --permission-mode MODE     Override the configured Claude permission mode for this run.
  --humanize                 Require humanize/RLCR for this run.
  --no-humanize              Disable humanize/RLCR for this run.
  --humanize-mode MODE       Set humanize mode: required, auto, or off.
  --yolo                     Run Claude+Codex review loop until pass or max rounds.
  --max-round N              Maximum YOLO correction rounds. Default: 3.
  --text                     Use Claude text output instead of detailed stream-json.
  --stream-json              Use detailed stream-json internally and show a human-readable progress log. This is the default.
  --no-partial               Do not include partial message chunks in stream-json output.
  --no-hook-events           Do not include hook lifecycle events in stream-json output.
  --no-verbose               Do not pass --verbose to Claude Code.
EOF
        return 0 ;;
      --*) die "Unknown run option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected run argument: $1"; fi
        ;;
    esac
    shift
  done
  [ -n "$ref" ] || die "Usage: humanize-flow run BD_ID_OR_SLUG"
  [ -n "$model" ] || die "Claude model cannot be empty."
  [ -n "$permission_mode" ] || die "Claude permission mode cannot be empty."
  humanize_mode="$(normalize_humanize_mode "$humanize_mode")" || die "Unsupported Claude humanize mode: $humanize_mode (supported: required, auto, off)"
  if [ "$yolo" -eq 1 ]; then
    [ "$mode" != "interactive" ] || die "YOLO mode does not support --interactive."
    cmd_run_yolo "$ref" "$max_round" "$model" "$output_format" "$verbose" "$partial" "$hook_events" "$humanize_mode"
  else
    cmd_run_once "$ref" "$mode" "$model" "$permission_mode" "$output_format" "$verbose" "$partial" "$hook_events" "$humanize_mode"
  fi
}

cmd_run_next() {
  require_git_repo
  command_exists bd || die "bd CLI not found."
  local tmp bd_id
  tmp="$(state_dir)/tmp/bd-ready-$(timestamp).json"
  mkdir -p "$(dirname "$tmp")"
  bd ready --json > "$tmp"
  bd_id="$(python3 - "$tmp" "$(state_dir)/handoffs" "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" <<'PY'
import json, sys
from pathlib import Path
ready_path = Path(sys.argv[1])
handoffs_dir = Path(sys.argv[2])
noninteractive = sys.argv[3] == '1'
try:
    data = json.loads(ready_path.read_text())
except Exception:
    raise SystemExit(1)
if isinstance(data, dict):
    items = data.get('issues') or data.get('items') or data.get('data') or []
elif isinstance(data, list):
    items = data
else:
    items = []

def labels_of(item):
    labels = item.get('labels') or item.get('label_names') or []
    if isinstance(labels, str):
        labels = [x.strip() for x in labels.split(',') if x.strip()]
    return labels

def item_id(item):
    for key in ('id', 'issue_id', 'bead_id'):
        v = item.get(key)
        if isinstance(v, str) and v:
            return v
    return None

def item_title(item):
    for key in ('title', 'summary', 'name'):
        v = item.get(key)
        if isinstance(v, str) and v:
            return v
    return '(untitled)'

def item_type(item):
    v = item.get('type') or item.get('issue_type') or ''
    return v if isinstance(v, str) else ''

def parent_id(item):
    for key in ('parent_id', 'parent', 'epic_id', 'epic'):
        v = item.get(key)
        if isinstance(v, str) and v:
            return v
        if isinstance(v, dict):
            for nested in ('id', 'issue_id', 'bead_id'):
                nv = v.get(nested)
                if isinstance(nv, str) and nv:
                    return nv
    return ''

approved_ids = set()
if handoffs_dir.exists():
    for path in sorted(handoffs_dir.glob('*.json')):
        try:
            h = json.loads(path.read_text(encoding='utf-8'))
        except Exception:
            continue
        if h.get('approval', {}).get('status') != 'approved':
            continue
        source = h.get('source') or {}
        if isinstance(source, dict):
            if source.get('bd_id'):
                approved_ids.add(source['bd_id'])
            for bid in source.get('bd_ids') or []:
                approved_ids.add(bid)
        execution = h.get('execution') or {}
        if isinstance(execution, dict) and execution.get('current_bd_id'):
            approved_ids.add(execution['current_bd_id'])
        bd = h.get('bd') or {}
        epic = bd.get('epic') or {}
        if epic.get('bd_id'):
            approved_ids.add(epic['bd_id'])
        for task in bd.get('tasks') or []:
            if isinstance(task, dict) and task.get('bd_id'):
                approved_ids.add(task['bd_id'])

chosen = None
ready = [item for item in items if isinstance(item, dict) and item_id(item)]

def priority(item):
    iid = item_id(item)
    labels = labels_of(item)
    if iid in approved_ids:
        return 0
    if 'humanize-flow' in labels:
        return 1
    return 2

ready = sorted(ready, key=lambda item: (priority(item), parent_id(item), item_id(item) or ''))
if ready and (noninteractive or not sys.stdin.isatty() or len(ready) == 1):
    chosen = item_id(ready[0])
elif ready:
    groups = {}
    order = []
    for item in ready:
        group = parent_id(item) or item_id(item)
        if group not in groups:
            groups[group] = []
            order.append(group)
        groups[group].append(item)
    if len(order) > 1:
        print('Ready Epic/task groups:', file=sys.stderr)
        for idx, group in enumerate(order, 1):
            group_items = groups[group]
            first = group_items[0]
            print(f'  {idx}. {group} ({len(group_items)} ready) - {item_title(first)}', file=sys.stderr)
        while True:
            answer = input('Select Epic/task group number, Beads task id, or q to cancel: ').strip()
            if answer.lower() in {'q', 'quit', 'cancel'}:
                raise SystemExit(2)
            selected_group = ''
            if answer.isdigit() and 1 <= int(answer) <= len(order):
                selected_group = order[int(answer) - 1]
            elif answer in groups:
                selected_group = answer
            else:
                for group, group_items in groups.items():
                    if any(item_id(item) == answer for item in group_items):
                        selected_group = group
                        chosen = answer
                        break
            if selected_group:
                group_items = groups[selected_group]
                if not chosen:
                    if len(group_items) == 1:
                        chosen = item_id(group_items[0])
                    else:
                        print(f'Ready tasks in {selected_group}:', file=sys.stderr)
                        for idx, item in enumerate(group_items, 1):
                            print(f'  {idx}. {item_id(item)} [{item_type(item) or "task"}] {item_title(item)}', file=sys.stderr)
                        while True:
                            task_answer = input('Select task number or Beads task id: ').strip()
                            if task_answer.isdigit() and 1 <= int(task_answer) <= len(group_items):
                                chosen = item_id(group_items[int(task_answer) - 1])
                                break
                            if any(item_id(item) == task_answer for item in group_items):
                                chosen = task_answer
                                break
                            print('Invalid selection.', file=sys.stderr)
                break
            print('Invalid selection.', file=sys.stderr)
    else:
        group_items = groups[order[0]]
        if len(group_items) == 1:
            chosen = item_id(group_items[0])
        else:
            print('Ready tasks:', file=sys.stderr)
            for idx, item in enumerate(group_items, 1):
                print(f'  {idx}. {item_id(item)} [{item_type(item) or "task"}] {item_title(item)}', file=sys.stderr)
            while True:
                answer = input('Select task number, Beads task id, or q to cancel: ').strip()
                if answer.lower() in {'q', 'quit', 'cancel'}:
                    raise SystemExit(2)
                if answer.isdigit() and 1 <= int(answer) <= len(group_items):
                    chosen = item_id(group_items[int(answer) - 1])
                    break
                if any(item_id(item) == answer for item in group_items):
                    chosen = answer
                    break
                print('Invalid selection.', file=sys.stderr)
if chosen:
    print(chosen)
PY
)"
  [ -n "$bd_id" ] || die "No ready Beads task found."
  info "selected ready task: $bd_id"
  cmd_run "$bd_id"
}

cmd_review() {
  require_git_repo
  local ref="" bd_id slug file run_dir prompt_file review_dir review_file base prompt_text sandbox yolo
  sandbox="$(review_sandbox_default)"
  yolo="$(review_yolo_default)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --sandbox) shift; sandbox="${1:-}"; yolo="false" ;;
      --yolo) yolo="true" ;;
      --no-yolo) yolo="false" ;;
      --help|-h|help)
        cat <<'EOF'
Usage:
  humanize-flow review BD_ID_OR_SLUG [--yolo|--no-yolo] [--sandbox MODE]

BD_ID_OR_SLUG may be either a Beads task id or a Humanize Flow handoff slug.
Default review mode is yolo, which passes Codex
--dangerously-bypass-approvals-and-sandbox to avoid approval prompts.
Set review.yolo=false, HUMANIZE_FLOW_REVIEW_YOLO=false, --no-yolo, or
--sandbox MODE to use normal sandboxed Codex execution. Supported sandbox
modes: read-only, workspace-write, danger-full-access.
EOF
        return 0 ;;
      --*) die "Unknown review option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected review argument: $1"; fi
        ;;
    esac
    shift
  done
  sandbox="$(normalize_sandbox_mode "$sandbox")" || die "Unsupported review sandbox: $sandbox (supported: read-only, workspace-write, danger-full-access)"
  yolo="$(normalize_bool "$yolo")" || die "Unsupported review yolo value: $yolo (supported: true, false)"
  [ -n "$ref" ] || die "Usage: humanize-flow review BD_ID_OR_SLUG [--yolo|--no-yolo] [--sandbox MODE]"
  command_exists codex || die "codex CLI not found."
  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then
    bd_id="$(default_bd_id_for_slug "$slug" 2>/dev/null || true)"
  fi
  if [ -z "${bd_id:-}" ]; then bd_id="$ref"; fi
  if [ -n "$slug" ]; then file="$(handoff_path "$slug")"; else file=""; fi
  run_dir="$(state_dir)/runs/$(timestamp)-review-$ref"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-reviewer-prompt.md"
  review_dir="$(docs_dir)/${slug:-unknown}/reviews"
  mkdir -p "$review_dir"
  review_file="$review_dir/$(timestamp)-$ref.md"
  base="$(git merge-base HEAD main 2>/dev/null || git merge-base HEAD master 2>/dev/null || git rev-parse HEAD~1 2>/dev/null || git rev-parse HEAD 2>/dev/null || printf 'HEAD')"

  cat > "$prompt_file" <<EOF
$(reviewer_skill_hint)

You are running the Humanize Flow reviewer for this repository.

Task id: $bd_id
Handoff slug: ${slug:-unknown}
Handoff path: ${file:-not-found}
Review output path requested by caller: $review_file
Suggested git base: $base

$(language_instruction)

Follow the humanize-flow-reviewer skill exactly:
- Inspect the Beads task, handoff, plan, acceptance criteria, git status, and diff.
- Treat a missing approved handoff, plan, or acceptance criteria as a blocked review, not a pass.
- Do not implement fixes.
- Produce a review in Markdown using verdict: pass, changes_requested, or blocked.
- Include blocking findings with severity labels [P0]..[P3].
- If the verdict is pass, include a "Human verification guide" section with concrete manual test steps and a checkbox checklist for the human to complete before commit/push.
- If the verdict is changes_requested or blocked, include a "Human correction options" section explaining what context corrections, exclusions, or scope clarifications could change the verdict.
- State exactly what must happen before the task can close.
EOF

  info "review prompt: $prompt_file"
  info "review yolo: $yolo"
  if [ "$yolo" = "true" ]; then
    info "review codex mode: dangerously-bypass-approvals-and-sandbox"
  else
    info "review sandbox: $sandbox"
  fi
  prompt_text="$(cat "$prompt_file")"
  if [ "$yolo" = "true" ]; then
    run_codex_exec --yolo "$prompt_text" | tee "$review_file"
  else
    run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$review_file"
  fi
  if [ -n "$slug" ]; then
    set_handoff_artifact "$slug" "latest_review" "$review_file"
  fi
  info "review written: $review_file"
}

cmd_review_feedback() {
  require_git_repo
  local ref="" note="" from_file="" review_file="" bd_id slug file run_dir prompt_file feedback_file output_file review_dir base prompt_text safe_ref editor sandbox yolo
  sandbox="$(review_sandbox_default)"
  yolo="$(review_yolo_default)"
  while [ $# -gt 0 ]; do
    case "$1" in
      --note) shift; note="${1:-}" ;;
      --from) shift; from_file="${1:-}" ;;
      --review) shift; review_file="${1:-}" ;;
      --sandbox) shift; sandbox="${1:-}"; yolo="false" ;;
      --yolo) yolo="true" ;;
      --no-yolo) yolo="false" ;;
      --help|-h|help)
        cat <<'EOF'
Usage:
  humanize-flow review-feedback BD_ID_OR_SLUG [--yolo|--no-yolo] [--sandbox MODE]
  humanize-flow review-feedback BD_ID_OR_SLUG --note "manual test feedback" [--yolo|--no-yolo] [--sandbox MODE]
  humanize-flow review-feedback BD_ID_OR_SLUG --from docs/manual-test-notes.md [--yolo|--no-yolo] [--sandbox MODE]
  humanize-flow review-feedback BD_ID_OR_SLUG --review docs/.../reviews/latest.md --note "..." [--yolo|--no-yolo] [--sandbox MODE]

Merges human manual-test feedback or review corrections with the latest Codex
review and writes a new consolidated review report. The consolidated report
may keep the verdict, change pass to changes_requested, or change
changes_requested/blocked to pass when the human correction changes the review
scope or evidence.

Without --note or --from, opens ${VISUAL:-${EDITOR:-vi}} for writing feedback
and continues after the editor exits.
Default review-feedback mode is yolo, which passes Codex
--dangerously-bypass-approvals-and-sandbox to avoid approval prompts.
Set review.yolo=false, HUMANIZE_FLOW_REVIEW_YOLO=false, --no-yolo, or
--sandbox MODE to use normal sandboxed Codex execution. Supported sandbox
modes: read-only, workspace-write, danger-full-access.
EOF
        return 0 ;;
      --*) die "Unknown review-feedback option: $1" ;;
      *)
        if [ -z "$ref" ]; then ref="$1"; else die "Unexpected review-feedback argument: $1"; fi
        ;;
    esac
    shift
  done

  sandbox="$(normalize_sandbox_mode "$sandbox")" || die "Unsupported review sandbox: $sandbox (supported: read-only, workspace-write, danger-full-access)"
  yolo="$(normalize_bool "$yolo")" || die "Unsupported review yolo value: $yolo (supported: true, false)"
  [ -n "$ref" ] || die "Usage: humanize-flow review-feedback BD_ID_OR_SLUG [--note TEXT|--from FILE]"
  if [ -n "$from_file" ] && [ ! -f "$from_file" ]; then
    die "feedback file not found: $from_file"
  fi
  command_exists codex || die "codex CLI not found."

  slug="$(find_handoff_for_ref "$ref" 2>/dev/null || true)"
  if [ -n "$slug" ]; then
    bd_id="$(default_bd_id_for_slug "$slug" 2>/dev/null || true)"
  fi
  if [ -z "${bd_id:-}" ]; then bd_id="$ref"; fi
  if [ -n "$slug" ]; then file="$(handoff_path "$slug")"; else file=""; fi
  if [ -z "$review_file" ] && [ -n "$slug" ]; then
    review_file="$(latest_review_for_slug "$slug" 2>/dev/null || true)"
  fi
  [ -n "$review_file" ] || die "No prior review found. Pass --review FILE or run humanize-flow review first."
  [ -f "$review_file" ] || die "review file not found: $review_file"

  run_dir="$(state_dir)/runs/$(timestamp)-review-feedback-$ref"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-review-feedback-prompt.md"
  feedback_file="$run_dir/human-feedback.md"
  review_dir="$(docs_dir)/${slug:-unknown}/reviews"
  mkdir -p "$review_dir"
  safe_ref="$(slugify "$ref")"
  output_file="$review_dir/$(timestamp)-$safe_ref-human-feedback.md"
  base="$(git merge-base HEAD main 2>/dev/null || git merge-base HEAD master 2>/dev/null || git rev-parse HEAD~1 2>/dev/null || git rev-parse HEAD 2>/dev/null || printf 'HEAD')"

  if [ -n "$note" ] || [ -n "$from_file" ]; then
    {
      if [ -n "$note" ]; then
        printf '%s\n' "$note"
      fi
      if [ -n "$from_file" ]; then
        [ -z "$note" ] || printf '\n'
        cat "$from_file"
      fi
    } > "$feedback_file"
  else
    if [ ! -t 0 ] && [ -z "${VISUAL:-}" ] && [ -z "${EDITOR:-}" ]; then
      die "review-feedback needs --note/--from in non-interactive mode unless VISUAL or EDITOR is set."
    fi
    cat > "$feedback_file" <<'EOF'
# Write manual-test feedback or review correction notes below.
# Lines starting with # are ignored.
# Save and quit the editor to continue.

EOF
    editor="${VISUAL:-${EDITOR:-vi}}"
    info "opening editor for human feedback: $editor"
    # shellcheck disable=SC2086
    $editor "$feedback_file" || die "editor exited unsuccessfully"
    python3 - "$feedback_file" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
lines = [
    line.rstrip()
    for line in path.read_text(encoding='utf-8').splitlines()
    if not line.lstrip().startswith('#')
]
text = '\n'.join(lines).strip()
path.write_text((text + '\n') if text else '', encoding='utf-8')
PY
  fi
  [ -s "$feedback_file" ] || die "human feedback is empty; aborted."

  cat > "$prompt_file" <<EOF
$(reviewer_skill_hint)

You are updating a Humanize Flow review with human manual-test feedback or human correction notes.

Task id: $bd_id
Handoff slug: ${slug:-unknown}
Handoff path: ${file:-not-found}
Prior review: $review_file
Human feedback: $feedback_file
Updated review output path requested by caller: $output_file
Suggested git base: $base

$(language_instruction)

Follow the humanize-flow-reviewer skill and these additional rules:
- Read the Beads task, handoff, plan, acceptance criteria, git status, diff, prior review, and human feedback.
- Treat human feedback as additional evidence or scope correction, not as an automatic override.
- Reconcile disagreements explicitly: state whether the feedback changes the review scope, invalidates a prior finding, adds a new finding, or supplies missing verification evidence.
- Re-evaluate the final verdict: pass, changes_requested, or blocked.
- If human feedback says a file or diff should be excluded, verify that exclusion against the approved plan/handoff before accepting it.
- If the updated verdict is pass, include a "Human verification guide" section with concrete manual test steps and a checkbox checklist to complete before commit/push.
- If the updated verdict is changes_requested or blocked, include the exact next command to return to the worker, usually: humanize-flow run $bd_id
- Preserve links/paths to the prior review and human feedback artifact.
- Do not implement fixes.
EOF

  info "review feedback prompt: $prompt_file"
  info "human feedback saved: $feedback_file"
  info "review feedback yolo: $yolo"
  if [ "$yolo" = "true" ]; then
    info "review feedback codex mode: dangerously-bypass-approvals-and-sandbox"
  else
    info "review feedback sandbox: $sandbox"
  fi
  prompt_text="$(cat "$prompt_file")"
  if [ "$yolo" = "true" ]; then
    run_codex_exec --yolo "$prompt_text" | tee "$output_file"
  else
    run_codex_exec --sandbox "$sandbox" "$prompt_text" | tee "$output_file"
  fi
  if [ -n "$slug" ]; then
    set_handoff_artifact "$slug" "latest_review" "$output_file"
    set_handoff_artifact "$slug" "latest_human_feedback" "$feedback_file"
  fi
  info "updated review written: $output_file"
}

commit_failure_looks_hook_related() {
  local log_file
  log_file="$1"
  grep -Eiq '(hook|pre-commit|pre commit|lefthook|husky|lint-staged|eslint|prettier|typecheck|tsc|biome|stylelint|test)' "$log_file"
}

show_selected_cached_stat() {
  local paths_file path
  paths_file="$1"
  while IFS= read -r path || [ -n "$path" ]; do
    [ -n "$path" ] || continue
    git diff --cached --stat -- "$path"
  done < "$paths_file"
}

create_commit_failure_bd() {
  local run_dir log_file message_file prompt_file task_file output_file prompt_text answer
  run_dir="$1"; log_file="$2"; message_file="$3"

  if ! command_exists bd; then
    warn "bd CLI not found; cannot create a Beads task for the commit failure."
    return 0
  fi
  if [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" = "1" ]; then
    warn "non-interactive mode; skipped Beads task prompt for commit failure."
    return 0
  fi

  printf 'Create a Beads task to fix this commit hook failure? [y/N] '
  read -r answer
  case "$answer" in
    y|Y|yes|YES) ;;
    *) info "skipped Beads task creation for commit failure."; return 0 ;;
  esac

  prompt_file="$run_dir/codex-hook-failure-bd-prompt.md"
  task_file="$run_dir/hook-failure-bd.json"
  output_file="$run_dir/hook-failure-bd-create-output.json"
  cat > "$prompt_file" <<EOF
You are drafting a Beads task for a failed git commit hook.

$(language_instruction)

Inspect:
- Commit failure log: $log_file
- Proposed commit message: $message_file
- Selected commit paths when available: $(dirname "$message_file")/commit-paths.txt
- git status --short --untracked-files=all
- git diff --cached --stat for the selected commit paths
- git diff --cached for the selected commit paths
- Relevant repository guidance files, especially AGENTS.md and CLAUDE.md when present.

Return only JSON with this shape:
{
  "title": "short task title",
  "description": "actionable task description",
  "priority": 2,
  "labels": ["humanize-flow", "commit-hook"]
}

Rules:
- The task should be about making the commit hook pass.
- Distinguish likely code issues from likely local environment issues.
- Include the failed hook/check name when visible.
- Mention the saved failure log path.
- Do not return Markdown fences or explanation.
EOF
  info "hook failure Beads prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec "$prompt_text" > "$task_file"
  sed -i.bak '/^```/d' "$task_file"
  rm -f "$task_file.bak"

  python3 - "$task_file" "$log_file" "$output_file" <<'PY'
import json, re, subprocess, sys
from pathlib import Path

task_path = Path(sys.argv[1])
log_path = Path(sys.argv[2])
output_path = Path(sys.argv[3])
raw = task_path.read_text(encoding="utf-8").strip()
try:
    data = json.loads(raw)
except Exception:
    match = re.search(r"\{.*\}", raw, re.S)
    if not match:
        raise SystemExit(f"could not parse Codex Beads task JSON: {task_path}")
    data = json.loads(match.group(0))

title = str(data.get("title") or "Fix commit hook failure").strip()
description = str(data.get("description") or "").strip()
priority = str(data.get("priority") or "2").strip()
labels = data.get("labels") or []
if isinstance(labels, str):
    labels = [part.strip() for part in labels.split(",")]
labels = [re.sub(r"[^A-Za-z0-9_.-]+", "-", str(label).strip()).strip("-") for label in labels]
labels = [label for label in labels if label]
for label in ("humanize-flow", "commit-hook"):
    if label not in labels:
        labels.append(label)
if priority not in {"0", "1", "2", "3", "4", "5"}:
    priority = "2"
if not description:
    description = "A git commit hook failed during `humanize-flow commit`."
description = description.rstrip() + f"\n\nFailure log: `{log_path}`\n"

args = [
    "bd",
    "create",
    title,
    "-t",
    "task",
    "-p",
    priority,
    "--description",
    description,
    "-l",
    ",".join(labels),
    "--json",
]
cp = subprocess.run(args, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
if cp.returncode != 0:
    sys.stderr.write(cp.stderr)
    raise SystemExit(cp.returncode)
output_path.write_text(cp.stdout, encoding="utf-8")
print(cp.stdout.strip())
PY
  info "created Beads task for commit failure; output saved: $output_file"
}

handle_commit_failure() {
  local run_dir log_file message_file
  run_dir="$1"; log_file="$2"; message_file="$3"
  warn "git commit failed; output saved: $log_file"
  cat "$log_file" >&2
  if commit_failure_looks_hook_related "$log_file"; then
    create_commit_failure_bd "$run_dir" "$log_file" "$message_file"
  else
    warn "commit failure does not look like a hook/lint/test failure; skipped Beads task prompt."
  fi
}

cmd_commit() {
  require_git_repo
  local yes=0 message_file prompt_file run_dir prompt_text first_line stage_prompt_file stage_paths_file commit_paths_file selected_count path commit_log commit_status answer
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes|-y) yes=1 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow commit [--yes]

Creates a commit with Codex-selected paths and a Codex-drafted Lore commit
message. Codex always reviews the full working tree, including staged and
unstaged changes, then selects which changed paths belong in this commit.
EOF
        return 0 ;;
      *) die "Unknown commit option: $1" ;;
    esac
    shift
  done
  command_exists codex || die "codex CLI not found."
  run_dir="$(state_dir)/runs/$(timestamp)-commit"
  mkdir -p "$run_dir"
  stage_prompt_file="$run_dir/codex-stage-prompt.md"
  stage_paths_file="$run_dir/stage-paths.txt"
  commit_paths_file="$run_dir/commit-paths.txt"
  if [ -z "$(git status --porcelain --untracked-files=all)" ]; then
    die "No changes to commit."
  fi
  cat > "$stage_prompt_file" <<EOF
You are selecting which changed files belong in one git commit.

$(language_instruction)

Inspect:
- git status --short --untracked-files=all
- git diff --cached --stat
- git diff --cached
- git diff --stat
- git diff
- Relevant repository guidance files, especially AGENTS.md and CLAUDE.md in the root or along changed paths when present.

Rules:
- Return only repository-relative file paths to commit, one per line.
- Do not return Markdown, bullets, quotes, explanations, directories, commands, or absolute paths.
- Include only files that belong in this commit.
- Treat existing staged changes as advisory context only; they may be accidental, incomplete, or unrelated.
- Include unstaged paths when they belong with the commit, even if other paths were already staged.
- Exclude staged paths when they do not belong with the commit.
- Exclude unrelated user changes, generated local runtime files, accidental command output, secrets, credentials, build artifacts, temp files, and anything repository guidance says not to commit.
- If no changed file should be committed, return exactly: NONE
- Do not run git add, git commit, or modify files.
EOF
  info "commit path selection prompt: $stage_prompt_file"
  prompt_text="$(cat "$stage_prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec "$prompt_text" > "$stage_paths_file"
  sed -i.bak '/^```/d' "$stage_paths_file"
  rm -f "$stage_paths_file.bak"
  : > "$commit_paths_file"
  selected_count=0
  while IFS= read -r path || [ -n "$path" ]; do
    path="${path%$'\r'}"
    [ -n "$path" ] || continue
    [ "$path" != "NONE" ] || continue
    case "$path" in
      /*|../*|*/../*|.git|.git/*)
        die "Codex selected an unsafe path to commit: $path"
        ;;
    esac
    if [ -z "$(git status --porcelain --untracked-files=all -- "$path")" ]; then
      die "Codex selected a path with no working tree changes: $path"
    fi
    printf '%s\n' "$path" >> "$commit_paths_file"
    git add -- "$path"
    selected_count=$((selected_count + 1))
  done < "$stage_paths_file"
  [ "$selected_count" -gt 0 ] || die "Codex did not select any files to commit. Selection kept at $stage_paths_file"
  info "selected $selected_count path(s) for commit; selection saved: $commit_paths_file"
  prompt_file="$run_dir/codex-commit-prompt.md"
  message_file="$run_dir/commit-message.txt"
  cat > "$prompt_file" <<EOF
You are writing a git commit message for the selected commit paths only.

Selected paths:
$(sed 's/^/- /' "$commit_paths_file")

$(language_instruction)

Inspect:
- git status --short
- Selected path list: $commit_paths_file
- git diff --cached --stat -- <selected paths>
- git diff --cached -- <selected paths>

Return only the commit message, with no Markdown fences and no explanation.
Use the Lore Commit Protocol:

<intent line: why the change was made, not what changed>

<body: narrative context, constraints, approach rationale>

Constraint: <external constraint that shaped the decision>
Rejected: <alternative considered> | <reason>
Confidence: <low|medium|high>
Scope-risk: <narrow|moderate|broad>
Directive: <forward-looking warning if useful>
Tested: <what was verified>
Not-tested: <known gaps>

Keep the first line under 72 characters. Be honest about tests.
EOF
  info "commit prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  # shellcheck disable=SC2086
  run_codex_exec "$prompt_text" > "$message_file"
  sed -i.bak '/^```/d' "$message_file"
  rm -f "$message_file.bak"
  first_line="$(sed -n '1p' "$message_file")"
  [ -n "$first_line" ] || die "Codex returned an empty commit message."
  info "selected changes:"
  show_selected_cached_stat "$commit_paths_file"
  info "commit message: $message_file"
  log ""
  sed -n '1,120p' "$message_file"
  log ""
  if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ]; then
    printf 'Create commit with this message? [y/N] '
    read -r answer
    case "$answer" in
      y|Y|yes|YES) ;;
      *) die "Commit cancelled. Message kept at $message_file" ;;
    esac
  fi
  commit_log="$run_dir/git-commit.log"
  set +e
  git commit --only --pathspec-from-file="$commit_paths_file" -F "$message_file" > "$commit_log" 2>&1
  commit_status=$?
  set -e
  if [ "$commit_status" -ne 0 ]; then
    handle_commit_failure "$run_dir" "$commit_log" "$message_file"
    return "$commit_status"
  fi
  cat "$commit_log"
}

cmd_push() {
  require_git_repo
  local remote="" branch remotes count idx answer
  while [ $# -gt 0 ]; do
    case "$1" in
      --remote) shift; remote="${1:-}" ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow push [--remote NAME]

Pushes the current branch. If no remote is provided and more than one remote
exists, prompts for a remote number.
EOF
        return 0 ;;
      *) die "Unknown push option: $1" ;;
    esac
    shift
  done
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || die "Cannot determine current branch."
  if [ -z "$remote" ]; then
    remotes="$(git remote)"
    count="$(printf '%s\n' "$remotes" | sed '/^$/d' | wc -l | tr -d ' ')"
    [ "$count" -gt 0 ] || die "No git remotes configured."
    if [ "$count" -eq 1 ]; then
      remote="$(printf '%s\n' "$remotes" | sed '/^$/d' | sed -n '1p')"
    else
      log "Available remotes:"
      idx=1
      while IFS= read -r r; do
        [ -n "$r" ] || continue
        printf '  %s. %s\n' "$idx" "$r"
        idx=$((idx + 1))
      done <<EOF
$remotes
EOF
      if [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" = "1" ]; then
        die "Multiple remotes configured; pass --remote NAME in non-interactive mode."
      fi
      printf 'Select remote number or name: '
      read -r answer
      if printf '%s\n' "$answer" | grep -Eq '^[0-9]+$'; then
        remote="$(printf '%s\n' "$remotes" | sed '/^$/d' | sed -n "${answer}p")"
      else
        remote="$answer"
      fi
      [ -n "$remote" ] || die "Invalid remote selection."
    fi
  fi
  if ! git remote get-url "$remote" >/dev/null 2>&1; then
    die "Unknown remote: $remote"
  fi
  info "pushing $branch to $remote"
  git push -u "$remote" "$branch"
}

guess_pr_base() {
  local branch configured origin_head
  branch="$(git branch --show-current)"
  configured="$(git config --get "branch.$branch.gh-merge-base" 2>/dev/null || true)"
  if [ -n "$configured" ]; then
    printf '%s\n' "$configured"
    return 0
  fi
  origin_head="$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##' || true)"
  if [ -n "$origin_head" ]; then
    printf '%s\n' "$origin_head"
    return 0
  fi
  if git show-ref --verify --quiet refs/heads/main || git show-ref --verify --quiet refs/remotes/origin/main; then
    printf 'main\n'
    return 0
  fi
  if git show-ref --verify --quiet refs/heads/master || git show-ref --verify --quiet refs/remotes/origin/master; then
    printf 'master\n'
    return 0
  fi
  printf 'main\n'
}

cmd_pr() {
  require_git_repo
  local base="" head="" draft=0 dry_run=0 yes=0 push_first=0 remote="" run_dir prompt_file draft_file title_file body_file prompt_text branch merge_base pr_url answer
  while [ $# -gt 0 ]; do
    case "$1" in
      --base) shift; base="${1:-}" ;;
      --head) shift; head="${1:-}" ;;
      --remote) shift; remote="${1:-}" ;;
      --draft) draft=1 ;;
      --dry-run) dry_run=1 ;;
      --yes|-y) yes=1 ;;
      --push) push_first=1 ;;
      --help|-h)
        cat <<'EOF'
Usage:
  humanize-flow pr [--base BRANCH] [--head BRANCH] [--draft] [--push] [--yes] [--dry-run]

Uses Codex to draft a detailed, professional pull request title and body, then
creates the PR with GitHub CLI. The generated PR text follows the configured
Humanize Flow i18n language.

Options:
  --base BRANCH   Base branch for the PR. Defaults to branch gh-merge-base,
                  origin/HEAD, main, then master.
  --head BRANCH   Head branch for the PR. Defaults to the current branch.
  --remote NAME   Remote used by --push.
  --draft         Create a draft PR.
  --push          Push the current branch before creating the PR.
  --yes, -y       Skip confirmation after showing the generated PR draft.
  --dry-run       Generate and show the draft, but do not create the PR.
EOF
        return 0 ;;
      *) die "Unknown pr option: $1" ;;
    esac
    shift
  done

  command_exists codex || die "codex CLI not found."
  if [ "$dry_run" -ne 1 ]; then
    command_exists gh || die "GitHub CLI 'gh' not found."
  fi
  branch="$(git branch --show-current)"
  [ -n "$branch" ] || die "Cannot determine current branch."
  if [ -z "$head" ]; then head="$branch"; fi
  if [ -z "$base" ]; then base="$(guess_pr_base)"; fi
  [ "$head" != "$base" ] || die "Current/head branch '$head' matches base '$base'; create or switch to a feature branch before opening a PR."
  merge_base="$(git merge-base HEAD "$base" 2>/dev/null || git merge-base HEAD "origin/$base" 2>/dev/null || true)"
  [ -n "$merge_base" ] || die "Could not determine merge base for $base. Pass --base BRANCH or fetch the base branch."
  if git diff --quiet "$merge_base"..HEAD && [ -z "$(git log --oneline "$merge_base"..HEAD)" ]; then
    die "No commits or diff found between $base and HEAD."
  fi

  if [ "$push_first" -eq 1 ]; then
    if [ -n "$remote" ]; then cmd_push --remote "$remote"; else cmd_push; fi
  fi

  run_dir="$(state_dir)/runs/$(timestamp)-pr"
  mkdir -p "$run_dir"
  prompt_file="$run_dir/codex-pr-prompt.md"
  draft_file="$run_dir/pr-draft.json"
  title_file="$run_dir/pr-title.txt"
  body_file="$run_dir/pr-body.md"

  cat > "$prompt_file" <<EOF
You are drafting a professional GitHub pull request for this repository.

Base branch: $base
Head branch: $head
Merge base: $merge_base
PR title output: $title_file
PR body output: $body_file

$(language_instruction)

Inspect:
- git status --short
- git log --oneline $merge_base..HEAD
- git log --format=fuller $merge_base..HEAD
- git diff --stat $merge_base..HEAD
- git diff $merge_base..HEAD
- docs/humanize-flow artifacts relevant to this branch, especially request.md, plan.md, acceptance.md, implementation summaries, and review reports.
- .humanize-flow/handoffs/*.json when relevant.
- AGENTS.md and CLAUDE.md when present.

Return only JSON with this shape:
{
  "title": "concise PR title",
  "body": "professional Markdown PR body"
}

PR body requirements:
- Be detailed enough for a maintainer to review without reconstructing context from scratch.
- Include sections for summary, why/context, notable changes, verification, risks/rollback, and reviewer notes.
- Mention Humanize Flow handoff, Beads task ids, plan, acceptance, implementation summary, and review artifact paths when relevant.
- Use concrete test commands and outcomes when visible. If verification is not visible, say that honestly.
- Do not invent issue numbers, test results, reviewers, or external facts.
- Keep machine-readable literals canonical: file paths, commands, labels, JSON keys, APIs, Beads IDs, branch names, and commit hashes.
- Do not include Markdown fences around the JSON.
EOF

  info "PR prompt: $prompt_file"
  prompt_text="$(cat "$prompt_file")"
  run_codex_exec "$prompt_text" > "$draft_file"
  sed -i.bak '/^```/d' "$draft_file"
  rm -f "$draft_file.bak"
  python3 - "$draft_file" "$title_file" "$body_file" <<'PY'
import json, re, sys
from pathlib import Path

draft_path = Path(sys.argv[1])
title_path = Path(sys.argv[2])
body_path = Path(sys.argv[3])
raw = draft_path.read_text(encoding="utf-8").strip()
try:
    data = json.loads(raw)
except Exception:
    match = re.search(r"\{.*\}", raw, re.S)
    if not match:
        raise SystemExit(f"could not parse Codex PR JSON: {draft_path}")
    data = json.loads(match.group(0))
title = str(data.get("title") or "").strip()
body = str(data.get("body") or "").strip()
if not title:
    raise SystemExit("Codex returned an empty PR title")
if not body:
    raise SystemExit("Codex returned an empty PR body")
title_path.write_text(title.splitlines()[0].strip() + "\n", encoding="utf-8")
body_path.write_text(body.rstrip() + "\n", encoding="utf-8")
PY

  info "PR title: $title_file"
  info "PR body: $body_file"
  log ""
  printf 'Title: '
  sed -n '1p' "$title_file"
  log ""
  sed -n '1,220p' "$body_file"
  log ""

  if [ "$dry_run" -eq 1 ]; then
    info "--dry-run set; PR not created."
    return 0
  fi
  if [ "$yes" -ne 1 ] && [ "${HUMANIZE_FLOW_NONINTERACTIVE:-0}" != "1" ]; then
    printf 'Create PR with this title and body? [y/N] '
    read -r answer
    case "$answer" in
      y|Y|yes|YES) ;;
      *) die "PR creation cancelled. Draft kept in $run_dir" ;;
    esac
  fi

  if [ "$draft" -eq 1 ]; then
    pr_url="$(gh pr create --base "$base" --head "$head" --title "$(cat "$title_file")" --body-file "$body_file" --draft)"
  else
    pr_url="$(gh pr create --base "$base" --head "$head" --title "$(cat "$title_file")" --body-file "$body_file")"
  fi
  printf '%s\n' "$pr_url"
}

cmd_status() {
  require_git_repo
  local hdir
  hdir="$(state_dir)/handoffs"
  if [ ! -d "$hdir" ]; then
    warn "No .humanize-flow/handoffs directory. Run humanize-flow init first."
  else
    python3 - "$hdir" <<'PY'
import json, sys
from pathlib import Path
root = Path(sys.argv[1])
print('Handoffs:')
for path in sorted(root.glob('*.json')):
    try:
        data = json.loads(path.read_text(encoding='utf-8'))
    except Exception as e:
        print(f'  {path.name}: invalid JSON: {e}')
        continue
    approval = data.get('approval', {}).get('status', 'unknown')
    materialized = data.get('bd', {}).get('materialized', False)
    print(f"  {data.get('slug', path.stem):24} state={data.get('state','?'):18} approval={approval:9} bd_materialized={materialized}")
PY
  fi
  if command_exists bd; then
    log ""
    log "Ready Beads tasks:"
    bd ready --json 2>/dev/null || bd ready || true
  fi
}

main() {
  local cmd
  cmd="${1:-help}"
  if [ $# -gt 0 ]; then shift; fi
  case "$cmd" in
    help|--help|-h) usage ;;
    version|--version) log "$HF_VERSION" ;;
    paths) cmd_paths "$@" ;;
    doctor) cmd_doctor "$@" ;;
    init) cmd_init "$@" ;;
    plan) cmd_plan "$@" ;;
    plan-from-bd|from-bd) cmd_plan_from_bd "$@" ;;
    approve) cmd_approve "$@" ;;
    materialize-bd) cmd_materialize_bd "$@" ;;
    run) cmd_run "$@" ;;
    run-next) cmd_run_next "$@" ;;
    review) cmd_review "$@" ;;
    review-feedback) cmd_review_feedback "$@" ;;
    commit) cmd_commit "$@" ;;
    push) cmd_push "$@" ;;
    pr) cmd_pr "$@" ;;
    status) cmd_status "$@" ;;
    config) cmd_config "$@" ;;
    i18n) cmd_i18n "$@" ;;
    *) die "Unknown command: $cmd. Run 'humanize-flow help'." ;;
  esac
}

main "$@"
