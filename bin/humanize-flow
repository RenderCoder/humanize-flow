  fi
}

review_scope_instruction() {
  local ref slug bd_id file
  ref="$1"; slug="$2"; bd_id="$3"
  if [ -z "$slug" ]; then
    cat <<EOF
Review scope:
- Review only the requested Beads task id: $bd_id.
- Do not fail this review for unrelated tasks or unrelated repository changes unless they directly break this task.
EOF
    return
  fi
  file="$(handoff_path "$slug")"
  run_python3 - "$file" "$ref" "$slug" "$bd_id" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
ref = sys.argv[2]
slug = sys.argv[3]
bd_id = sys.argv[4]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    data = {}
bd = data.get('bd') or {}
epic = bd.get('epic') or {}
epic_id = epic.get('bd_id') if isinstance(epic, dict) else None
task_ids = [
    task.get('bd_id')
    for task in (bd.get('tasks') or [])
    if isinstance(task, dict) and task.get('bd_id')
]
is_epic_scope = ref in {slug, data.get('slug'), path.stem} or (epic_id and ref == epic_id)
if task_ids and bd_id in task_ids and not is_epic_scope:
    print("Review scope:")
    print(f"- Review only Beads task `{bd_id}` within handoff `{slug}`.")
    print("- Do not require sibling tasks from the same Epic/handoff to be complete.")
    print("- Do not fail this review because the overall Epic is incomplete; fail only for gaps, regressions, tests, or acceptance criteria that belong to this task or directly block this task.")
    print("- You may read the full handoff and plan for context, but verdict must be scoped to this task.")
else:
    print("Review scope:")
    print(f"- Review the full approved handoff scope for `{slug}`.")
    print("- If this is an Epic-level review, all child tasks and handoff acceptance criteria must be complete before pass.")
PY
}

yolo_target_ids_for_ref() {
  local ref slug
  ref="$1"; slug="$2"
  run_python3 - "$(handoff_path "$slug")" "$ref" "$slug" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
ref = sys.argv[2]
slug = sys.argv[3]
try:
    data = json.loads(path.read_text(encoding='utf-8'))
except Exception:
    raise SystemExit(1)

bd = data.get('bd') or {}
epic = bd.get('epic') or {}
epic_id = epic.get('bd_id') if isinstance(epic, dict) else None
tasks = [
    task.get('bd_id')
    for task in (bd.get('tasks') or [])
    if isinstance(task, dict) and task.get('bd_id')
]

